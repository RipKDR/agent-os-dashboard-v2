      fn: () => { switchTab('chat'); setTimeout(() => selectChatAgent(a.id), 40); }
    })),
    { label: 'Refresh data',       fn: loadAll,                 key: 'R' },
    { label: 'Browse Skills',      fn: () => showSkillsBrowser(), key: '' },
    { label: 'Model Configuration', fn: () => openModelConfig(),  key: '' },
    { label: 'Quick Note (Cmd+Shift+N)', fn: () => {
      const n = prompt('Quick note:');
      if (n) { const ns = JSON.parse(localStorage.getItem('aos-quick-notes')||'[]'); ns.push({text:n,time:new Date().toISOString()}); localStorage.setItem('aos-quick-notes',JSON.stringify(ns)); toast2('Note saved','success'); }
    }, key: '' },
  ];

  const pal  = document.getElementById('palette');
  const inp  = document.getElementById('pal-in');
  const res  = document.getElementById('pal-res');
  let sel = 0;
  let filtered = CMDS;

  const close = () => { pal.classList.remove('open'); inp.value = ''; };

  const render = () => {
    const q = inp.value.toLowerCase();
    filtered = CMDS.filter(c => !q || c.label.toLowerCase().includes(q));
    sel = 0;
    res.innerHTML = filtered.map((c, i) =>
      `<div class="pal-item ${i === 0 ? 'sel' : ''}" data-i="${i}">
        <span>${c.label}</span>
        ${c.key ? `<span class="pal-key">${c.key}</span>` : ''}
      </div>`
    ).join('');
    res.querySelectorAll('.pal-item').forEach((el, i) =>
      el.addEventListener('click', () => { filtered[i].fn(); close(); })
    );
  };

  const updSel = () => {
    res.querySelectorAll('.pal-item').forEach((el, i) =>
      el.classList.toggle('sel', i === sel)
    );
  };

  inp.addEventListener('input', render);
  inp.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown')  { sel = Math.min(sel + 1, filtered.length - 1); updSel(); e.preventDefault(); }
    if (e.key === 'ArrowUp')    { sel = Math.max(sel - 1, 0); updSel(); e.preventDefault(); }
    if (e.key === 'Enter')      { filtered[sel]?.fn(); close(); }
    if (e.key === 'Escape')     { close(); }
  });
  pal.addEventListener('click', e => { if (e.target === pal) close(); });

  document.addEventListener('keydown', e => {
    const inInput = ['INPUT','TEXTAREA'].includes(document.activeElement.tagName);
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      pal.classList.add('open');
      render();
      setTimeout(() => inp.focus(), 10);
    }
    if ((e.metaKey || e.ctrlKey) && !e.shiftKey && e.key.toLowerCase() === 'n') {
      e.preventDefault();
      e.stopPropagation();
      showCapture();
    }
    if (!inInput && !pal.classList.contains('open')) {
      if (e.key === '1') switchTab('ov');
      if (e.key === '2') switchTab('log');
      if (e.key === '3') switchTab('task');
      if (e.key === '4') switchTab('chat');
      if (e.key === '5') { switchTab('files'); loadDir(''); }
      if (e.key === '6') switchTab('orch');
      if (e.key === '7') switchTab('github');
      if (e.key === '8') { switchTab('brain'); loadBrainSessions(); }
      if (e.key === '9') { switchTab('learn'); loadLearnTab(); }
      if (e.key === '0') { switchTab('terminal'); }
      if (e.key === '-' || e.key === '=') { switchTab('settings'); renderSettings(); }
      if (e.key === 'r' || e.key === 'R') loadAll();
    }
  });
}

