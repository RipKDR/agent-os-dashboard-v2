function loadRisks() {
  const el = document.getElementById('risks-content');
  if (!el) return;
  
  const tasks = allLogs || [];
  const now = new Date();
  
  // Derive risks from agent_logs
  const recentTasks = tasks.slice(0, 100);
  const failed = recentTasks.filter(t => t.status === 'failed');
  const stale = {};
  
  // Check which agents haven't run recently
  AGENTS.forEach(a => {
    const lastTask = tasks.filter(t => t.agent_name?.toLowerCase() === a.id)[0];
    if (lastTask) {
      const hoursSince = (now - new Date(lastTask.created_at)) / 3600000;
      if (hoursSince > 24) stale[a.id] = Math.round(hoursSince);
    }
  });
  
  // Count today's failures
  const todayFailures = tasks.filter(t => {
    const d = new Date(t.created_at);
    return t.status === 'failed' && d.toDateString() === now.toDateString();
  });
  
  let html = '<div style="display:flex;flex-direction:column;gap:6px">';
  
  // Summary strip
  html += `
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
      <div style="padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:4px;text-align:center">
        <div style="font-size:20px;color:${todayFailures.length > 0 ? 'var(--red)' : 'var(--green)'}">${todayFailures.length}</div>
        <div style="font-size:8px;color:var(--faint);text-transform:uppercase;letter-spacing:0.10em;margin-top:4px">Failed Today</div>
      </div>
      <div style="padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:4px;text-align:center">
        <div style="font-size:20px;color:${Object.keys(stale).length > 0 ? 'var(--amber)' : 'var(--green)'}">${Object.keys(stale).length}</div>
        <div style="font-size:8px;color:var(--faint);text-transform:uppercase;letter-spacing:0.10em;margin-top:4px">Stale Agents</div>
      </div>
      <div style="padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:4px;text-align:center">
        <div style="font-size:20px;color:var(--amber)">${recentTasks.length}</div>
        <div style="font-size:8px;color:var(--faint);text-transform:uppercase;letter-spacing:0.10em;margin-top:4px">Recent Tasks</div>
      </div>
    </div>`;
  
  // Failed tasks
  if (failed.length > 0) {
    html += `<div style="margin-top:6px;padding:8px 10px;background:var(--surface);border:1px solid var(--border);border-radius:4px">
      <div style="font-size:9px;color:var(--red);text-transform:uppercase;letter-spacing:0.10em;margin-bottom:6px">❌ Recent Failures</div>`;
    failed.slice(0, 5).forEach(t => {
      html += `<div style="display:flex;gap:8px;padding:4px 0;font-size:10px;border-bottom:1px solid var(--border)">
        <span style="color:var(--amber);width:60px">${escHtml(t.agent_name || '?')}</span>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtml((t.task_description || '').slice(0, 60))}</span>
        <span style="color:var(--faint)">${fmtDt(t.created_at)}</span>
      </div>`;
    });
    html += '</div>';
  }
  
  // Stale agents
  if (Object.keys(stale).length > 0) {
    html += `<div style="margin-top:6px;padding:8px 10px;background:var(--surface);border:1px solid var(--border);border-radius:4px">
      <div style="font-size:9px;color:var(--amber);text-transform:uppercase;letter-spacing:0.10em;margin-bottom:6px">😴 Stale Agents</div>`;
    Object.entries(stale).forEach(([agent, hours]) => {
      const name = AGENTS.find(a => a.id === agent)?.name || agent;
      html += `<div style="display:flex;gap:8px;padding:4px 0;font-size:10px">
        <span style="color:var(--amber);width:60px">${escHtml(name)}</span>
        <span style="color:var(--dim)">${hours}h since last task</span>
      </div>`;
    });
    html += '</div>';
  }
  
  if (!failed.length && !Object.keys(stale).length) {
    html += '<div class="empty" style="margin-top:6px"><div class="empty-t">All Clear</div><div class="empty-s">No failed tasks or stale agents</div></div>';
  }
  
  html += '</div>';
  el.innerHTML = html;
}

