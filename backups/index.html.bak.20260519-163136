      <div class="ac-task">${escHtml(task)}</div>
      <div class="ac-time-on-task">${last ? timeOnTask(last.created_at) : '—'}</div>
      <div class="ac-meta">
        <div>
          <div class="ac-mv amber">${logs.length}</div>
          <div class="ac-ml">Total</div>
        </div>
        <div>
          <div class="ac-mv green">${done}</div>
          <div class="ac-ml">Done</div>
        </div>
        <div>
          <div class="ac-mv red">${fail}</div>
          <div class="ac-ml">Fail</div>
        </div>
      </div>
      <div class="ac-spark"><canvas id="sp-${a.id}"></canvas></div>
      <button class="ac-dispatch-btn" onclick="toggleDispatch('${a.id}',event)">Dispatch ▸</button>
      <div class="ac-composer" id="ac-composer-${a.id}" style="display:none" onclick="event.stopPropagation()">
        <textarea id="ac-task-input-${a.id}" class="ac-task-input" placeholder="Task for ${escHtml(a.name)}…" rows="2"></textarea>
        <div class="ac-composer-actions">
          <button class="mini-btn" onclick="toggleDispatch('${a.id}',event)">Cancel</button>
          <button class="mini-btn primary" onclick="dispatchCardTask('${a.id}',event)">Send ▸</button>
        </div>
      </div>
    </div>`;
  }).join('');

  requestAnimationFrame(() => AGENTS.forEach(a => drawSpark(a.id, dateStrs)));
}

function drawSpark(id, dateStrs) {
  const canvas = document.getElementById(`sp-${id}`);
  if (!canvas) return;

  const logs = logsByAgent[id] || [];
  const vals = dateStrs.map(ds => logs.filter(l => new Date(l.created_at).toDateString() === ds).length);

  if (sparklines[id]) {
    sparklines[id].data.datasets[0].data = vals;
    sparklines[id].update('none');
    return;
  }

  // Lazy-load Chart.js if not loaded yet (guard against concurrent loads)
  if (typeof Chart === 'undefined') {
    if (!window._chartLoading) {
      window._chartLoading = true;
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js';
      s.onload = () => { window._chartLoading = false; drawSpark(id, dateStrs); };
      s.onerror = () => { window._chartLoading = false; };
      document.head.appendChild(s);
    } else {
      // Already loading — retry after a short delay
      setTimeout(() => drawSpark(id, dateStrs), 300);
    }
    return;
  }

  sparklines[id] = new Chart(canvas, {
    type: 'line',
    data: {
      labels: vals.map(() => ''),
      datasets: [{
        data: vals,
        borderColor: 'rgba(232,144,10,0.6)',
        backgroundColor: 'rgba(232,144,10,0.055)',
        borderWidth: 1.5,
        pointRadius: 0,
        fill: true,
        tension: 0.4,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      scales: { x: { display: false }, y: { display: false, min: 0 } }
    }
  });
}

