        const bull = Math.round((snap.bullish||0) * 100 / snap.total);
        const bear = Math.round((snap.bearish||0) * 100 / snap.total);
        sentEl.innerHTML = `<span style="color:var(--dim)">Sentiment:</span> <span style="color:#22c55e">${bull}%↑</span> <span style="color:#ef4444">${bear}%↓</span> <span style="color:var(--faint)">(${snap.total} sources)</span>`;
      }).catch(() => { sentEl.innerHTML = '<span style="color:var(--dim)">Sentiment: n/a</span>'; });
    }
  } catch(e) { el.innerHTML = `<div class="empty"><div class="empty-t">Failed to load ${escHtml(ticker)}</div></div>`; }
}

