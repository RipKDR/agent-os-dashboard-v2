async function updateRiskPortfolio() {
  const capital = parseFloat(document.getElementById('risk-capital')?.value || 0);
  const openPositions = parseInt(document.getElementById('risk-open')?.value || 0);
  const dailyPnL = parseFloat(document.getElementById('risk-dpnl')?.value || 0);
  const statusEl = document.getElementById('risk-update-status');
  if (!statusEl) return;

  if (!capital || capital <= 0) {
    statusEl.textContent = 'Capital must be > 0';
    statusEl.style.color = 'var(--red)';
    return;
  }

