async function selectChatAgent(id) {
  chatAgent = id;

  document.querySelectorAll('.ca-row').forEach(r =>
    r.classList.toggle('active', r.dataset.agent === id)
  );

  const a = AGENTS.find(x => x.id === id);
  document.getElementById('ch-name').textContent = a?.name || id;
  document.getElementById('ch-role').textContent = a?.role || '';
  document.getElementById('c-send').disabled = !document.getElementById('c-input').value.trim();

  unread[id] = 0;
  const badge = document.getElementById(`cb-${id}`);
  if (badge) badge.style.display = 'none';

  await loadHistory(id);
  subscribeChat(id);
}

async function loadHistory(id) {
  const el = document.getElementById('chat-msgs');
  el.innerHTML = `<div class="empty"><div class="empty-s">Loading…</div></div>`;
  if (!sb) return;

  try {
    const { data, error } = await sb
      .from('chat_messages')
      .select('*')
      .eq('agent_name', id)
      .order('created_at', { ascending: true })
      .limit(200);

    if (error) throw error;

    if (!data.length) {
      el.innerHTML = `<div class="empty">
        <div class="empty-t">No messages yet</div>
        <div class="empty-s">Send the first message</div>
      </div>`;
      return;
    }

    el.innerHTML = data.map(bubble).join('');
    el.scrollTop = el.scrollHeight;
  } catch {
    el.innerHTML = `<div class="empty">
      <div class="empty-s" style="color:var(--red)">Failed to load messages</div>
    </div>`;
  }
}

function bubble(m) {
  const dir = m.direction === 'outbound' ? 'out' : 'in';
  return `<div class="bw ${dir}">
    <div class="bbl ${dir}">${escHtml(m.body)}</div>
    <div class="bm">${dir === 'out' ? 'You' : escHtml(m.sender || '?')} · ${fmtDt(m.created_at)}</div>
  </div>`;
}

function subscribeChat(id) {
  if (chatChan) { sb?.removeChannel(chatChan); chatChan = null; }
  if (!sb) return;

  const conn = document.getElementById('ch-conn');
  conn.textContent = 'Connecting…';

  chatChan = sb.channel(`chat-${id}`)
    .on('postgres_changes', {
      event: 'INSERT', schema: 'public', table: 'chat_messages',
      filter: `agent_name=eq.${id}`
    }, ({ new: m }) => {
      const el  = document.getElementById('chat-msgs');
      const emp = el.querySelector('.empty');
      if (emp) el.innerHTML = '';
      el.insertAdjacentHTML('beforeend', bubble(m));
      el.scrollTop = el.scrollHeight;

      if (m.direction === 'inbound' && chatAgent !== id) {
        unread[id] = (unread[id] || 0) + 1;
        const badge = document.getElementById(`cb-${id}`);
        if (badge) { badge.textContent = unread[id]; badge.style.display = 'flex'; }
      }
    })
    .subscribe(status => {
      conn.textContent = status === 'SUBSCRIBED' ? 'Live' : status;
      conn.style.color = status === 'SUBSCRIBED' ? 'var(--green)' : 'var(--faint)';
    });
}

async function sendMsg() {
  const agentAtSend = chatAgent;
  const input = document.getElementById('c-input');
  const body  = input.value.trim();
  if (!body || !agentAtSend || !sb) return;

  input.value = '';
  input.style.height = 'auto';
  document.getElementById('c-send').disabled = true;

  const el  = document.getElementById('chat-msgs');
  const emp = el.querySelector('.empty');
  if (emp) el.innerHTML = '';

  const tid = `t${Date.now()}`;
  el.insertAdjacentHTML('beforeend', `
    <div class="bw out" id="${tid}">
      <div class="bbl out" style="opacity:0.5">${escHtml(body)}</div>
      <div class="bm">You · sending…</div>
    </div>
  `);
  el.scrollTop = el.scrollHeight;

  try {
    const { error } = await sb.from('chat_messages').insert({
      agent_name: agentAtSend,
      sender: 'operator',
      body,
      direction: 'outbound'
    });
    if (error) throw error;

    const wrap = document.getElementById(tid);
    if (wrap) {
      wrap.querySelector('.bbl').style.opacity = '1';
      wrap.querySelector('.bm').textContent = `You · ${new Date().toLocaleTimeString()}`;
    }

    setTimeout(async () => {
      try {
        const { data } = await sb.from('chat_messages')
          .select('processed')
          .eq('agent_name', agentAtSend)
          .eq('direction', 'outbound')
          .order('created_at', { ascending: false })
          .limit(1);
        if (data?.[0] && !data[0].processed) {
          const w = document.getElementById(tid);
          if (w) w.insertAdjacentHTML('beforeend',
            '<div style="font-size:8px;color:var(--amber);margin-top:2px;letter-spacing:0.08em">Waiting for bot…</div>');
        }
      } catch { /* ignore */ }
    }, 10_000);
  } catch {
    const wrap = document.getElementById(tid);
    if (wrap) {
      wrap.querySelector('.bbl').style.borderColor = 'var(--red)';
      wrap.querySelector('.bm').textContent = 'Failed to send';
    }
    toast2('Send failed', 'error');
  }
}

