.office-standup { margin:8px 16px; background:var(--a-soft); border:1px solid var(--border2); border-radius:4px; padding:10px 14px; font-size:10px; color:var(--text); }

/* ── APPROVALS HUB ───────────────────────────────────── */
#panel-approvals { flex-direction:column; overflow-y:auto; }
.approval-item { padding:12px 14px; border-bottom:1px solid var(--border); display:flex; align-items:flex-start; gap:10px; }
.ai-type { font-size:7px; text-transform:uppercase; letter-spacing:0.12em; padding:2px 6px; border-radius:2px; white-space:nowrap; flex-shrink:0; }
.ai-type.signal  { background:var(--g-soft); color:var(--green); }
.ai-type.content { background:var(--a-soft); color:var(--amber); }
.ai-type.email   { background:rgba(100,100,200,0.15); color:#8888ff; }
.ai-type.factory { background:var(--r-soft); color:var(--red); }
.ai-body { flex:1; }
.ai-label { font-size:11px; color:var(--text); margin-bottom:3px; }
.ai-sub   { font-size:9px; color:var(--dim); }
.ai-actions { display:flex; gap:6px; flex-shrink:0; }
.ai-btn { padding:4px 10px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); cursor:pointer; border-radius:2px; text-transform:uppercase; }
.ai-btn.approve { border-color:var(--green); color:var(--green); }
.ai-btn.reject  { border-color:var(--red); color:var(--red); }

/* ── PRICE ALERT FORM ────────────────────────────────── */
.alert-form { display:flex; gap:8px; padding:8px 14px; border-top:1px solid var(--border); background:var(--surface); flex-shrink:0; align-items:center; flex-wrap:wrap; }
.alert-input { background:transparent; border:1px solid var(--border2); border-radius:2px; padding:4px 8px; font:10px var(--mono); color:var(--text); outline:none; width:80px; }
.alert-select { background:var(--bg); color:var(--text); border:1px solid var(--border2); border-radius:2px; padding:4px 6px; font:10px var(--mono); }

/* ── MACRO STRIP ─────────────────────────────────────── */
.macro-chip { display:flex; flex-direction:column; padding:6px 16px; border-right:1px solid var(--border); min-width:90px; }
.mc-label { font-size:8px; color:var(--dim); text-transform:uppercase; letter-spacing:.10em; margin-bottom:2px; }
.macro-chip span:last-child { font-size:12px; color:var(--text); }

/* Session Intelligence styles (HighLowTicker-inspired) */
.idx-card { flex:1; padding:4px 10px; border-right:1px solid var(--border); display:flex; flex-direction:column; gap:1px; }
.idx-card:last-child { border-right:none; }
.idx-lab { font-size:7px; color:var(--dim); text-transform:uppercase; letter-spacing:.1em; }
.idx-val { font-size:13px; font-variant-numeric:tabular-nums; }
.idx-hl { font-size:8px; color:var(--dim); }
.vel { padding:1px 5px; background:var(--raised); border:1px solid var(--border2); border-radius:2px; font-size:8px; }
.alert-pill { font-size:7px; padding:1px 5px; border-radius:2px; background:var(--red); color:#fff; }

/* ── FILTER BUTTONS ──────────────────────────────────── */
.proj-filter-btn { padding:3px 10px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); cursor:pointer; border-radius:2px; text-transform:uppercase; letter-spacing:.08em; }
.proj-filter-btn.on { border-color:var(--amber); color:var(--amber); background:var(--a-soft); }
.proj-filter-btn:hover:not(.on) { border-color:var(--border); color:var(--text); }

/* Guide cards */
.guide-card {
  background: var(--raised);
  border: 1px solid var(--border2);
  border-radius: 4px;
  padding: 8px 12px;
  font-size: 9px;
  color: var(--text);
  cursor: pointer;
  transition: all 80ms ease;
}
.guide-card:hover {
  border-color: var(--amber);
  background: var(--a-soft);
}

/* ── MODALS ──────────────────────────────────────────── */
[id^="modal-"] { display:none; }
[id^="modal-"].open { display:flex !important; }
