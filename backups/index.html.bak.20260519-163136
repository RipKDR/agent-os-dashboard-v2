  const fp = (allLogs && allLogs.length) ? allLogs.slice(0, 24).map(l => l.id || l.created_at).join(',') : '';

  if (fp !== tickerFp) {
    tickerFp = fp;
    const items = allLogs.slice(0, 24).map(l => {
      const fail = l.status === 'failed';
      const raw  = l.task_description || '';
      const desc = raw.slice(0, 55) + (raw.length > 55 ? '…' : '');
      return `<span class="t-item">
        <span class="t-dot${fail ? ' fail' : ''}"></span>
        <span class="t-agent">${escHtml(l.agent_name || '?')}</span>
        <span class="t-sep"> — </span>
        <span>${escHtml(desc)}</span>
      </span>`;
    }).join('');
    inner.innerHTML = items + items || '<span class="t-item"><span class="t-dot"></span><span>Waiting for data…</span></span>';

    if (tickerRaf) cancelAnimationFrame(tickerRaf);
    tickerPos = 0;
    const halfWidth = inner.scrollWidth / 2;
    const step = () => {
      tickerPos -= 0.38;
      if (Math.abs(tickerPos) >= halfWidth) tickerPos = 0;
      inner.style.transform = `translateX(${tickerPos}px)`;
      tickerRaf = requestAnimationFrame(step);
    };
    tickerRaf = requestAnimationFrame(step);
  }
}

