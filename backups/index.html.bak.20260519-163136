let sessionIntelTimer = null;
function initSessionIntel() {
  if (sessionIntelTimer) return;
  updateSessionIntel();
  sessionIntelTimer = setInterval(updateSessionIntel, 4500);
}
function updateSessionIntel() {
  fetch('/api/trading/session-intel').then(r => r.json()).then(data => {
    // Index Watch — real data
    (data.indexes || []).forEach(d => {
      const p = document.getElementById('idx-' + d.ticker.toLowerCase());
      const h = document.getElementById('idx-' + d.ticker.toLowerCase() + '-h');
      const l = document.getElementById('idx-' + d.ticker.toLowerCase() + '-l');
      const chg = parseFloat(d.change_pct || 0);
      if (p) p.innerHTML = `${d.price} <span style="font-size:9px;color:${chg>=0?'var(--green)':'var(--red)'}">${chg>=0?'+':''}${chg}%</span>`;
      if (h) h.textContent = `H ${d.day_high || d.high_52w || '—'}`;
      if (l) l.textContent = `L ${d.day_low  || d.low_52w  || '—'}`;
    });

    // Regime + throughput (real stub from server)
    const rEl = document.getElementById('session-regime');
    if (rEl && data.regime) {
      rEl.textContent = data.regime;
      rEl.style.borderColor = data.regime.includes('Bull') ? 'var(--green)' : 'var(--border2)';
    }
    const tEl = document.getElementById('session-throughput');
    if (tEl && data.throughput) tEl.innerHTML = `${data.throughput} · ${data.momentum || ''}`;

    // Real New Highs / Lows from watchlist (★ = in your watchlist, click to add)
    const highEl = document.getElementById('session-highs');
    const lowEl  = document.getElementById('session-lows');
    const wlSet = new Set((data.watchlistTickers || []).map(t => t.toUpperCase()));
    function makeRowHTML(item, color) {
      const star = wlSet.has(item.ticker.toUpperCase()) ? ' ★' : '';
      let badges = '';
      if (item.is52wH) badges += '<span style="font-size:6px;background:var(--green);color:#000;padding:0 2px;margin-left:3px;border-radius:1px">52wH</span>';
      if (item.is52wL) badges += '<span style="font-size:6px;background:var(--red);color:#fff;padding:0 2px;margin-left:3px;border-radius:1px">52wL</span>';
      if (item.bigMove) badges += '<span style="font-size:6px;background:var(--amber);color:#000;padding:0 2px;margin-left:3px;border-radius:1px">BIG</span>';
      return `<div class="hl-row" data-ticker="${item.ticker}" style="padding:1px 6px;color:${color};cursor:pointer">${item.ticker}${star} ${item.chg >= 0 ? '+' : ''}${item.chg}%${badges}</div>`;
    }
    if (highEl) {
      highEl.innerHTML = (data.newHighs && data.newHighs.length)
        ? data.newHighs.map(h => makeRowHTML(h, 'var(--green)')).join('')
        : '<div style="padding:1px 6px;color:var(--dim)">— none —</div>';
      highEl.querySelectorAll('.hl-row').forEach(el => el.onclick = () => addToWatchlistFromSession(el.dataset.ticker));
    }
    if (lowEl) {
      lowEl.innerHTML = (data.newLows && data.newLows.length)
        ? data.newLows.map(l => makeRowHTML(l, 'var(--red)')).join('')
        : '<div style="padding:1px 6px;color:var(--dim)">— none —</div>';
      lowEl.querySelectorAll('.hl-row').forEach(el => el.onclick = () => addToWatchlistFromSession(el.dataset.ticker));
    }

    // Alerts from server
    const a = data.alerts || {};
    document.getElementById('alert-burst').style.display = a.burst ? 'inline' : 'none';
    document.getElementById('alert-spike').style.display = a.spike ? 'inline' : 'none';
    document.getElementById('alert-pop').style.display   = a.pop   ? 'inline' : 'none';

    // Real velocity from server (computed from recent price movement)
    if (data.velocity) {
      ['20m','5m','1m','30s'].forEach(tf => {
        const el = document.getElementById('vel-' + tf);
        if (el && data.velocity[tf] != null) el.textContent = `${tf} ${data.velocity[tf]}`;
      });
    }

    // Recent Breakouts log (session flow)
    const rb = document.getElementById('recent-breakouts');
    if (rb && data.recentHL && data.recentHL.length) {
      rb.innerHTML = data.recentHL.map(ev => {
        const t = new Date(ev.ts).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'});
        const col = ev.type === 'high' ? 'var(--green)' : 'var(--red)';
        return `<span style="margin-right:12px;color:${col}">${t} ${ev.ticker} ${ev.type.toUpperCase()} ${ev.chg >= 0 ? '+' : ''}${ev.chg}%</span>`;
      }).join('');
    } else if (rb) {
      rb.innerHTML = '<span style="color:var(--faint)">no breakouts yet this session</span>';
    }

    // Volume Spikes
    const vs = document.getElementById('volume-spikes');
    if (vs) {
      if (data.volumeSpikes && data.volumeSpikes.length) {
        vs.innerHTML = 'Vol ▲ ' + data.volumeSpikes.map(s => `<span style="margin-right:8px">${s.ticker} ${s.ratio}x</span>`).join('');
      } else {
        vs.innerHTML = '<span style="color:var(--faint)">no volume spikes</span>';
      }
    }

    // Broker status line
    const bs = document.getElementById('broker-status');
    if (bs && data.broker) {
      bs.innerHTML = data.broker.connected
        ? `🔗 ${data.broker.name} · real-time`
        : `☐ ${data.broker.name} · ${data.broker.note || ''}`;
    }
  }).catch(() => { /* silent fallback */ });
}

