async function placeBrokerOrder(side) {
  const symbol = document.getElementById('qo-symbol').value.trim().toUpperCase();
  const qty    = Number(document.getElementById('qo-qty').value);
  const type   = document.getElementById('qo-type').value;
  const limit  = type === 'limit' ? Number(document.getElementById('qo-limit').value) : undefined;
  const st     = document.getElementById('qo-status');
  if (!symbol || !qty) { st.textContent = 'Symbol and qty required.'; st.style.color = '#ff4444'; return; }

  const body = { symbol, qty, side, type, bracket: false };
  if (limit) body.limit_price = limit;

  async function submitOrder(pin) {
    if (pin) body.confirm_pin = pin;
    st.textContent = 'Placing order…'; st.style.color = 'var(--dim)';
    const res = await apiFetch('/api/trading/broker/orders', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.pin_required) {
      const dlg = document.getElementById('pin-dialog');
      const desc = document.getElementById('pin-dialog-desc');
      if (desc) desc.textContent = `PIN required to place ${side.toUpperCase()} ${qty}x ${symbol}`;
      const pinInput = document.getElementById('pin-input');
      if (pinInput) pinInput.value = '';
      document.getElementById('pin-confirm-btn').onclick = async () => {
        try {
          await submitOrder(pinInput.value.trim());
          dlg.close();
        } catch(e) {
          st.textContent = 'Error: ' + e.message;
          st.style.color = '#ff4444';
        }
      };
      dlg.showModal();
      pinInput.focus();
      return;
    }
    st.textContent = `✓ Order placed: ${res.id?.slice(0,8)}…`; st.style.color = '#00e676';
    setTimeout(loadBrokerAccount, 1000);
  }

  try { await submitOrder(); }
  catch(e) { st.textContent = 'Error: ' + e.message; st.style.color = '#ff4444'; }
}

