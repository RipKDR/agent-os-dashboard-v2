/* ─── TRADING — Correlation Heatmap ────────────── */
async function loadCorrelHeatmap() {
  const statusEl = document.getElementById('correl-heatmap-status');
  const heatEl   = document.getElementById('correl-heatmap');
  if (!statusEl || !heatEl) return;
  try {
    statusEl.textContent = 'Fetching watchlist prices…';
    const wl = await fetch('/api/trading/watchlist').then(r => r.json());
    if (!Array.isArray(wl) || !wl.length) { statusEl.textContent = 'No watchlist items'; return; }
    const tickers = wl.map(w => w.ticker).filter(Boolean);
    if (tickers.length < 2) { statusEl.textContent = 'Add 2+ tickers to compute correlations'; return; }
    statusEl.textContent = `Fetching 30d history for ${tickers.length} tickers…`;
    const results = await Promise.all(tickers.map(t =>
      fetch(`/api/trading/quote?ticker=${encodeURIComponent(t)}`).then(r => r.json()).catch(() => null)
    ));
    const series = {};
    tickers.forEach((t, i) => {
      const q = results[i];
      if (q && Array.isArray(q.closes) && q.closes.length > 1) series[t] = q.closes.filter(v => v != null && !isNaN(v));
    });
    const validTickers = Object.keys(series);
    if (validTickers.length < 2) { statusEl.textContent = 'Not enough price history for correlation'; return; }
    statusEl.textContent = '';
    renderCorrelHeatmap(validTickers, series, heatEl);
  } catch(e) { statusEl.textContent = 'Error: ' + e.message; }
}

function _pearsonR(a, b) {
  const n = Math.min(a.length, b.length);
  if (n < 2) return 0;
  const ax = a.slice(-n), bx = b.slice(-n);
  const ma = ax.reduce((s,v) => s+v, 0) / n;
  const mb = bx.reduce((s,v) => s+v, 0) / n;
  let num = 0, sa = 0, sb = 0;
  for (let i = 0; i < n; i++) {
    const da = ax[i] - ma, db = bx[i] - mb;
    num += da * db; sa += da * da; sb += db * db;
  }
  const denom = Math.sqrt(sa * sb);
  return denom === 0 ? 0 : num / denom;
}

function renderCorrelHeatmap(tickers, series, el) {
  const n = tickers.length;
  const matrix = Array.from({length:n}, (_,i) => Array.from({length:n}, (_,j) => _pearsonR(series[tickers[i]], series[tickers[j]])));
  const cellSize = Math.min(46, Math.floor(280 / (n + 1)));
  const labelW = Math.max(32, cellSize);
  function rToColor(r) {
    if (isNaN(r)) return '#333';
    const abs = Math.abs(r);
    const alpha = 0.2 + abs * 0.75;
    return r >= 0 ? `rgba(0,184,90,${alpha.toFixed(2)})` : `rgba(216,48,48,${alpha.toFixed(2)})`;
  }
  let html = `<table style="border-collapse:collapse;font-size:8px;font-family:var(--mono)">`;
  // header row
  html += `<tr><th style="width:${labelW}px"></th>`;
  tickers.forEach(t => { html += `<th style="width:${cellSize}px;text-align:center;color:var(--dim);padding:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:${cellSize}px" title="${escHtml(t)}">${escHtml(t.slice(0,5))}</th>`; });
  html += '</tr>';
  matrix.forEach((row, i) => {
    html += `<tr><td style="color:var(--dim);padding:2px 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:${labelW}px" title="${escHtml(tickers[i])}">${escHtml(tickers[i].slice(0,5))}</td>`;
    row.forEach((r, j) => {
      const bg = rToColor(r);
      const txt = i === j ? '—' : r.toFixed(2);
      html += `<td title="${escHtml(tickers[i])} / ${escHtml(tickers[j])}: ${i===j?'1.00':r.toFixed(3)}" style="text-align:center;padding:3px;background:${bg};color:var(--text);border-radius:2px;cursor:default">${txt}</td>`;
    });
    html += '</tr>';
  });
  html += '</table>';
  html += `<div style="display:flex;gap:16px;margin-top:8px;font-size:8px;color:var(--dim);align-items:center">`;
  html += `<span style="display:inline-block;width:12px;height:12px;background:rgba(0,184,90,0.8);border-radius:1px;vertical-align:middle"></span> Positive corr &nbsp;`;
  html += `<span style="display:inline-block;width:12px;height:12px;background:rgba(216,48,48,0.8);border-radius:1px;vertical-align:middle"></span> Negative corr &nbsp;`;
  html += `<span style="color:var(--dim)">Intensity = |r|, n=${Math.min(...Object.values(series).map(s=>s.length))} closes</span></div>`;
  el.innerHTML = html;
}

