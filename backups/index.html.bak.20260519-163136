async function loadForecasts() {
  const list = document.getElementById('forecast-list');
  if (!list) return;
  try {
    let url = '/api/trading/forecasts';
    if (forecastFilter !== 'all' && forecastFilter !== 'pending')
      url += `?status=${forecastFilter}`;
    else if (forecastFilter === 'pending')
      url += '?status=pending';
    const rows = await apiFetch(url);
    const data = Array.isArray(rows) ? rows : [];

    if (data.length === 0) {
      list.innerHTML = `<div class="empty"><div class="empty-t">No forecasts yet</div><div class="empty-s">Click "↻ Run Forecast" to generate ranked opportunities from the feature mesh</div></div>`;
      return;
    }

    const tsEl = document.getElementById('forecast-ts');
    if (tsEl && data[0]?.ts) tsEl.textContent = 'as of ' + new Date(data[0].ts).toLocaleTimeString();

    const filtered = forecastFilter === 'long'  ? data.filter(r => r.direction === 'long')
                   : forecastFilter === 'short' ? data.filter(r => r.direction === 'short')
                   : forecastFilter === 'pending' ? data.filter(r => r.status === 'pending')
                   : data;

    list.innerHTML = filtered.map(fc => {
      const scoreColor = fc.score >= 10 ? 'var(--green)' : fc.score <= -10 ? '#ff4444' : 'var(--dim)';
      const dirIcon    = fc.direction === 'long' ? '▲' : fc.direction === 'short' ? '▼' : '─';
      const barW       = Math.abs(fc.score).toFixed(0);
      const barColor   = fc.score >= 10 ? 'var(--green)' : fc.score <= -10 ? '#ff4444' : 'var(--border2)';
      const isPending  = fc.status === 'pending';
      const isApproved = fc.status === 'approved';
      const isDismissed= fc.status === 'dismissed';
      return `<div style="margin:4px 0;background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:10px 12px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
          <span style="font-size:11px;font-weight:600;color:var(--text);font-family:var(--mono);min-width:52px">${escapeHtml(fc.ticker)}</span>
          <span style="font-size:11px;color:${scoreColor};min-width:48px">${dirIcon} ${fc.score > 0 ? '+' : ''}${fc.score}</span>
          <div style="flex:1;height:4px;background:var(--bg);border-radius:2px;overflow:hidden">
            <div style="width:${barW}%;height:100%;background:${barColor};border-radius:2px"></div>
          </div>
          <span style="font-size:9px;color:var(--dim);min-width:60px;text-align:right">conf ${fc.confidence}%</span>
          ${isPending ? `
            <button onclick="actForecast('${escapeHtml(fc.id)}','approved')" style="font-size:8px;padding:3px 8px;background:var(--green);color:#000;border:none;border-radius:2px;cursor:pointer">✓ Approve</button>
            <button onclick="actForecast('${escapeHtml(fc.id)}','dismissed')" style="font-size:8px;padding:3px 8px;background:var(--surface);color:var(--dim);border:1px solid var(--border);border-radius:2px;cursor:pointer">✕</button>
          ` : `<span style="font-size:8px;padding:3px 8px;border-radius:2px;background:${isApproved?'rgba(0,230,118,.15)':isDismissed?'rgba(255,68,68,.1)':'var(--raised)'};color:${isApproved?'var(--green)':isDismissed?'#ff4444':'var(--dim)'}">${fc.status}</span>`}
        </div>
        <div style="font-size:8px;color:var(--dim);line-height:1.4">${escapeHtml(fc.rationale)}</div>
        ${fc.features ? `<div style="display:flex;gap:12px;margin-top:6px;font-size:7px;color:var(--dim);font-family:var(--mono)">
          <span>1d ${fc.features.pct_1d >= 0 ? '+' : ''}${(fc.features.pct_1d*100).toFixed(1)}%</span>
          <span>5d ${fc.features.pct_5d >= 0 ? '+' : ''}${(fc.features.pct_5d*100).toFixed(1)}%</span>
          <span>vol ${fc.features.vol_ratio}x</span>
          <span>RSI ${fc.features.rsi}</span>
          <span>ATR ${(fc.features.atr_pct*100).toFixed(2)}%</span>
          <span>@ $${fc.features.close}</span>
        </div>` : ''}
      </div>`;
    }).join('');
  } catch(e) {
    if (document.getElementById('forecast-list'))
      document.getElementById('forecast-list').innerHTML = `<div class="empty"><div class="empty-t">Failed to load forecasts</div><div class="empty-s">${escapeHtml(e.message)}</div></div>`;
  }
}

