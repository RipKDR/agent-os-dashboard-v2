function loadPipelineTemplate(templateId) {
  const template = PIPELINE_TEMPLATES[templateId];
  if (!template) return;
  currentPipeline = JSON.parse(JSON.stringify(template.steps));
  renderPipelineSteps();
}

function renderPipelineSteps() {
  const el = document.getElementById('pipeline-steps');
  if (!el) return;
  
  if (!currentPipeline.length) {
    el.innerHTML = `<div class="empty"><div class="empty-t">Custom Pipeline</div><div class="empty-s">Add steps below</div></div>`;
    return;
  }
  
  const agentColors = { alex: 'var(--amber)', maya: 'var(--green)', jordan: '#88C0D0', dev: 'var(--red)', sam: '#A6E22E' };
  const agentEmojis = { alex: '🔎', maya: '🎨', jordan: '🏗️', dev: '⚡', sam: '🧪' };
  
  el.innerHTML = currentPipeline.map((step, i) => `
    <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:4px" id="ps-${i}">
      <div style="font-size:9px;color:var(--faint);width:20px;text-align:center">${i+1}</div>
      <span style="font-size:14px">${agentEmojis[step.agent] || '➡️'}</span>
      <select onchange="currentPipeline[${i}].agent=this.value" style="background:var(--bg);color:${agentColors[step.agent] || 'var(--text)'};border:1px solid var(--border2);border-radius:2px;padding:3px 6px;font:9px var(--mono);width:70px">
        ${['alex','maya','jordan','dev','sam'].map(a => `<option ${a === step.agent ? 'selected' : ''} value="${a}">${a.charAt(0).toUpperCase()+a.slice(1)}</option>`).join('')}
      </select>
      <input value="${escHtml(step.desc)}" onchange="currentPipeline[${i}].desc=this.value" style="flex:1;background:transparent;border:1px solid var(--border2);border-radius:2px;padding:3px 8px;font:10px var(--mono);color:var(--text);outline:none">
      ${i > 0 ? `<button onclick="movePipelineStep(${i},-1)" style="background:none;border:none;cursor:pointer;color:var(--dim);font-size:12px">↑</button>` : ''}
      ${i < currentPipeline.length - 1 ? `<button onclick="movePipelineStep(${i},1)" style="background:none;border:none;cursor:pointer;color:var(--dim);font-size:12px">↓</button>` : ''}
      <button onclick="removePipelineStep(${i})" style="background:none;border:none;cursor:pointer;color:var(--red);font-size:12px">✕</button>
    </div>
  `).join('') + 
  `<button onclick="addPipelineStep()" style="margin-top:4px;padding:6px;background:var(--surface);border:1px dashed var(--border2);border-radius:4px;cursor:pointer;font:9px var(--mono);color:var(--dim);width:100%">+ Add Step</button>`;
}

function addPipelineStep() {
  currentPipeline.push({ agent: 'alex', desc: 'New step' });
  renderPipelineSteps();
}

function removePipelineStep(i) {
  currentPipeline.splice(i, 1);
  renderPipelineSteps();
}

function movePipelineStep(i, dir) {
  const j = i + dir;
  if (j < 0 || j >= currentPipeline.length) return;
  [currentPipeline[i], currentPipeline[j]] = [currentPipeline[j], currentPipeline[i]];
  renderPipelineSteps();
}

async function runPipeline() {
  const taskDesc = document.getElementById('pipeline-task-desc').value.trim();
  if (!taskDesc || !currentPipeline.length) {
    toast2('Enter a task description and add pipeline steps', 'warn');
    return;
  }
  
  const btn = document.querySelector('#orch-pipeline .dispatch-btn');
  btn.disabled = true;
  btn.textContent = '▶ Running…';
  
  // Switch to dispatch view temporarily to show results
  document.getElementById('orch-pipeline').style.display = 'none';
  document.getElementById('orch-dispatch').style.display = 'flex';
  document.querySelectorAll('#orch-mode-tabs .om-tab').forEach((b, i) => {
    b.classList.toggle('active', i === 0);
  });
  
  const resultsEl = document.getElementById('dispatch-results');
  document.getElementById('dispatch-empty').style.display = 'none';
  
  const pipelineHeader = document.createElement('div');
  pipelineHeader.style.cssText = 'margin:8px;padding:10px 14px;background:var(--surface);border:1px solid var(--amber);border-radius:4px;font-size:10px;color:var(--amber)';
  pipelineHeader.innerHTML = `🔗 Pipeline: ${escHtml(taskDesc)}<br><span style="color:var(--dim);font-size:9px">${currentPipeline.length} steps · sequential with context pass-through</span>`;
  resultsEl.prepend(pipelineHeader);
  
  let context = taskDesc;
  for (let i = 0; i < currentPipeline.length; i++) {
    const step = currentPipeline[i];
    const stepLabel = `${AGENTS.find(a => a.id === step.agent)?.name || step.agent}: ${step.desc}`;
    
    const card = document.createElement('div');
    card.className = 'dr-card';
    card.id = `pipe-${i}`;
    card.innerHTML = `
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:14px">${['🔎','🎨','🏗️','⚡','🧪'][['alex','maya','jordan','dev','sam'].indexOf(step.agent)] || '➡️'}</span>
        <span class="dr-agent">Step ${i+1}: ${AGENTS.find(a => a.id === step.agent)?.name || step.agent}</span>
        <span class="dr-status" style="margin-left:auto">⏳ Running…</span>
      </div>
      <div style="font-size:9px;color:var(--dim);margin-top:3px">${escHtml(step.desc)}</div>
      <div class="dr-body" id="pipe-body-${i}"></div>
    `;
    resultsEl.appendChild(card);
    resultsEl.scrollTop = resultsEl.scrollHeight;
    
    try {
      const res = await fetch('/api/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agent_name: step.agent, body: context }),
      });
      const data = await res.json();
      
      const bodyEl = document.getElementById(`pipe-body-${i}`);
      if (data.inbound) {
        bodyEl.textContent = (data.inbound.body || '').slice(0, 1500) + ((data.inbound.body || '').length > 1500 ? '\n\n[...]' : '');
        context = data.inbound.body || context; // Pass result as context to next step
      }
      
      const statusEl = card.querySelector('.dr-status');
      if (data.inbound?.error) {
        statusEl.innerHTML = '❌ Failed';
        toast2(`Step ${i+1} (${step.agent}) failed`, 'error');
        break; // Stop pipeline on failure
      } else {
        statusEl.innerHTML = '✅ Done';
      }
    } catch (err) {
      const bodyEl = document.getElementById(`pipe-body-${i}`);
      if (bodyEl) bodyEl.textContent = 'Error: ' + err.message;
      card.querySelector('.dr-status').innerHTML = '❌ Failed';
      toast2(`Step ${i+1} failed: ${err.message}`, 'error');
      break;
    }
  }
  
  btn.disabled = false;
  btn.textContent = '▶ Run Pipeline';
  toast2(`Pipeline complete (${currentPipeline.length} steps)`, 'success');
}

