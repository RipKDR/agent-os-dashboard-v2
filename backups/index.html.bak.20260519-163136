<script>
/* ── CONFIG ──────────────────────────────────────────────── */
let SB_URL  = '';
let SB_KEY  = '';
const POLL_MS = 30_000;

/* ── UTILITIES ───────────────────────────────────────────── */
function escapeHtml(s) {
  return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ── API FETCH HELPER ─────────────────────────────────────── */
async function apiFetch(url, opts = {}) {
  const r = await fetch(url, opts);
  if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text().catch(() => '')}`);
  return r.json();
}

const AGENTS = [
  { id: 'alex',   name: 'Alex',   role: 'Product Research'  },
  { id: 'maya',   name: 'Maya',   role: 'UX / UI'           },
  { id: 'jordan', name: 'Jordan', role: 'Architecture'       },
  { id: 'dev',    name: 'Dev',    role: 'Implementation'    },
  { id: 'sam',    name: 'Sam',    role: 'QA / Release'       },
];

/* ── STATE ───────────────────────────────────────────────── */
let sb          = null;
let allLogs     = [];
let logsByAgent = {};
let globalStats = {};
let logFilter   = 'all';
let loadAborted = false;
let chatAgent   = null;
let chatChan    = null;
let sparklines  = {};
let unread      = {};
let tickerRaf   = null;
let tickerPos   = 0;
let tickerFp    = '';
let missionStatus = null;

/* ── INIT ────────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', async () => {
  clock();
  tabs();
  switchSurface('now'); // boot into Now surface
  palette();
  chatUI();
  logFilters();
  renderMission();
  loadMissionStatus();
  setInterval(loadMissionStatus, 60_000);
  initRelayStatus();

  try {
    const cfg = await fetch('/api/config').then(r => r.json());
    SB_URL = cfg.supabaseUrl || '';
    SB_KEY = cfg.supabaseKey || '';
    if (SB_URL && SB_KEY) {
      sb = window.supabase.createClient(SB_URL, SB_KEY);
      window.sb = sb;
    }
  } catch (e) { console.error(e); }


  const bgLoad = async () => {
    if (typeof renderTicker === "function") renderTicker();
    try {
      loadAborted = false;
      const result = await Promise.race([
        loadAll(),
        new Promise((_, rej) => setTimeout(() => rej(new Error('timeout')), 12000))
      ]);
      if (loadAborted) return; // stale response
    } catch (e) {
      if (loadAborted) return;
      if (e.message === 'timeout') console.warn('Supabase load timeout — showing partial data');
      else if (sb) toast2('Data load issue', 'warn');
      // Always render ticker/mission even if supabase fails
      if (typeof renderTicker === 'function') renderTicker();
      if (typeof renderMission === 'function') renderMission();
    }
  };
  bgLoad();
  setInterval(bgLoad, POLL_MS);

  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) { loadAborted = true; bgLoad(); }
  });

  setTimeout(connectSSE, 500);
});

/* ── CLOCK ───────────────────────────────────────────────── */
function clock() {
  const el = document.getElementById('clock');
  const tick = () => { el.textContent = new Date().toLocaleTimeString('en-US', { hour12: false }); };
  tick();
  setInterval(tick, 1000);
}

/* ── SURFACES ────────────────────────────────────────────── */
const SURFACES = {
  now:       { label: 'Now',       default: 'now',      tabs: [] },
  work:      { label: 'Work',      default: 'projects', tabs: [['projects','Projects'],['task','Tasks'],['calendar','Calendar'],['github','GitHub'],['orch','Orch']] },
  trading:   { label: 'Trading',   default: 'trading',  tabs: [['trading','Signals'],['approvals','Review']] },
  knowledge: { label: 'Knowledge', default: 'knowledge',tabs: [['knowledge','Vault'],['files','Docs'],['learn','Memory']] },
  comms:     { label: 'Comms',     default: 'chat',     tabs: [['chat','Chat'],['email','Inbox'],['log','Logs'],['news','News']] },
  systems:   { label: 'Systems',   default: 'settings', tabs: [['settings','Settings'],['costs','Costs'],['security','Security'],['factory','Factory'],['terminal','Terminal'],['mission','Mission'],['ov','Overview'],['team','Team'],['office','Office'],['content','Studio'],['brain','Brain']] },
};

function renderSubNav(surfaceName) {
  const surf = SURFACES[surfaceName];
  const el = document.getElementById('sub-nav');
  if (!surf || !surf.tabs.length) { el.innerHTML = ''; return; }
  el.innerHTML = surf.tabs.map(([id, label]) =>
    `<div class="snav-item" data-tab="${id}" onclick="switchTab('${id}')">${label}</div>`
  ).join('');
}

function switchSurface(name) {
  document.querySelectorAll('.surf').forEach(s =>
    s.classList.toggle('active', s.dataset.surface === name)
  );
  renderSubNav(name);
  const surf = SURFACES[name];
  if (surf) switchTab(surf.default);
}

/* ── TABS ────────────────────────────────────────────────── */
function tabs() {
  document.querySelectorAll('.tab').forEach(t =>
    t.addEventListener('click', () => switchTab(t.dataset.tab))
  );
}

function switchTab(name) {
  document.querySelectorAll('.snav-item').forEach(t =>
    t.classList.toggle('active', t.dataset.tab === name)
  );
  document.querySelectorAll('.panel').forEach(p =>
    p.classList.toggle('active', p.id === `panel-${name}`)
  );
  if (name === 'settings') { setTimeout(renderSettings, 50); }
  if (name === 'task')     { setTimeout(renderTasks, 50); }
  if (name === 'files')    { setTimeout(() => loadDir(''), 50); }
  if (name === 'github')   { setTimeout(loadGitHubRepos, 50); }
  if (name === 'brain')    { setTimeout(loadBrainSessions, 50); }
  if (name === 'learn')    { setTimeout(loadLearnTab, 50); }
  if (name === 'now')      { setTimeout(loadNowSurface, 50); }
  if (name === 'knowledge'){ setTimeout(loadVaultTree, 50); }
  if (name === 'news')     { setTimeout(() => loadCommsFeed(''), 50); }
}

/* ── NOW SURFACE ─────────────────────────────────────────── */
async function loadNowSurface() {
  const [briefRes, signalsRes, capturesRes, weeklyRes, filingsRes, approvalsRes, positionsRes] = await Promise.allSettled([
    fetch('/api/brief/today').then(r => r.json()),
    fetch('/api/trading/forecasts?limit=5').then(r => r.json()),
    fetch('/api/capture?limit=5').then(r => r.json()),
    fetch('/api/brief/weekly').then(r => r.json()),
    fetch('/api/trading/filings?limit=5').then(r => r.json()),
    fetch('/api/approvals').then(r => r.json()),
    fetch('/api/trading/positions').then(r => r.json()).catch(() => []),
  ]);

  // Brief
  const brief = briefRes.value;
  const briefEl = document.getElementById('now-brief');
  if (briefEl) briefEl.textContent = brief?.content || 'No brief yet. Click Refresh to generate.';

  // Actionable Top Signals + Why Engine
  const signals = Array.isArray(signalsRes.value) ? signalsRes.value : [];
  const sigEl = document.getElementById('now-signals');
  if (sigEl) {
    if (!signals.length) { sigEl.textContent = 'No forecasts yet. Trading engine is scanning.'; }
    else sigEl.innerHTML = signals.slice(0, 3).map(s => {
      const canAct = s.status === 'watching' || !s.status;
      const t = escapeHtml(s.ticker || '');
      return `<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border)">
        <span style="color:${s.direction==='long'?'var(--green)':'var(--red)'};font-weight:600">${s.direction?.toUpperCase()||'?'} ${t}</span>
        <span style="color:var(--dim)">${s.score||0} · ${s.confidence||0}%</span>
        <span style="display:flex;gap:4px">
          ${canAct ? `<button onclick="approveSignal('${s.id}');setTimeout(loadNowSurface,300)" style="background:none;border:1px solid var(--green);color:var(--green);border-radius:2px;padding:0 5px;font:8px var(--mono);cursor:pointer">Approve</button> <button onclick="rejectSignal('${s.id}');setTimeout(loadNowSurface,300)" style="background:none;border:1px solid var(--red);color:var(--red);border-radius:2px;padding:0 5px;font:8px var(--mono);cursor:pointer">Dismiss</button>` : `<button onclick="switchSurface('trading')" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:0 5px;font:8px var(--mono);cursor:pointer">View</button>`}
          <button onclick="showWhy('${t}')" style="background:none;border:1px solid var(--amber);color:var(--amber);border-radius:2px;padding:0 5px;font:8px var(--mono);cursor:pointer">Why?</button>
        </span>
      </div>`;
    }).join('');
  }

  // Captures
  const captures = Array.isArray(capturesRes.value) ? capturesRes.value : [];
  const capEl = document.getElementById('now-captures');
  if (capEl) {
    if (!captures.length) { capEl.textContent = 'No captures today. Press ⌘N to add one.'; }
    else capEl.innerHTML = captures.slice(0, 5).map(c =>
      `<div style="padding:4px 0;border-bottom:1px solid var(--border);font-size:10px"><span style="color:var(--amber)">[${escapeHtml(c.intent||'?')}]</span> ${escapeHtml(c.text||c.raw_text||'')}</div>`
    ).join('');
  }

  // Pending Approvals (compact)
  const approvalsEl = document.getElementById('now-approvals');
  if (approvalsEl) {
    const items = Array.isArray(approvalsRes.value) ? approvalsRes.value : [];
    if (!items.length) { approvalsEl.textContent = 'All clear — no pending items.'; }
    else approvalsEl.innerHTML = items.slice(0, 4).map(item => `
      <div style="padding:3px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
        <span style="color:var(--amber)">${escapeHtml(item._type||'item')}</span>
        <span style="color:var(--dim);flex:1;margin:0 8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(item.title||item.task_description||item.ticker||'')}</span>
        ${item._type==='signal' ? `<button onclick="approveSignal('${item.id}');setTimeout(loadNowSurface,200)" style="background:none;border:1px solid var(--green);color:var(--green);border-radius:2px;padding:0 4px;font:7px var(--mono);cursor:pointer">OK</button>` : ''}
      </div>`).join('');
  }

  // Weekly review
  const weekly = weeklyRes.value;
  const weeklyEl = document.getElementById('now-weekly');
  if (weeklyEl) {
    const latest = Array.isArray(weekly) ? weekly[weekly.length - 1] : null;
    weeklyEl.textContent = latest?.content || 'No weekly review yet. Click Generate to create one.';
  }

  // SEC filings
  const filingsEl = document.getElementById('now-filings');
  if (filingsEl) {
    const filings = filingsRes?.value;
    if (!Array.isArray(filings) || !filings.length) {
      filingsEl.textContent = 'No recent filings. Filings ingest runs every 4h.';
    } else {
      filingsEl.innerHTML = filings.slice(0, 4).map(f =>
        `<div style="padding:3px 0;border-bottom:1px solid var(--border)"><span style="color:var(--amber)">[${escapeHtml(f.ticker)} ${escapeHtml(f.type)}]</span> <a href="${escapeHtml(f.url||'#')}" target="_blank" rel="noopener" style="color:var(--text)">${escapeHtml(f.title)}</a></div>`
      ).join('');
    }
  }

  // Health strip
  const healthEl = document.getElementById('now-health');
  if (healthEl) {
    const pos = Array.isArray(positionsRes.value) ? positionsRes.value : [];
    const open = pos.filter(p => !p.status || p.status === 'open').length;
    const paper = (window.ALPACA_PAPER || true) ? 'PAPER' : 'LIVE';
    healthEl.innerHTML = `<span>Broker: <b style="color:var(--amber)">${paper}</b></span> · <span>Positions: <b>${open}</b></span> · <span>Forecasts: <b>${signals.length}</b></span> · <span>Last ingest: <b>${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</b></span>`;
  }
}

/* ── WHY ENGINE (killer feature) ─────────────────────────── */
async function showWhy(ticker) {
  if (!ticker) return;
  const box = document.getElementById('now-why');
  if (!box) return;
  box.style.display = 'block';
  box.innerHTML = `<span style="color:var(--amber)">Why ${ticker}?</span> <span style="color:var(--dim)">Loading explanation…</span>`;

  try {
    const data = await fetch(`/api/trading/why/${ticker}`).then(r => r.json());
    const expl = data.explanation || 'No causal note generated.';
    box.innerHTML = `
