.proj-bar-wrap { background:var(--faint); border-radius:2px; height:3px; margin-bottom:6px; }
.proj-bar { background:var(--amber); height:3px; border-radius:2px; transition:width 300ms; }
.proj-stats { font-size:9px; color:var(--dim); display:flex; justify-content:space-between; }
.proj-detail { margin:0 10px 10px; background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; }

/* ── CALENDAR ────────────────────────────────────────── */
#panel-calendar { flex-direction:column; overflow-y:auto; }
