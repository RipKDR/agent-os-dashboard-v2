let _logsFp = '';
let _tasksFp = '';

function renderLogs() {
  const q = document.getElementById('log-srch').value.toLowerCase();
  let logs = logFilter === 'all' ? allLogs : (logsByAgent[logFilter] || []);
  if (q) {
    logs = logs.filter(l =>
      (l.task_description || '').toLowerCase().includes(q) ||
      (l.agent_name || '').toLowerCase().includes(q)
    );
  }

  const el = document.getElementById('log-list');
  // Build fingerprint from first/last visible log
  const visible = logs.slice(0, 250);
  const fp = visible.length
    ? `${logFilter}:${q}:${visible.length}:${visible[0]?.id||''}:${visible[visible.length-1]?.id||''}`
    : 'empty';
  if (fp === _logsFp) return;
  _logsFp = fp;

  if (!logs.length) {
    el.innerHTML = `<div class="empty">
      <div class="empty-t">No entries</div>
      <div class="empty-s">Adjust filter or search</div>
    </div>`;
    return;
  }

  el.innerHTML = visible.map(l => `
    <div class="l-row">
      <span class="l-time">${fmtDt(l.created_at)}</span>
      <span class="l-agent">${escHtml(l.agent_name || '—')}</span>
      <span class="l-status ${l.status || ''}">${l.status || '—'}</span>
      <span class="l-desc" title="${escHtml(l.task_description || '')}">${escHtml(l.task_description || '—')}</span>
