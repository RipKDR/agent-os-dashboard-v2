function renderJournal(entries) {
  const el = document.getElementById('journal-list');
  const stats = document.getElementById('journal-stats');
  if (!el) return;

  // Sort oldest → newest for equity curve
  const sorted = [...entries].sort((a,b) => new Date(a.created_at||0) - new Date(b.created_at||0));

  if (stats && sorted.length) {
    const wins = sorted.filter(e => parseFloat(e.result_pct||0) > 0).length;
    const wr = Math.round(wins / sorted.length * 100);
    const avgR = (sorted.reduce((a,e) => a + parseFloat(e.result_pct||0), 0) / sorted.length).toFixed(1);
    const totalR = sorted.reduce((a,e) => a + parseFloat(e.result_pct||0), 0).toFixed(1);
    stats.textContent = `${sorted.length} trades · WR ${wr}% · Avg ${avgR}% · Total ${totalR >= 0 ? '+' : ''}${totalR}%`;
  } else if (stats) { stats.textContent = 'No trades logged'; }

  // ── Equity curve ──────────────────────────────────────────────
  const cvs = document.getElementById('equity-curve-chart');
  if (cvs && window.Chart) {
    if (window._equityChartInst) { window._equityChartInst.destroy(); window._equityChartInst = null; }
    if (sorted.length >= 2) {
      let cum = 0;
      const cumData = sorted.map(e => { cum += parseFloat(e.result_pct||0); return parseFloat(cum.toFixed(2)); });
      const labels  = sorted.map((_,i) => i+1);
      const lastVal = cumData[cumData.length-1] || 0;
      const color   = lastVal >= 0 ? '#00B85A' : '#D83030';
      window._equityChartInst = new Chart(cvs, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            data: cumData,
            borderColor: color,
            backgroundColor: lastVal >= 0 ? 'rgba(0,184,90,0.08)' : 'rgba(216,48,48,0.08)',
            borderWidth: 1.5,
            fill: true,
            tension: 0.3,
            pointRadius: sorted.length < 20 ? 3 : 0,
            pointBackgroundColor: color,
          }]
        },
        options: {
          animation: false,
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => `${ctx.raw >= 0 ? '+' : ''}${ctx.raw}%` } } },
          scales: {
            x: { display: false },
            y: { display: true, ticks: { color:'var(--dim)', font:{size:8}, callback: v => v+'%' }, grid: { color:'rgba(255,255,255,0.04)' } }
          }
        }
      });
    } else {
      // Not enough data — show placeholder text on canvas
      const ctx2d = cvs.getContext('2d');
      ctx2d.clearRect(0,0,cvs.width,cvs.height);
      ctx2d.fillStyle = 'rgba(255,255,255,0.12)';
      ctx2d.font = '10px monospace';
      ctx2d.fillText('Log at least 2 trades to see equity curve', 8, 30);
    }
  }

  if (!sorted.length) { el.innerHTML = emptyHtml('No trades logged', 'Click + Log Trade to record a completed trade'); return; }
  // Render newest first in the list
  el.innerHTML = [...sorted].reverse().map(e => {
    const pct = parseFloat(e.result_pct||0);
    return `<div style="padding:12px 14px;border-bottom:1px solid var(--border)">
      <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:6px">
        <span style="font-size:12px;color:${e.direction==='short'?'var(--red)':'var(--green)'}">${e.direction==='short'?'▼ SHORT':'▲ LONG'}</span>
        <span style="font-size:13px;color:var(--amber)">${escHtml(e.ticker||'')}</span>
        <span style="font-size:13px;color:${pct>=0?'var(--green)':'var(--red)'}">${pct>=0?'+':''}${pct}%</span>
        <span style="flex:1"></span>
        <span style="font-size:8px;color:var(--dim)">${e.created_at?new Date(e.created_at).toLocaleDateString():''}</span>
      </div>
      ${e.lessons ? `<div style="font-size:9px;color:var(--dim)">💡 ${escHtml(e.lessons.slice(0,100))}</div>` : ''}
    </div>`;
  }).join('');
}

