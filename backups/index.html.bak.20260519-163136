function calcPositionSize() {
  // Enhanced to match backend RiskEngine.calculatePositionSize logic
  // (capital * riskPerTradePct) / |entry-stop| floored
  const account = parseFloat(document.getElementById('ps-account')?.value||0);
  const risk    = parseFloat(document.getElementById('ps-risk')?.value||0) / 100;
  const entry   = parseFloat(document.getElementById('ps-entry')?.value||0);
  const stop    = parseFloat(document.getElementById('ps-stop')?.value||0);
  const el = document.getElementById('ps-result');
  if (!el) return;
  if (!account || !risk || !entry || !stop || entry === stop) { el.textContent = ''; return; }
  const riskAmt = account * risk;
  const priceDiff = Math.abs(entry - stop);
  const shares = Math.floor(riskAmt / priceDiff);
  const posValue = shares * entry;
  const localTxt = `${shares.toLocaleString()} shares = $${posValue.toLocaleString()} (${(posValue/account*100).toFixed(1)}% of portfolio)`;

  const useLive = document.getElementById('ps-live')?.checked;
  if (useLive) {
    // fire-and-forget live call; oninput handlers remain non-blocking
    (async () => {
      try {
        const data = await apiFetch('/api/trading/risk/calculate-size', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ account, riskPct: risk*100, entry, stop })
        });
        if (data && data.shares != null) {
          const engTxt = `${(data.shares||0).toLocaleString()} shares = $${(data.positionValue||0).toLocaleString()}`;
          el.textContent = `Local: ${localTxt}  |  Engine: ${engTxt}`;
          return;
        }
      } catch (e) {
        showToast('Risk engine unavailable, using local calc', 'warn');
      }
      el.textContent = localTxt;
    })();
    return;
  }
  el.textContent = localTxt;
}

