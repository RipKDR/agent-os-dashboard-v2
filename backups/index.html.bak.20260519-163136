<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Agent OS — Mission Control</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔧</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script defer src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all';this.onload=null" />

  <style>
    /* ── TOKENS ─────────────────────────────────────────── */
    :root {
      --bg:        #090909;
      --surface:   #0F0F0F;
      --raised:    #151515;
      --border:    #1E1E1E;
      --border2:   #282828;
      --text:      #CEC3AD;
      --dim:       #5A5248;
      --faint:     #2E2A26;
      --amber:     #E8900A;
      --a-soft:    rgba(232,144,10,0.11);
      --green:     #00B85A;
      --g-soft:    rgba(0,184,90,0.10);
      --red:       #D83030;
      --r-soft:    rgba(216,48,48,0.10);
      --mono:      'JetBrains Mono', 'Courier New', monospace;
      --serif:     'Cormorant Garamond', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.55;
    }

    /* scanline overlay */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      background: repeating-linear-gradient(
        0deg,
        rgba(0,0,0,0.028) 0px, rgba(0,0,0,0.028) 1px,
        transparent 1px, transparent 3px
      );
    }

    /* ── GRID ────────────────────────────────────────────── */
    #app {
      display: grid;
      height: 100vh;
      grid-template-rows: 26px 40px 28px 1fr;
      grid-template-columns: 192px 1fr;
    }
    #sub-nav {
      grid-column: 1 / -1;
    }

    /* ── TICKER ──────────────────────────────────────────── */
    #ticker {
      grid-column: 1 / -1;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .ticker-tag {
      padding: 0 11px;
      font-size: 8px;
      letter-spacing: 0.20em;
      text-transform: uppercase;
      color: var(--amber);
      white-space: nowrap;
      border-right: 1px solid var(--border2);
      height: 100%;
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    .ticker-track { flex: 1; overflow: hidden; position: relative; }

    .ticker-inner {
      display: flex;
      gap: 52px;
      white-space: nowrap;
      will-change: transform;
    }

    .t-item {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 10px;
      color: var(--dim);
    }

    .t-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--green);
      flex-shrink: 0;
    }
    .t-dot.fail { background: var(--red); }

    .t-agent { color: var(--text); letter-spacing: 0.03em; }
    .t-sep   { color: var(--faint); }

    /* ── HEADER ──────────────────────────────────────────── */
    #header {
      grid-column: 1 / -1;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: stretch;
      position: relative;
    }

    /* amber underline accent on header */
    #header::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 240px; height: 1px;
      background: linear-gradient(90deg, var(--amber), transparent);
    }

    #logo {
      font-family: var(--serif);
      font-size: 17px;
      font-weight: 300;
      font-style: italic;
      color: var(--amber);
      display: flex;
      align-items: center;
      padding: 0 18px 0 16px;
      border-right: 1px solid var(--border2);
      white-space: nowrap;
      letter-spacing: 0.03em;
    }

    #tabs { display: flex; align-items: stretch; overflow-x: auto; scrollbar-width: none; }
    #tabs::-webkit-scrollbar { display: none; }

    /* ── Surface nav ─────────────────────────────────────────── */
    #surfaces { display:flex; height:100%; }
    .surf {
      padding: 0 20px;
      display: flex;
      align-items: center;
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
      cursor: pointer;
      border-right: 1px solid var(--border);
      transition: color 100ms, background 100ms;
      user-select: none;
      white-space: nowrap;
      position: relative;
    }
    .surf:hover { color: var(--text); background: var(--raised); }
    .surf.active {
      color: var(--amber);
      background: var(--a-soft);
    }
    .surf.active::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--amber);
    }

    /* ── Sub-nav ─────────────────────────────────────────────── */
    #sub-nav {
      display: flex;
      height: 28px;
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      flex-shrink: 0;
    }
    .snav-item {
      padding: 0 14px;
      display: flex;
      align-items: center;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      cursor: pointer;
      border-right: 1px solid var(--border);
      transition: color 80ms, background 80ms;
      user-select: none;
      white-space: nowrap;
    }
    .snav-item:hover { color: var(--text); background: var(--raised); }
    .snav-item.active { color: var(--amber); }

    .tab {
      padding: 0 16px;
      display: flex;
      align-items: center;
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--dim);
      cursor: pointer;
      border-right: 1px solid var(--border);
      transition: color 100ms, background 100ms;
      user-select: none;
      white-space: nowrap;
      position: relative;
    }

    .tab:hover { color: var(--text); background: var(--raised); }

    .tab.active {
      color: var(--amber);
      background: var(--a-soft);
    }
    .tab.active::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: var(--amber);
    }

    #hdr-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 0 16px;
    }

    /* ── NOTIFICATION BELL ────────────────────────────────── */
    .notif-bell {
      position: relative;
      cursor: pointer;
      font-size: 16px;
      padding: 4px;
      opacity: 0.7;
      transition: opacity 150ms;
      background: none;
      border: none;
      color: var(--text);
    }
    .notif-bell:hover { opacity: 1; }
    .notif-bell .bell-badge {
      position: absolute;
      top: -2px;
      right: -4px;
      background: var(--red);
      color: #fff;
      font-size: 7px;
      font-weight: 700;
      padding: 1px 3px;
      border-radius: 9px;
      min-width: 12px;
      text-align: center;
      display: none;
    }
    .notif-bell .bell-badge.show { display: block; }

    #upd-badge {
      font-size: 8px;
      color: var(--faint);
      letter-spacing: 0.10em;
      text-transform: uppercase;
    }

    #relay-indicator {
      font-size: 9px;
      color: var(--dim);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 5px;
      cursor: pointer;
      padding: 3px 8px;
      border-radius: 3px;
      transition: background 150ms;
    }
    #relay-indicator:hover { background: var(--raised); }
    #relay-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--faint);
      flex-shrink: 0;
    }
    #relay-dot.live { background: var(--green); box-shadow: 0 0 4px var(--green); }

    #clock {
      font-size: 11px;
      color: var(--dim);
      letter-spacing: 0.14em;
      font-variant-numeric: tabular-nums;
      border-left: 1px solid var(--border2);
      padding-left: 18px;
    }

    /* ── SIDEBAR ─────────────────────────────────────────── */
    #sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .s-label {
      font-size: 7px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--faint);
      padding: 10px 14px 5px;
    }

    /* agent rows */
    .a-row {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 7px 14px;
      cursor: pointer;
      transition: background 80ms;
      border-left: 2px solid transparent;
    }
    .a-row:hover  { background: var(--raised); }
    .a-row.active { background: var(--a-soft); border-left-color: var(--amber); }
    .a-row.active .a-row-name { color: var(--amber); }

    .a-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .a-dot.on  { background: var(--green); box-shadow: 0 0 5px var(--green); }
    .a-dot.wk  { background: var(--amber); box-shadow: 0 0 5px var(--amber); }
    .a-dot.off { background: var(--faint); }

    .a-row-name {
      font-size: 11px;
      letter-spacing: 0.03em;
      flex: 1;
    }

    .a-count {
      font-size: 9px;
      color: var(--dim);
      font-variant-numeric: tabular-nums;
    }

    /* sidebar stats */
    #sb-stats {
      border-top: 1px solid var(--border);
      padding: 14px 14px 10px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px 10px;
    }

    .ss-v {
      font-size: 20px;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .ss-v.amber { color: var(--amber); }
    .ss-v.green { color: var(--green); }
    .ss-v.red   { color: var(--red);   }

    .ss-l {
      font-size: 7px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--faint);
      margin-top: 4px;
    }

    /* ── MAIN ────────────────────────────────────────────── */
    #main {
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ── PANELS ──────────────────────────────────────────── */
    .panel { display: none; flex: 1; overflow: hidden; flex-direction: column; }
    .panel.active { display: flex; }

    /* ── OVERVIEW ────────────────────────────────────────── */
    #panel-ov { flex-direction: column; overflow-y: auto; }

    .sys-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }

    .sb-cell {
      padding: 13px 18px;
      border-right: 1px solid var(--border);
    }
    .sb-cell:last-child { border-right: none; }

    .sb-l {
      font-size: 7px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--faint);
      margin-bottom: 5px;
    }

    .sb-v {
      font-size: 20px;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }

    /* agent cards */
    #cards-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      border-bottom: 1px solid var(--border);
    }

    .a-card {
      padding: 20px 16px;
      border-right: 1px solid var(--border);
      cursor: pointer;
      transition: background 100ms;
    }
    .a-card:last-child { border-right: none; }
    .a-card:hover { background: var(--surface); }

    .ac-name {
      font-family: var(--serif);
      font-size: 28px;
      font-weight: 300;
      font-style: italic;
      line-height: 1;
      margin-bottom: 4px;
    }

    .ac-role {
      font-size: 7px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 13px;
    }

    .ac-status {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 8px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .ac-status .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
    .ac-status.on  { color: var(--green); }
    .ac-status.wk  { color: var(--amber); }
    .ac-status.off { color: var(--faint); }

    .ac-task {
      font-size: 10px;
      color: var(--dim);
      line-height: 1.5;
      min-height: 30px;
      margin-bottom: 12px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .ac-meta { display: flex; gap: 14px; margin-bottom: 12px; }

    .ac-mv {
      font-size: 15px;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }
    .ac-mv.amber { color: var(--amber); }
    .ac-mv.green { color: var(--green); }
    .ac-mv.red   { color: var(--red);   }

    .ac-ml {
      font-size: 7px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--faint);
      margin-top: 2px;
    }

    .ac-spark { height: 30px; }

    .ac-time-on-task {
      font-size: 8px;
      color: var(--dim);
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }
    .ac-dispatch-btn {
      display: block;
      width: 100%;
      margin-top: 10px;
      padding: 5px 0;
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--amber);
      font-family: var(--mono);
      font-size: 8px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 100ms, background 100ms;
    }
    .ac-dispatch-btn:hover { border-color: var(--amber); background: var(--a-soft); }
    .ac-composer {
      margin-top: 8px;
      padding-top: 8px;
      border-top: 1px solid var(--border);
    }
    .ac-task-input {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--text);
      font-family: var(--mono);
      font-size: 9px;
      padding: 6px 8px;
      resize: none;
      outline: none;
      border-radius: 2px;
    }
    .ac-task-input:focus { border-color: var(--amber); }
    .ac-composer-actions { display: flex; justify-content: flex-end; gap: 6px; margin-top: 6px; }


/* ── MISSION CONTROL / VIDEO-INSPIRED OPS VIEW ───────────── */
#panel-mission { flex-direction:column; overflow-y:auto; background:radial-gradient(circle at top left, rgba(232,144,10,0.08), transparent 28%), var(--bg); }
.mission-shell { padding:12px; display:grid; grid-template-columns:1.1fr 0.9fr; gap:12px; align-content:start; }
.mc-card { background:rgba(15,15,15,0.92); border:1px solid var(--border); border-radius:6px; overflow:hidden; }
.mc-card:hover { border-color:var(--border2); }
.mc-head { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:10px 12px; border-bottom:1px solid var(--border); background:rgba(21,21,21,0.78); }
.mc-title { font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--amber); }
.mc-sub { font-size:8px; letter-spacing:0.10em; text-transform:uppercase; color:var(--faint); }
.mc-hero { grid-column:1/-1; padding:18px; display:grid; grid-template-columns:1fr auto; gap:18px; align-items:center; background:linear-gradient(135deg, rgba(232,144,10,0.12), rgba(15,15,15,0.96) 42%, rgba(0,184,90,0.07)); }
.mc-kicker { font-size:8px; letter-spacing:0.22em; text-transform:uppercase; color:var(--amber); margin-bottom:7px; }
.mc-h1 { font-family:var(--serif); font-size:36px; line-height:0.95; font-weight:300; font-style:italic; color:var(--text); margin-bottom:9px; }
.mc-copy { max-width:720px; font-size:11px; line-height:1.65; color:var(--dim); }
.mc-metrics { display:grid; grid-template-columns:repeat(4, minmax(86px,1fr)); gap:8px; min-width:420px; }
.mc-metric { border:1px solid var(--border2); background:rgba(9,9,9,0.48); padding:10px; border-radius:4px; }
.mc-num { font-size:22px; font-variant-numeric:tabular-nums; color:var(--text); }
.mc-label { margin-top:3px; font-size:7px; letter-spacing:0.14em; text-transform:uppercase; color:var(--faint); }
.office-grid { padding:12px; display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }
.office-agent { min-height:118px; border:1px solid var(--border); background:var(--bg); border-radius:5px; padding:10px; position:relative; overflow:hidden; cursor:pointer; }
.office-agent::after { content:''; position:absolute; inset:auto 10px 10px auto; width:28px; height:28px; border:1px solid var(--border2); border-radius:50%; opacity:0.6; }
.office-name { font-family:var(--serif); font-size:21px; font-style:italic; color:var(--text); }
.office-role { margin:3px 0 12px; font-size:7px; letter-spacing:0.14em; text-transform:uppercase; color:var(--dim); }
.office-status { display:inline-flex; align-items:center; gap:5px; font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--green); background:var(--g-soft); padding:3px 7px; border-radius:999px; }
.office-status.idle { color:var(--dim); background:transparent; border:1px solid var(--border2); }
.office-task { margin-top:11px; font-size:9px; line-height:1.45; color:var(--dim); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.module-grid { padding:10px; display:grid; grid-template-columns:repeat(2,1fr); gap:8px; }
.module-tile { border:1px solid var(--border); background:var(--bg); border-radius:4px; padding:10px; min-height:84px; cursor:pointer; transition:all 90ms; }
.module-tile:hover { border-color:var(--amber); background:var(--a-soft); }
.module-top { display:flex; justify-content:space-between; gap:8px; margin-bottom:8px; }
.module-name { font-size:10px; color:var(--text); }
.module-chip { font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--amber); }
.module-desc { font-size:9px; line-height:1.5; color:var(--dim); }
.queue-list, .approval-list { padding:8px 10px 10px; display:flex; flex-direction:column; gap:6px; }
.queue-item, .approval-item { display:grid; grid-template-columns:72px 1fr auto; gap:10px; align-items:center; border:1px solid var(--border); background:var(--bg); padding:8px 9px; border-radius:4px; }
.queue-time { color:var(--amber); font-size:10px; font-variant-numeric:tabular-nums; }
.queue-main { min-width:0; }
.queue-name { font-size:10px; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.queue-agent { font-size:8px; color:var(--faint); text-transform:uppercase; letter-spacing:0.09em; }
.queue-badge { font-size:7px; letter-spacing:0.10em; text-transform:uppercase; color:var(--green); border:1px solid rgba(0,184,90,0.28); padding:2px 6px; border-radius:999px; }
.approval-item { grid-template-columns:1fr auto; }
.approval-actions { display:flex; gap:5px; }
.mini-btn { border:1px solid var(--border2); background:transparent; color:var(--dim); padding:3px 7px; border-radius:3px; font:8px var(--mono); text-transform:uppercase; cursor:pointer; }
.mini-btn.primary { color:#000; background:var(--amber); border-color:var(--amber); }
.cost-bars { padding:12px; display:flex; flex-direction:column; gap:9px; }
.cost-row { display:grid; grid-template-columns:56px 1fr 54px; gap:10px; align-items:center; }
.cost-name { font-size:9px; color:var(--dim); text-transform:uppercase; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.cost-track { height:7px; border:1px solid var(--border2); background:var(--bg); border-radius:999px; overflow:hidden; }
.cost-fill { height:100%; background:linear-gradient(90deg, var(--amber), rgba(232,144,10,0.35)); }
.cost-val { text-align:right; font-size:9px; color:var(--text); font-variant-numeric:tabular-nums; }
@media (max-width: 1180px) { .mission-shell { grid-template-columns:1fr; } .mc-hero { grid-template-columns:1fr; } .mc-metrics { min-width:0; } .office-grid { grid-template-columns:repeat(2,1fr); } }

.mc-steps { grid-column:1/-1; padding:10px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:8px; }
.mc-step { border:1px solid var(--border); background:var(--bg); border-radius:5px; padding:10px; min-height:122px; cursor:pointer; transition:all 90ms; position:relative; }
.mc-step:hover { border-color:var(--amber); background:var(--a-soft); transform:translateY(-1px); }
.mc-step-num { font-size:8px; color:var(--amber); letter-spacing:0.16em; text-transform:uppercase; margin-bottom:8px; }
.mc-step-title { font-size:11px; color:var(--text); margin-bottom:7px; line-height:1.3; }
.mc-step-desc { font-size:9px; line-height:1.5; color:var(--dim); }
.mc-step-foot { position:absolute; left:10px; right:10px; bottom:9px; display:flex; justify-content:space-between; gap:8px; align-items:center; }
.mc-step-status { font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--green); }
.mc-step-link { font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--faint); }
.pipeline-lanes { padding:10px; display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }
.pipeline-lane { border:1px solid var(--border); background:var(--bg); border-radius:5px; padding:10px; min-height:116px; }
.lane-agent { font-family:var(--serif); font-size:18px; font-style:italic; color:var(--text); }
.lane-role { margin:3px 0 9px; font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--faint); }
.lane-output { font-size:9px; line-height:1.45; color:var(--dim); }
.studio-grid { padding:10px; display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
.studio-card { border:1px solid var(--border); background:var(--bg); border-radius:5px; padding:10px; min-height:96px; }
.studio-title { font-size:10px; color:var(--text); margin-bottom:7px; }
.studio-copy { font-size:9px; line-height:1.5; color:var(--dim); }
.analytics-strip { padding:10px; display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
.analytics-box { border:1px solid var(--border); background:var(--bg); border-radius:5px; padding:10px; }
.analytics-value { font-size:18px; color:var(--text); font-variant-numeric:tabular-nums; }
.analytics-label { margin-top:3px; font-size:7px; letter-spacing:0.12em; color:var(--faint); text-transform:uppercase; }
@media (max-width: 1180px) { .mc-steps { grid-template-columns:repeat(2,1fr); } .pipeline-lanes { grid-template-columns:repeat(2,1fr); } .studio-grid, .analytics-strip { grid-template-columns:1fr; } }

    /* ── LOGS ────────────────────────────────────────────── */
    #panel-log { flex-direction: column; }

    .log-bar {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 8px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .fb {
      padding: 3px 10px;
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--dim);
      font-family: var(--mono);
      font-size: 8px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 80ms;
    }
    .fb:hover, .fb.on { border-color: var(--amber); color: var(--amber); background: var(--a-soft); }

    .log-srch {
      flex: 1;
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--border2);
      color: var(--text);
      font-family: var(--mono);
      font-size: 11px;
      padding: 2px 8px;
      outline: none;
      margin-left: 8px;
    }
    .log-srch:focus { border-bottom-color: var(--amber); }
    .log-srch::placeholder { color: var(--faint); }

    .log-cols {
      display: grid;
      grid-template-columns: 148px 68px 90px 1fr 78px;
      gap: 12px;
      padding: 5px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .log-cols span {
      font-size: 7px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--faint);
    }
    .log-cols span:last-child { text-align: right; }

    #log-list { flex: 1; overflow-y: auto; }

    .l-row {
      display: grid;
      grid-template-columns: 148px 68px 90px 1fr 78px;
      gap: 12px;
      padding: 7px 14px;
      border-bottom: 1px solid var(--border);
      align-items: center;
      transition: background 60ms;
      animation: rowIn 160ms ease;
    }
    @keyframes rowIn { from { opacity:0; transform:translateX(-4px); } to { opacity:1; transform:translateX(0); } }
    .l-row:hover { background: var(--surface); }

    .l-time  { font-size: 9px; color: var(--faint); font-variant-numeric: tabular-nums; white-space: nowrap; }
    .l-agent { font-size: 10px; }

    .l-status {
      font-size: 7px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 2px 7px;
    }
    .l-status.completed  { color: var(--green); background: var(--g-soft); }
    .l-status.failed     { color: var(--red);   background: var(--r-soft); }
    .l-status.in_progress{ color: var(--amber); background: var(--a-soft); }

    .l-desc  { font-size: 10px; color: var(--dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .l-model { font-size: 9px; color: var(--faint); text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ── TASKS ───────────────────────────────────────────── */
    #panel-task { overflow-y: auto; flex-direction: column; }

    .t-cols {
      display: grid;
      grid-template-columns: 1fr 96px 90px 140px;
      gap: 12px;
      padding: 5px 14px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      position: sticky;
      top: 0;
      z-index: 2;
    }
    .t-cols span {
      font-size: 7px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--faint);
    }

    .t-row {
      display: grid;
      grid-template-columns: 1fr 96px 90px 140px;
      gap: 12px;
      padding: 9px 14px;
      border-bottom: 1px solid var(--border);
      align-items: center;
      transition: background 60ms;
    }
    .t-row:hover { background: var(--surface); }

    .t-desc  { font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .t-agent { font-size: 10px; color: var(--dim); }
    .t-time  { font-size: 9px; color: var(--faint); font-variant-numeric: tabular-nums; }

    /* ── CHAT ────────────────────────────────────────────── */
    #panel-chat { flex-direction: row; }

    #chat-aside {
      width: 148px;
      border-right: 1px solid var(--border);
      background: var(--surface);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .ca-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      cursor: pointer;
      transition: background 80ms;
      border-left: 2px solid transparent;
    }
    .ca-row:hover  { background: var(--raised); }
    .ca-row.active { background: var(--a-soft); border-left-color: var(--amber); }
    .ca-row.active .ca-name { color: var(--amber); }

    .ca-name { font-size: 11px; flex: 1; }

    .ca-badge {
      font-size: 8px;
      background: var(--red);
      color: #fff;
      min-width: 15px; height: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 3px;
    }

    #chat-body { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

    #chat-hd {
      padding: 9px 15px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    #ch-name {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 300;
      font-style: italic;
    }
    #ch-role { font-size: 8px; color: var(--dim); letter-spacing: 0.08em; }
    #ch-conn { font-size: 7px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--faint); }

    #chat-msgs {
      flex: 1;
      overflow-y: auto;
      padding: 14px;
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .bw { display: flex; flex-direction: column; animation: msgIn 160ms ease; }
    .bw.out { align-items: flex-end; }
    .bw.in  { align-items: flex-start; }
    @keyframes msgIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }

    .bbl {
      max-width: 68%;
      padding: 9px 12px;
      font-size: 12px;
      line-height: 1.55;
    }
    .bbl.out { background: var(--a-soft); border: 1px solid rgba(232,144,10,0.18); }
    .bbl.in  { background: var(--raised); border: 1px solid var(--border2); }

    .bm { font-size: 8px; color: var(--faint); margin-top: 3px; letter-spacing: 0.04em; }

    #chat-compose {
      border-top: 1px solid var(--border);
      background: var(--surface);
      padding: 9px 13px;
      display: flex;
      gap: 8px;
      align-items: flex-end;
      flex-shrink: 0;
    }

    #c-input {
      flex: 1;
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--text);
      font-family: var(--mono);
      font-size: 12px;
      padding: 7px 10px;
      resize: none;
      min-height: 36px;
      max-height: 108px;
      outline: none;
      line-height: 1.5;
      transition: border-color 100ms;
    }
    #c-input:focus { border-color: var(--amber); }
    #c-input::placeholder { color: var(--faint); }

    #c-send {
      padding: 0 15px;
      height: 36px;
      background: var(--amber);
      color: #000;
      border: none;
      font-family: var(--mono);
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 100ms;
    }
    #c-send:hover    { opacity: 0.85; }
    #c-send:disabled { opacity: 0.25; cursor: not-allowed; }

    /* ── EMPTY ───────────────────────────────────────────── */
    .empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      gap: 6px;
      padding: 40px;
      text-align: center;
    }
    .empty-t {
      font-family: var(--serif);
      font-size: 22px;
      font-style: italic;
      font-weight: 300;
      color: var(--border2);
    }
    .empty-s {
      font-size: 8px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--faint);
    }

    /* ── SCROLLBARS ──────────────────────────────────────── */
    ::-webkit-scrollbar       { width: 3px; height: 3px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border2); }
    ::-webkit-scrollbar-thumb:hover { background: var(--dim); }

    /* ── TOASTS ──────────────────────────────────────────── */
    #toasts {
      position: fixed;
      bottom: 14px; right: 14px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      z-index: 100;
      pointer-events: none;
    }
    .toast {
      padding: 9px 13px;
      border: 1px solid var(--border2);
      background: var(--raised);
      font-size: 11px;
      pointer-events: auto;
      animation: tIn 180ms ease;
    }
    @keyframes tIn { from { opacity:0; transform:translateX(14px); } to { opacity:1; transform:translateX(0); } }
    .toast.success { border-left: 2px solid var(--green); }
    .toast.error   { border-left: 2px solid var(--red);   }
    .toast.info    { border-left: 2px solid var(--amber);  }

    /* ── PALETTE ─────────────────────────────────────────── */
    #palette {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.65);
      z-index: 200;
      align-items: flex-start;
      justify-content: center;
      padding-top: 18vh;
    }
    #palette.open { display: flex; }

    .pal-box {
      width: 480px;
      border: 1px solid var(--border2);
      background: var(--surface);
    }

    .pal-ir {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }
    .pal-pr { color: var(--amber); font-size: 14px; }
    .pal-in {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      outline: none;
    }
    .pal-in::placeholder { color: var(--faint); }

    .pal-res { max-height: 300px; overflow-y: auto; }

    .pal-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 16px;
      cursor: pointer;
      font-size: 12px;
      transition: background 60ms;
    }

    /* ── GLOBAL CAPTURE ─────────────────────────────────── */
    #capture-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.68);
      z-index: 700;
      align-items: flex-start;
      justify-content: center;
      padding: 14vh 14px 0;
    }
    #capture-overlay.open { display: flex; }
    .capture-box {
      width: min(680px, 100%);
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 6px;
      box-shadow: 0 18px 80px rgba(0,0,0,0.55);
      overflow: hidden;
    }
    .capture-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
    }
    .capture-title {
      color: var(--amber);
      font-size: 9px;
      letter-spacing: .14em;
      text-transform: uppercase;
    }
    .capture-key {
      color: var(--dim);
      font-size: 8px;
      border: 1px solid var(--border2);
      border-radius: 2px;
      padding: 1px 6px;
    }
    #capture-input {
      width: 100%;
      min-height: 118px;
      resize: vertical;
      background: var(--bg);
      color: var(--text);
      border: none;
      border-bottom: 1px solid var(--border);
      outline: none;
      padding: 14px;
      font: 12px/1.6 var(--mono);
    }
    #capture-input::placeholder { color: var(--faint); }
    .capture-meta {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      color: var(--dim);
      font-size: 9px;
    }
    #capture-intent {
      background: var(--a-soft);
      color: var(--amber);
      border: 1px solid var(--border2);
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 8px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    #capture-route {
      color: var(--dim);
      min-width: 160px;
    }
    .capture-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      justify-content: flex-end;
      padding: 10px 14px;
    }
    .capture-hint { margin-right: auto; color: var(--faint); font-size: 8px; }
    .capture-btn {
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--dim);
      border-radius: 3px;
      padding: 5px 11px;
      cursor: pointer;
      font: 9px var(--mono);
    }
    .capture-btn.primary {
      background: var(--amber);
      border-color: var(--amber);
      color: #000;
      font-weight: 700;
    }
    .pal-item:hover, .pal-item.sel { background: var(--a-soft); color: var(--amber); }

    .pal-key {
      font-size: 8px;
      color: var(--faint);
      border: 1px solid var(--border2);
      padding: 1px 5px;
    }


/* ── TOASTS ────────────────────────────────────── */
#toast-area { position:fixed; bottom:20px; right:20px; z-index:9997; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
.toast2 { padding:10px 18px; border-radius:4px; font-size:11px; background:var(--raised); border:1px solid var(--border2); color:var(--text); animation:tin 240ms ease; pointer-events:auto; max-width:380px; backdrop-filter:blur(8px); }
.toast2.success { border-color:var(--green); box-shadow:0 0 20px var(--g-soft); }
.toast2.error { border-color:var(--red); box-shadow:0 0 20px var(--r-soft); }
.toast2.warn { border-color:var(--amber); box-shadow:0 0 20px var(--a-soft); }
@keyframes tin { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

/* ── CONNECTION STATUS ─────────────────────────── */
#conn-status { display:inline-flex; align-items:center; gap:5px; font-size:8px; padding:0 10px; }
.cs-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
.cs-dot.on { background:var(--green); box-shadow:0 0 4px var(--green); }
.cs-dot.warn { background:var(--amber); }
.cs-dot.off { background:var(--red); }

/* ── FILES PANEL ───────────────────────────────── */
#files-header { display:flex; align-items:center; gap:12px; padding:10px 16px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
#files-grid { flex:1; overflow-y:auto; display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:2px; padding:8px; align-content:start; }
.fi-item { padding:10px 14px; cursor:pointer; display:flex; align-items:center; gap:10px; border-radius:3px; transition:background 80ms; font-size:11px; background:var(--surface); border:1px solid var(--border); }
.fi-item:hover { background:var(--raised); border-color:var(--border2); }
.fi-item .fi-icon { font-size:16px; width:20px; text-align:center; }
.fi-item .fi-name { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.fi-item .fi-meta { font-size:9px; color:var(--dim); text-align:right; flex-shrink:0; }
#file-preview { display:none; position:fixed; inset:40px 40px; z-index:9990; background:var(--bg); border:1px solid var(--border2); border-radius:6px; flex-direction:column; overflow:hidden; box-shadow:0 32px 80px rgba(0,0,0,0.6); }
#file-preview.open { display:flex; }
#fp-header { display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
#fp-title { flex:1; font-size:11px; color:var(--amber); }
#fp-close { cursor:pointer; font-size:14px; color:var(--dim); padding:0 4px; }
#fp-close:hover { color:var(--text); }
#fp-content { flex:1; overflow:auto; padding:16px; font-size:11px; line-height:1.7; white-space:pre-wrap; word-break:break-word; }

/* ── ORCHESTRATION PANEL ───────────────────────── */
#dispatch-bar { display:flex; gap:10px; padding:12px 16px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
#dispatch-input { flex:1; background:transparent; border:1px solid var(--border2); border-radius:4px; padding:8px 12px; font:11px var(--mono); color:var(--text); outline:none; }
#dispatch-input:focus { border-color:var(--amber); }
.dispatch-btn { padding:8px 16px; border:none; border-radius:4px; cursor:pointer; font:9px var(--mono); letter-spacing:0.10em; text-transform:uppercase; background:var(--amber); color:#000; font-weight:600; transition:opacity 120ms; }
.dispatch-btn:disabled { opacity:0.35; cursor:default; }
#agent-picker { display:flex; align-items:center; gap:6px; padding:8px 16px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
.dispatch-mode { font-size:10px; color:var(--dim); }
.ap-btn { padding:4px 12px; border:1px solid var(--border2); border-radius:3px; cursor:pointer; font:9px var(--mono); color:var(--dim); background:transparent; transition:all 80ms; }
.ap-btn:hover { border-color:var(--text); color:var(--text); }
.ap-btn.selected { border-color:var(--amber); color:var(--amber); background:var(--a-soft); }
#dispatch-results { flex:1; overflow-y:auto; }
.dr-card { margin:8px; padding:12px 16px; border:1px solid var(--border); border-radius:4px; background:var(--surface); }
.dr-card .dr-agent { font-size:11px; color:var(--amber); }
.dr-card .dr-status { font-size:9px; color:var(--dim); }
.dr-card .dr-body { margin-top:8px; font-size:11px; line-height:1.6; white-space:pre-wrap; }
.dr-card .dr-meta { margin-top:8px; font-size:9px; color:var(--dim); display:flex; gap:16px; }

/* ── TAB GROUPS ──────────────────────────────────────── */
.tab-group { position:relative; display:flex; }
.tab-group-trigger { cursor:pointer; }
.tab-group-menu { display:none; position:absolute; top:100%; left:0; background:var(--surface); border:1px solid var(--border2); min-width:140px; z-index:200; box-shadow:0 4px 16px rgba(0,0,0,0.5); }
.tab-group:hover .tab-group-menu { display:block; }
.tgm-item { padding:8px 14px; font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim); cursor:pointer; white-space:nowrap; }
.tgm-item:hover { background:var(--raised); color:var(--amber); }

/* ── NOTIFICATION CENTER ────────────────────────────── */
#notif-center { position:fixed; top:0; right:-320px; width:300px; height:100vh; background:var(--surface); border-left:1px solid var(--border2); z-index:500; display:flex; flex-direction:column; transition:right 180ms ease; }
#notif-center.open { right:0; }
#notif-header { padding:10px 14px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:8px; flex-shrink:0; }
#notif-list { flex:1; overflow-y:auto; }
.notif-item { padding:10px 14px; border-bottom:1px solid var(--border); font-size:10px; line-height:1.5; }
.notif-item.unread { background:var(--a-soft); }
.notif-item .ni-type { font-size:8px; letter-spacing:0.12em; text-transform:uppercase; color:var(--amber); margin-bottom:2px; }
.notif-item .ni-msg { color:var(--text); }
.notif-item .ni-time { font-size:8px; color:var(--faint); margin-top:2px; }
.notif-item.success .ni-type { color:var(--green); }
.notif-item.error   .ni-type { color:var(--red); }

/* ── MORNING BRIEF ──────────────────────────────────── */
#brief-card { margin:8px; background:var(--surface); border:1px solid var(--border2); border-left:3px solid var(--amber); border-radius:4px; padding:12px 14px; }
#brief-card .bc-head { font-size:8px; letter-spacing:0.15em; text-transform:uppercase; color:var(--amber); margin-bottom:6px; display:flex; align-items:center; gap:8px; }
#brief-card .bc-body { font-size:10px; line-height:1.7; color:var(--text); white-space:pre-wrap; }

/* ── PROJECTS ────────────────────────────────────────── */
#panel-projects { flex-direction:column; overflow-y:auto; }
.proj-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px; padding:10px; }
.proj-card { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; cursor:pointer; }
.proj-card:hover { border-color:var(--border2); }
