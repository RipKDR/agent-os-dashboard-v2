  <!-- SIDEBAR -->
  <aside id="sidebar">
    <div class="s-label">Agents</div>
    <div id="agent-list"></div>
    <div class="s-label" style="margin-top:4px">System</div>
    <div id="sb-stats">
      <div>
        <div class="ss-v amber" id="ss-total">—</div>
        <div class="ss-l">Total</div>
      </div>
      <div>
        <div class="ss-v green" id="ss-done">—</div>
        <div class="ss-l">Done</div>
      </div>
      <div>
        <div class="ss-v red" id="ss-fail">—</div>
        <div class="ss-l">Failed</div>
      </div>
      <div>
        <div class="ss-v" id="ss-rate" style="color:var(--text)">—</div>
        <div class="ss-l">Rate</div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main id="main">

    <!-- NOW (cockpit, default surface) -->
    <div class="panel active" id="panel-now" style="flex-direction:column;overflow-y:auto;padding:12px;gap:12px">
      <!-- Health strip -->
      <div id="now-health" style="display:flex;gap:12px;align-items:center;padding:6px 10px;background:var(--surface);border:1px solid var(--border);border-radius:3px;font-size:9px;color:var(--dim)"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <!-- Daily Brief -->
        <div style="background:var(--surface);border:1px solid var(--border2);border-left:3px solid var(--amber);border-radius:4px;padding:14px;min-height:160px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
            <span style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber)">Daily Brief</span>
            <button onclick="refreshBrief()" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:2px 8px;font:9px var(--mono);cursor:pointer">Refresh</button>
          </div>
          <div id="now-brief" style="font-size:10px;color:var(--dim);line-height:1.6;white-space:pre-wrap">Loading…</div>
        </div>
        <!-- Top Signals (actionable) -->
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:14px;min-height:160px">
          <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin-bottom:10px">Top Signals</div>
          <div id="now-signals" style="font-size:10px;color:var(--dim)">Loading…</div>
          <div id="now-why" style="margin-top:8px;font-size:10px;color:var(--dim);display:none;border-top:1px solid var(--border);padding-top:8px"></div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <!-- Today's Captures -->
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:14px;min-height:120px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
            <span style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber)">Captures Today</span>
            <button onclick="showCapture()" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:2px 8px;font:9px var(--mono);cursor:pointer">+ New</button>
          </div>
          <div id="now-captures" style="font-size:10px;color:var(--dim)">Loading…</div>
        </div>
        <!-- Pending Approvals -->
        <div style="background:var(--surface);border:1px solid var(--amber);border-radius:4px;padding:14px;min-height:120px">
          <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin-bottom:10px">Pending Approvals</div>
          <div id="now-approvals" style="font-size:10px;color:var(--dim)">Loading…</div>
        </div>
      </div>
      <!-- Agent Inbox area (Pending Approvals + Filings per spec) -->
      <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin:4px 0 6px 4px">Agent Inbox</div>
      <!-- SEC Filings (inside Agent Inbox area) -->
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:14px;min-height:80px">
        <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin-bottom:10px">Recent Filings</div>
        <div id="now-filings" style="font-size:10px;color:var(--dim)">Loading…</div>
      </div>
      <!-- Weekly Review -->
      <div style="background:var(--surface);border:1px solid var(--border2);border-radius:4px;padding:14px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
          <span style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber)">Weekly Review</span>
          <button onclick="generateWeeklyReview()" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:2px 8px;font:9px var(--mono);cursor:pointer">Generate</button>
        </div>
        <div id="now-weekly" style="font-size:10px;color:var(--dim);line-height:1.6;white-space:pre-wrap">Loading…</div>
      </div>

      <!-- Agent Cards (live from Supabase) -->
      <div>
        <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin:4px 0 8px 4px">Agents</div>
        <div id="now-agent-cards" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px"></div>
      </div>

      <!-- Recent Activity Feed (live from Supabase) -->
      <div>
        <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin:4px 0 8px 4px">Recent Activity</div>
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:4px;overflow:hidden">
          <div id="now-activity-feed" style="font-size:10px;color:var(--dim);max-height:300px;overflow-y:auto;padding:8px 0">Loading…</div>
        </div>
      </div>
    </div>

    <!-- KNOWLEDGE (vault browser) -->
    <div class="panel" id="panel-knowledge" style="flex-direction:row;overflow:hidden">
      <div id="vault-tree-pane" style="width:240px;min-width:180px;border-right:1px solid var(--border);overflow-y:auto;flex-shrink:0;display:flex;flex-direction:column">
        <div style="padding:8px 12px;border-bottom:1px solid var(--border);display:flex;gap:6px;align-items:center">
          <input id="vault-search-input" placeholder="Search vault…" onkeydown="if(event.key==='Enter')searchVault(this.value)" style="flex:1;background:var(--bg);border:1px solid var(--border2);color:var(--text);border-radius:2px;padding:4px 8px;font:9px var(--mono)">
          <button onclick="searchVault(document.getElementById('vault-search-input').value)" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:3px 8px;font:9px var(--mono);cursor:pointer">Go</button>
        </div>
        <div style="padding:4px 8px;border-bottom:1px solid var(--border);display:flex;gap:4px;flex-wrap:wrap;flex-shrink:0">
          <button onclick="browseVault('')" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:2px 6px;font:8px var(--mono);cursor:pointer">All</button>
          <button onclick="browseVault('trading')" style="background:none;border:1px solid var(--border2);color:var(--amber);border-radius:2px;padding:2px 6px;font:8px var(--mono);cursor:pointer">Tickers</button>
          <button onclick="browseVault('_daily')" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:2px 6px;font:8px var(--mono);cursor:pointer">Daily</button>
        </div>
        <div style="padding:6px 8px;border-bottom:1px solid var(--border)">
          <div id="upload-zone" style="border:1px dashed var(--dim);border-radius:6px;padding:8px;text-align:center;cursor:pointer;" onclick="document.getElementById('upload-input').click()" ondragover="event.preventDefault();this.style.borderColor='var(--amber)'" ondragleave="this.style.borderColor='var(--dim)'" ondrop="event.preventDefault();this.style.borderColor='var(--dim)';uploadFiles(event.dataTransfer.files)">
            <span style="color:var(--dim);font-size:10px;">Drop or click to upload (.py .js .txt .md .csv …)</span>
            <input type="file" id="upload-input" style="display:none" multiple accept=".py,.js,.ts,.txt,.md,.json,.csv,.yaml,.yml,.sh,.sql,.html,.css" onchange="uploadFiles(this.files);this.value=''">
          </div>
          <div id="upload-status" style="font-size:10px;color:var(--dim);margin-top:4px;min-height:14px;text-align:center"></div>
        </div>
        <div id="vault-tree" style="padding:8px;flex:1;overflow-y:auto;font-size:10px"></div>
      </div>
      <div id="vault-viewer-pane" style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px">
        <div id="vault-content" style="font-size:11px;line-height:1.7;color:var(--text);white-space:pre-wrap">Select a file from the tree to view it.</div>
        <div id="vault-backlinks" style="display:none;border-top:1px solid var(--border);padding-top:10px;margin-top:6px">
          <div style="font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--dim);margin-bottom:6px">Backlinks</div>
          <div id="vault-backlinks-list" style="font-size:10px;color:var(--amber)"></div>
        </div>
      </div>
    </div>

    <!-- OVERVIEW -->
    <div class="panel" id="panel-ov">
      <div id="morning-brief" style="padding:10px 14px;background:var(--surface);border-left:2px solid var(--amber);margin:8px;border-radius:0 4px 4px 0;font-size:10px;color:var(--dim)">Loading today's brief…</div>
      <div class="sys-bar">
        <div class="sb-cell">
          <div class="sb-l">Active Agents</div>
          <div class="sb-v" id="sbc-active">—</div>
        </div>
        <div class="sb-cell">
          <div class="sb-l">Tasks Today</div>
          <div class="sb-v" id="sbc-today">—</div>
        </div>
        <div class="sb-cell">
          <div class="sb-l">Success Rate</div>
          <div class="sb-v" id="sbc-rate">—</div>
        </div>
        <div class="sb-cell">
          <div class="sb-l">Last Activity</div>
          <div class="sb-v" id="sbc-last" style="font-size:13px">—</div>
        </div>
      </div>
      <div id="cards-grid"></div>
    </div>



    <!-- MISSION CONTROL -->
    <div class="panel" id="panel-mission">
      <div class="mission-shell">
        <section class="mc-card mc-hero">
          <div>
            <div class="mc-kicker">Step-by-step rebuild from the YouTube chapters</div>
            <div class="mc-h1">Mission Control operating system.</div>
            <div class="mc-copy">This view now mirrors the video flow directly: agent roster → virtual office → dashboard/task/project views → calendar → docs/memory → content studio → social approvals → software factory → local inbox → cost tracker → logs/settings.</div>
          </div>
          <div class="mc-metrics" id="mission-metrics"></div>
        </section>

        <section class="mc-card" style="grid-column:1/-1">
          <div class="mc-head"><span class="mc-title">Video Chapter Checklist</span><span class="mc-sub">implemented in order, click to jump</span></div>
          <div class="mc-steps" id="mission-steps"></div>
        </section>

        <section class="mc-card" style="grid-column:1/-1">
          <div class="mc-head"><span class="mc-title">02 — Meet the Agents / 04 — Virtual Office</span><span class="mc-sub">roles, status, active desk, current task</span></div>
          <div class="office-grid" id="mission-office"></div>
        </section>

        <section class="mc-card" style="grid-column:1/-1">
          <div class="mc-head"><span class="mc-title">06–07 — Task Board + Project Pipeline</span><span class="mc-sub">who owns each phase from idea to release</span></div>
          <div class="pipeline-lanes" id="mission-pipeline"></div>
        </section>

        <section class="mc-card">
          <div class="mc-head"><span class="mc-title">08 — Agent Calendar</span><span class="mc-sub">recurring jobs + daily cadence</span></div>
          <div class="queue-list" id="mission-calendar"></div>
        </section>

        <section class="mc-card">
          <div class="mc-head"><span class="mc-title">09 — Docs + Memory Files</span><span class="mc-sub">visible workspace memory/docs surfaces</span></div>
          <div class="module-grid" id="mission-memory"></div>
        </section>

        <section class="mc-card" style="grid-column:1/-1">
          <div class="mc-head"><span class="mc-title">10–16 — Content, Analytics, Social, Factory, Inbox</span><span class="mc-sub">operational modules from the video</span></div>
          <div class="studio-grid" id="mission-studio"></div>
        </section>

        <section class="mc-card">
          <div class="mc-head"><span class="mc-title">13–16 — Approval Queue</span><span class="mc-sub">human-in-loop before social/email/external actions</span></div>
          <div class="approval-list" id="mission-approvals"></div>
        </section>

        <section class="mc-card">
          <div class="mc-head"><span class="mc-title">21 — Cost / ROI Tracker</span><span class="mc-sub">proxy from recent model use</span></div>
          <div class="cost-bars" id="mission-costs"></div>
        </section>

        <section class="mc-card" style="grid-column:1/-1">
          <div class="mc-head"><span class="mc-title">22 — Logs + Settings</span><span class="mc-sub">audit, config, health, and shortcuts</span></div>
          <div class="analytics-strip" id="mission-ops"></div>
        </section>
      </div>
    </div>

    <!-- LOGS -->
    <div class="panel" id="panel-log">
      <div id="docker-health-bar" style="display:flex;align-items:center;gap:8px;padding:6px 12px;border-bottom:1px solid var(--border);background:var(--raised);flex-shrink:0;overflow-x:auto;min-height:28px">
        <span style="font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.10em;flex-shrink:0">System</span>
        <div id="docker-chips" style="display:flex;gap:6px;flex-wrap:wrap"></div>
        <button onclick="loadDockerHealth()" style="margin-left:auto;font-size:8px;background:none;border:none;color:var(--dim);cursor:pointer;flex-shrink:0">↻</button>
      </div>
      <div class="log-bar">
        <button class="fb on" data-agent="all">All</button>
        <button class="fb" data-agent="alex">Alex</button>
        <button class="fb" data-agent="maya">Maya</button>
        <button class="fb" data-agent="jordan">Jordan</button>
        <button class="fb" data-agent="dev">Dev</button>
        <button class="fb" data-agent="sam">Sam</button>
        <input class="log-srch" id="log-srch" type="text" placeholder="Search logs…" />
        <button class="fb" id="fb-jobs" data-agent="__jobs__" onclick="toggleJobsMode()">Jobs</button>
        <button class="dispatch-btn" onclick="exportLogs()" style="font-size:8px;padding:3px 10px;margin-left:auto">⬇ CSV</button>
      </div>
      <div class="log-cols" id="log-cols-hdr">
        <span>Time</span>
        <span>Agent</span>
        <span>Status</span>
        <span>Task</span>
        <span>Model</span>
      </div>
      <div id="log-list"></div>
    </div>

    <!-- NEWS FEED -->
    <div class="panel" id="panel-news" style="flex-direction:column;overflow:hidden">
      <div style="display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0">
        <span style="font-size:11px;color:var(--amber)">News Feed</span>
        <input id="comms-ticker-filter" placeholder="Filter by ticker…" oninput="loadCommsFeed(this.value)" style="background:var(--bg);border:1px solid var(--border2);color:var(--text);border-radius:2px;padding:4px 8px;font:9px var(--mono);width:140px">
        <button onclick="loadCommsFeed(document.getElementById('comms-ticker-filter').value)" style="background:none;border:1px solid var(--border2);color:var(--dim);border-radius:2px;padding:3px 8px;font:8px var(--mono);cursor:pointer">Refresh</button>
      </div>
      <div id="news-feed-list" style="flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:4px">
        <div class="empty"><div class="empty-t">News Feed</div><div class="empty-s">Switch to this tab to load latest news.</div></div>
      </div>
    </div>

    <!-- TASKS -->
    <div class="panel" id="panel-task">
      <div class="t-cols">
        <span>Task</span>
        <span>Agent</span>
        <span>Status</span>
        <span>Time</span>
      </div>
      <div id="task-list" style="overflow-y:auto;flex:1"></div>
    </div>

    <!-- FILES -->
    <div class="panel" id="panel-files" style="flex-direction:column">
      <div id="files-header">
        <span style="font-size:10px;letter-spacing:0.10em;color:var(--amber)">📂</span>
        <span id="files-path">workspace/</span>
        <input id="files-search" style="flex:1;max-width:200px;background:transparent;border:1px solid var(--border2);border-radius:3px;padding:4px 10px;font:10px var(--mono);color:var(--text);outline:none" placeholder="Search files…">
        <button class="dispatch-btn" onclick="toggleTagsSidebar()" style="font-size:8px;padding:4px 8px;background:transparent;border:1px solid var(--border2);color:var(--dim)" title="Tags filter (Obsidian)">🏷 Tags</button>
        <button class="dispatch-btn" onclick="loadDir('dashboard-v2')" style="font-size:8px;padding:4px 8px;background:var(--amber);color:#000">📋 Spec Docs</button>
      </div>
      <div style="display:flex;flex:1;overflow:hidden;min-height:0">
        <!-- Tags sidebar -->
        <div id="tags-sidebar" style="display:none;width:160px;flex-shrink:0;border-right:1px solid var(--border);overflow-y:auto;background:var(--raised)">
          <div style="padding:8px 10px;font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.10em;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            Tags
            <button onclick="clearTagFilter()" style="font-size:8px;color:var(--dim);background:none;border:none;cursor:pointer">✕ clear</button>
          </div>
          <div id="tags-list" style="padding:6px 0"></div>
        </div>
        <!-- Main file area -->
        <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0">
          <div id="file-preview">
            <div id="fp-header">
              <span id="fp-title"></span>
              <span id="fp-close" onclick="closeFilePreview()">✕</span>
              <span id="fp-save" onclick="saveFileFromPreview()" style="display:none;cursor:pointer;color:var(--green);font-size:9px;padding:0 8px">💾 Save</span>
              <span style="font-size:9px;color:var(--dim)" id="fp-path-display"></span>
            </div>
            <div id="fp-content"></div>
          </div>
          <div id="files-grid" style="overflow-y:auto;flex:1"></div>
        </div>
      </div>
    </div>
    <div class="panel" id="panel-orch" style="flex-direction:column">
      <div id="orch-mode-tabs" style="display:flex;gap:0;border-bottom:1px solid var(--border);flex-shrink:0">
        <button class="om-tab active" onclick="switchOrchMode('dispatch',this)">⚡ Dispatch</button>
        <button class="om-tab" onclick="switchOrchMode('pipeline',this)">🔗 Pipeline</button>
        <button class="om-tab" onclick="switchOrchMode('risks',this)">⚠️ Risks</button>
        <button class="om-tab" onclick="switchOrchMode('sessions',this)">👁 Sessions</button>
      </div>
      
      <!-- Dispatch Mode -->
      <div id="orch-dispatch" style="display:flex;flex-direction:column;flex:1;overflow:hidden">
        <div id="dispatch-bar">
          <input id="dispatch-input" placeholder="What do you need done? e.g. Research competitor pricing…" spellcheck="false">
          <button class="dispatch-btn active" onclick="dispatchTask()">🚀 Send</button>
          <button class="dispatch-btn" onclick="showModelInfo()" title="Auto-model selection" style="font-size:8px;padding:4px 8px;background:transparent;border:1px solid var(--border2);color:var(--dim)">🤖</button>
        </div>
        <div id="agent-picker">
          <span class="dispatch-mode">→</span>
          <button class="ap-btn selected" data-agent="alex" onclick="toggleAgent(this)">Alex</button>
          <button class="ap-btn" data-agent="maya" onclick="toggleAgent(this)">Maya</button>
          <button class="ap-btn" data-agent="jordan" onclick="toggleAgent(this)">Jordan</button>
          <button class="ap-btn" data-agent="dev" onclick="toggleAgent(this)">Dev</button>
          <button class="ap-btn" data-agent="sam" onclick="toggleAgent(this)">Sam</button>
          <span style="flex:1"></span>
          <button class="ap-btn" onclick="selectAllAgents()">All</button>
        </div>
        <div id="dispatch-results" style="flex:1;overflow-y:auto">
          <div class="empty" id="dispatch-empty">
            <div class="empty-t">Dispatch Console</div>
            <div class="empty-s">Type a task, pick agents, hit Send</div>
          </div>
        </div>
      </div>
      
      <!-- Pipeline Mode -->
      <div id="orch-pipeline" style="display:none;flex-direction:column;flex:1;overflow:hidden">
        <div style="display:flex;gap:8px;padding:10px 16px;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0;align-items:center">
          <span style="font-size:10px;color:var(--dim)">Template:</span>
          <select id="pipeline-template" onchange="loadPipelineTemplate(this.value)" style="background:var(--bg);color:var(--text);border:1px solid var(--border2);border-radius:2px;padding:4px 8px;font:9px var(--mono)">
            <option value="full-mvp">🏗️ Full MVP (Alex→Maya→Jordan→Dev→Sam)</option>
            <option value="feature">🎯 Feature Scoped (Maya→Jordan→Dev)</option>
            <option value="debug">🔧 Debug & Fix (Dev→Sam)</option>
            <option value="research">📊 Quick Research (Alex)</option>
            <option value="custom">✏️ Custom</option>
          </select>
          <span style="flex:1"></span>
          <button class="dispatch-btn" onclick="runPipeline()" style="background:var(--green);color:#000">▶ Run Pipeline</button>
        </div>
        <div id="pipeline-steps" style="padding:8px;flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px">
          <div class="empty"><div class="empty-t">Select a template or build custom</div><div class="empty-s">Each step runs after the previous completes, passing context automatically</div></div>
        </div>
        <div id="pipeline-input" style="display:flex;gap:8px;padding:10px 16px;border-top:1px solid var(--border);background:var(--surface);flex-shrink:0">
          <input id="pipeline-task-desc" placeholder="What should the pipeline accomplish?" style="flex:1;background:transparent;border:1px solid var(--border2);border-radius:4px;padding:8px 12px;font:11px var(--mono);color:var(--text);outline:none">
        </div>
      </div>
      
      <!-- Risks Mode -->
      <div id="orch-risks" style="display:none;flex-direction:column;flex:1;overflow:hidden">
        <div id="risks-content" style="flex:1;overflow-y:auto;padding:8px">
          <div class="empty"><div class="empty-t">Task Risk Panel</div><div class="empty-s">Overdue, aging, and blocked tasks will appear here</div></div>
        </div>
      </div>
      
      <!-- Sessions Mode -->
      <div id="orch-sessions" style="display:none;flex-direction:column;flex:1;overflow:hidden">
