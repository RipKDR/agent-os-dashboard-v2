/* ─── Data freshness ─────────────────────────── */
const _dataTs = {};
function markFresh(panelId) { _dataTs[panelId] = Date.now(); _updateFreshnessDisplay(); }
function _updateFreshnessDisplay() {
  const now = Date.now();
  document.querySelectorAll('[data-freshness-for]').forEach(el => {
    const id = el.dataset.freshnessFor;
    const ts = _dataTs[id];
    if (!ts) { el.textContent = ''; return; }
    const s = Math.round((now - ts) / 1000);
    if (s < 60) el.textContent = `${s}s ago`;
    else if (s < 3600) el.textContent = `${Math.floor(s/60)}m ago`;
    else el.textContent = `${Math.floor(s/3600)}h ago`;
    el.style.color = s > 300 ? 'var(--red)' : 'var(--faint)';
  });
}
setInterval(_updateFreshnessDisplay, 10000);

