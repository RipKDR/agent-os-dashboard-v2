.cron-list { padding:8px; display:flex; flex-direction:column; gap:4px; }
.cron-row { display:grid; grid-template-columns:140px 80px 1fr 80px; gap:8px; align-items:center; padding:8px 10px; background:var(--surface); border:1px solid var(--border); border-radius:3px; font-size:10px; }
.cron-job { color:var(--text); }
.cron-agent { color:var(--amber); font-size:9px; }
.cron-sched { color:var(--dim); font-size:9px; }
.cron-status { font-size:8px; text-align:right; }
.cron-status.scheduled { color:var(--green); }
.cron-status.running { color:var(--amber); }

/* ── TRADING ─────────────────────────────────────────── */
#panel-trading { flex-direction:column; }
#trading-mode-tabs { display:flex; border-bottom:1px solid var(--border); flex-shrink:0; }
.tm-tab { flex:1; padding:8px; border:none; border-right:1px solid var(--border); cursor:pointer; font:9px var(--mono); color:var(--dim); background:transparent; text-transform:uppercase; letter-spacing:0.10em; }
.tm-tab:last-child { border-right:none; }
.tm-tab.active { color:var(--amber); background:var(--a-soft); }
.om-tab, .gh-tab { flex:1; padding:8px; border:none; border-right:1px solid var(--border); cursor:pointer; font:9px var(--mono); color:var(--dim); background:transparent; text-transform:uppercase; letter-spacing:0.10em; }
.om-tab:last-child, .gh-tab:last-child { border-right:none; }
.om-tab.active, .gh-tab.active { color:var(--amber); background:var(--a-soft); }
.trading-view { display:none; flex:1; overflow-y:auto; flex-direction:column; }
.trading-view.active { display:flex; }
.macro-strip { display:flex; gap:0; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; overflow-x:auto; }
.macro-cell { padding:8px 14px; border-right:1px solid var(--border); flex-shrink:0; }
.macro-label { font-size:7px; letter-spacing:0.12em; text-transform:uppercase; color:var(--faint); }
.macro-val { font-size:13px; color:var(--text); font-variant-numeric:tabular-nums; }
.macro-chg { font-size:9px; }
.macro-chg.pos { color:var(--green); }
.macro-chg.neg { color:var(--red); }
.watchlist-wrap { padding:8px; }
.wl-row { display:grid; grid-template-columns:80px 100px 70px 1fr 60px; gap:8px; align-items:center; padding:8px 10px; background:var(--surface); border:1px solid var(--border); border-radius:3px; margin-bottom:4px; font-size:10px; cursor:pointer; }
.wl-row:hover { border-color:var(--border2); }
.wl-ticker { font-size:12px; color:var(--amber); }
.wl-price { font-variant-numeric:tabular-nums; color:var(--text); }
.wl-chg.pos { color:var(--green); }
.wl-chg.neg { color:var(--red); }
.wl-52w { display:flex; align-items:center; gap:6px; }
.wl-52bar { flex:1; height:3px; background:var(--faint); border-radius:2px; }
.wl-52fill { height:3px; background:var(--amber); border-radius:2px; }
.signal-card { margin:4px 8px; background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; }
.signal-card.long .sc-dir { color:var(--green); }
.signal-card.short .sc-dir { color:var(--red); }
.sc-head { display:flex; align-items:center; gap:8px; margin-bottom:6px; }
.sc-dir { font-size:10px; font-weight:600; }
.sc-ticker { font-size:14px; color:var(--text); }
.sc-conv { color:var(--amber); font-size:10px; }
.sc-levels { display:flex; gap:16px; margin-bottom:6px; font-size:9px; color:var(--dim); font-variant-numeric:tabular-nums; }
.sc-levels span { color:var(--text); }
.sc-thesis { font-size:10px; color:var(--dim); line-height:1.5; margin-bottom:8px; font-style:italic; }
.sc-actions { display:flex; gap:6px; }
.sc-btn { padding:4px 10px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); letter-spacing:0.08em; cursor:pointer; border-radius:2px; text-transform:uppercase; }
.sc-btn:hover { color:var(--text); border-color:var(--border); }
.sc-btn.approve { border-color:var(--green); color:var(--green); }
.sc-btn.reject { border-color:var(--red); color:var(--red); }
.journal-row { margin:4px 8px; background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:10px 14px; display:flex; align-items:flex-start; gap:12px; }
.jr-pct.pos { color:var(--green); }
.jr-pct.neg { color:var(--red); }
.jr-meta { font-size:9px; color:var(--dim); }
.risk-section { padding:10px 14px; }
.risk-heat { display:flex; flex-direction:column; gap:4px; margin:8px 0; }
.rh-row { display:flex; align-items:center; gap:8px; font-size:9px; }
.rh-label { width:60px; color:var(--dim); }
.rh-bar { flex:1; height:6px; background:var(--faint); border-radius:3px; }
.rh-fill { height:6px; background:var(--amber); border-radius:3px; }
.rh-pct { width:40px; text-align:right; color:var(--text); }
.sizer-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin:8px 0; }
.sizer-field { display:flex; flex-direction:column; gap:3px; }
.sizer-label { font-size:8px; color:var(--faint); letter-spacing:0.10em; text-transform:uppercase; }
.sizer-input { background:transparent; border:1px solid var(--border2); border-radius:2px; padding:4px 8px; font:10px var(--mono); color:var(--text); outline:none; }
.sizer-input:focus { border-color:var(--amber); }
.sizer-result { grid-column:1/-1; padding:10px; background:var(--a-soft); border:1px solid var(--amber); border-radius:3px; font-size:11px; color:var(--amber); text-align:center; }

/* ── CONTENT ENGINE ──────────────────────────────────── */
#panel-content { flex-direction:column; }
#content-mode-tabs { display:flex; border-bottom:1px solid var(--border); flex-shrink:0; }
.cm-tab { flex:1; padding:8px; border:none; border-right:1px solid var(--border); cursor:pointer; font:9px var(--mono); color:var(--dim); background:transparent; text-transform:uppercase; letter-spacing:0.10em; }
.cm-tab:last-child { border-right:none; }
.cm-tab.active { color:var(--amber); background:var(--a-soft); }
.content-view { display:none; flex:1; overflow-y:auto; padding:8px; }
.content-view.active { display:block; }
.idea-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:8px; }
.idea-card { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; }
.idea-title { font-size:11px; color:var(--text); margin-bottom:4px; }
.idea-source { font-size:8px; color:var(--faint); text-transform:uppercase; letter-spacing:0.10em; margin-bottom:6px; }
.idea-signal { height:3px; background:var(--faint); border-radius:2px; margin-bottom:8px; }
.idea-signal-fill { height:3px; background:var(--amber); border-radius:2px; }
.idea-actions { display:flex; gap:6px; }
.idea-btn { flex:1; padding:4px 6px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); cursor:pointer; border-radius:2px; text-transform:uppercase; }
.idea-btn.approve { border-color:var(--green); color:var(--green); }
.idea-btn.reject { border-color:var(--red); color:var(--red); }
.video-card { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; margin-bottom:8px; }
.vc-title { font-size:12px; color:var(--amber); margin-bottom:4px; }
.vc-status { font-size:8px; color:var(--dim); text-transform:uppercase; letter-spacing:0.10em; display:inline-block; padding:2px 6px; border:1px solid var(--border2); border-radius:2px; margin-bottom:8px; }
.vc-outline { font-size:10px; color:var(--dim); line-height:1.5; white-space:pre-wrap; }
.analytics-kpi { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:12px; }
.kpi-box { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:10px 12px; }
.kpi-val { font-size:20px; color:var(--text); font-variant-numeric:tabular-nums; }
.kpi-label { font-size:8px; color:var(--faint); text-transform:uppercase; letter-spacing:0.10em; margin-top:2px; }

/* ── FACTORY ─────────────────────────────────────────── */
#panel-factory { flex-direction:column; overflow-y:auto; }
.factory-kanban { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; padding:10px; min-height:300px; }
.kanban-col { background:var(--surface); border:1px solid var(--border); border-radius:4px; }
.kanban-head { padding:8px 10px; border-bottom:1px solid var(--border); font-size:8px; letter-spacing:0.14em; text-transform:uppercase; color:var(--amber); }
.kanban-items { padding:6px; display:flex; flex-direction:column; gap:4px; }
.factory-card { background:var(--raised); border:1px solid var(--border); border-radius:3px; padding:10px 12px; }
.fc-title { font-size:10px; color:var(--text); margin-bottom:4px; }
.fc-problem { font-size:9px; color:var(--dim); line-height:1.4; margin-bottom:6px; }
.fc-signal { height:2px; background:var(--faint); border-radius:1px; margin-bottom:6px; }
.fc-signal-fill { height:2px; background:var(--amber); border-radius:1px; }
.fc-link { font-size:9px; color:var(--amber); text-decoration:none; }
.fc-link:hover { text-decoration:underline; }

/* ── EMAIL INBOX ─────────────────────────────────────── */
#panel-email { flex-direction:column; overflow-y:auto; }
.inbox-bar { display:flex; gap:8px; padding:8px 14px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; flex-wrap:wrap; align-items:center; }
.inbox-filter-btn { padding:3px 8px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); cursor:pointer; border-radius:2px; text-transform:uppercase; }
.inbox-filter-btn.active { color:var(--amber); border-color:var(--amber); }
.email-row { padding:10px 14px; border-bottom:1px solid var(--border); cursor:pointer; }
.email-row:hover { background:var(--surface); }
.er-head { display:flex; align-items:center; gap:8px; margin-bottom:4px; }
.er-from { font-size:11px; color:var(--text); flex:1; }
.er-priority { font-size:7px; text-transform:uppercase; letter-spacing:0.10em; padding:1px 5px; border-radius:2px; }
.er-priority.high { background:var(--r-soft); color:var(--red); }
.er-priority.med  { background:var(--a-soft); color:var(--amber); }
.er-priority.low  { background:var(--g-soft); color:var(--green); }
.er-subject { font-size:10px; color:var(--dim); margin-bottom:4px; }
.er-summary { font-size:9px; color:var(--faint); line-height:1.4; }
.er-actions { display:flex; gap:6px; margin-top:6px; flex-wrap:wrap; }
.er-btn { padding:3px 8px; border:1px solid var(--border2); background:transparent; color:var(--dim); font:8px var(--mono); cursor:pointer; border-radius:2px; text-transform:uppercase; }
.er-btn:hover { color:var(--text); }
.er-btn.pos { border-color:var(--green); color:var(--green); }
.er-btn.neg { border-color:var(--red); color:var(--red); }
.er-draft { margin-top:8px; background:var(--a-soft); border:1px solid var(--border2); border-radius:3px; padding:8px 10px; font-size:10px; color:var(--text); line-height:1.5; white-space:pre-wrap; }

/* ── COSTS ───────────────────────────────────────────── */
#panel-costs { flex-direction:column; overflow-y:auto; }
.costs-kpi { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; padding:10px; }
.costs-chart-wrap { padding:0 10px 10px; }
.costs-table { width:100%; border-collapse:collapse; font-size:10px; margin:0 10px; width:calc(100% - 20px); }
.costs-table th { padding:6px 8px; border-bottom:1px solid var(--border); font-size:8px; letter-spacing:0.10em; text-transform:uppercase; color:var(--faint); text-align:left; }
.costs-table td { padding:6px 8px; border-bottom:1px solid var(--border); color:var(--text); }
.suggestion-card { margin:8px 10px; background:var(--a-soft); border:1px solid var(--amber); border-radius:4px; padding:10px 12px; font-size:10px; color:var(--text); display:flex; align-items:center; gap:10px; }

/* ── TEAM ────────────────────────────────────────────── */
#panel-team { flex-direction:column; overflow-y:auto; }
.mission-banner { padding:20px 24px; background:radial-gradient(circle at top left,rgba(232,144,10,0.12),transparent 60%); border-bottom:1px solid var(--border); }
.mission-text { font-family:var(--serif); font-size:18px; font-style:italic; color:var(--text); }
.org-chart { padding:16px 24px; }
.org-row { display:flex; gap:12px; justify-content:center; margin-bottom:12px; }
.org-node { background:var(--surface); border:1px solid var(--border2); border-radius:4px; padding:10px 14px; text-align:center; min-width:120px; }
.org-node.ceo { border-color:var(--amber); }
.org-node.cos { border-color:var(--border); background:var(--raised); }
.org-name { font-size:11px; color:var(--amber); }
.org-role { font-size:8px; color:var(--dim); margin-top:2px; }
.org-model { font-size:8px; color:var(--faint); margin-top:2px; }
.org-line { width:1px; height:16px; background:var(--border2); margin:0 auto; }
.team-agents { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:8px; padding:10px 20px; }
.team-card { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:12px 14px; }
.tc-name { font-size:13px; color:var(--amber); margin-bottom:2px; }
.tc-role { font-size:9px; color:var(--dim); margin-bottom:6px; }
.tc-model { font-size:8px; color:var(--faint); padding:2px 6px; border:1px solid var(--border2); border-radius:2px; display:inline-block; }
.tc-last { font-size:9px; color:var(--faint); margin-top:6px; }

/* ── VIRTUAL OFFICE ──────────────────────────────────── */
#panel-office { flex-direction:column; overflow:hidden; }
.office-layout { flex:1; display:grid; gap:16px; padding:16px; align-content:start; }
.desk-tile { background:var(--surface); border:1px solid var(--border); border-radius:6px; padding:14px 16px; position:relative; transition:border-color 200ms,box-shadow 200ms; }
.desk-tile.working { border-color:var(--amber); box-shadow:0 0 12px rgba(232,144,10,0.15); }
.desk-tile.idle { opacity:0.6; }
.desk-icon { font-size:22px; margin-bottom:6px; text-align:center; }
.desk-name { font-size:11px; color:var(--amber); text-align:center; margin-bottom:2px; }
.desk-status { font-size:8px; text-align:center; text-transform:uppercase; letter-spacing:0.10em; color:var(--dim); margin-bottom:6px; }
.desk-status.working { color:var(--green); }
.desk-task { font-size:9px; color:var(--faint); line-height:1.4; text-align:center; }
.desk-cursor { display:inline-block; animation:blink 1s step-end infinite; }
