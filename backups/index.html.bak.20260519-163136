/* ─── SECURITY PANEL ────────────────────────────── */
async function loadSecurity() {
  const agentList = AGENTS.length ? AGENTS : [];
  let pricing = { model_prices: {}, avg_tokens: 2000 };
  try {
    const costCfg = await fetch('/api/costs').then(r=>r.json());
    if (costCfg) pricing = costCfg;
  } catch {}

  const estCost = row => modelCostFromPricing(row.model_used, pricing);

  const today = new Date().toDateString();
  const cutoff7d = Date.now() - daysMs(7);

  // --- Cost anomalies: compute per-agent today vs 7d avg ---
  const costEl = document.getElementById('sec-cost-anomalies');
  if (costEl && allLogs.length) {
    const todayLogs   = allLogs.filter(l => new Date(l.created_at).toDateString() === today);
    const week7Logs   = allLogs.filter(l => new Date(l.created_at).getTime() > cutoff7d);
    const agentIds    = [...new Set(allLogs.map(l=>l.agent_name))];
    const spikes = agentIds.map(ag => {
      const todayCost = todayLogs.filter(l=>l.agent_name===ag).reduce((s,l)=>s+estCost(l),0);
      const weekDays  = 7;
      const avgCost   = week7Logs.filter(l=>l.agent_name===ag).reduce((s,l)=>s+estCost(l),0) / weekDays;
      const mult      = avgCost < 0.0001 ? 1 : todayCost/avgCost;
      return { agent:ag, today_cost:todayCost, avg7d_cost:avgCost, mult };
    }).filter(a => a.mult >= 3 && a.today_cost > 0.001);

    if (!spikes.length) {
      costEl.innerHTML = `<div style="font-size:10px;color:var(--green)">✓ No cost anomalies detected</div>`;
    } else {
      costEl.innerHTML = spikes.map(a => `
        <div style="display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid var(--border);font-size:9px">
          <span style="color:var(--red);font-size:13px">⚠</span>
          <span style="color:var(--amber)">${escHtml(a.agent)}</span>
          <span style="color:var(--text)">Today: <b>$${a.today_cost.toFixed(4)}</b></span>
          <span style="color:var(--dim)">7d avg: $${a.avg7d_cost.toFixed(4)}/day</span>
          <span style="color:var(--red)">${a.mult.toFixed(1)}× spike</span>
        </div>`).join('');
    }
  } else if (costEl) {
    costEl.innerHTML = `<div style="font-size:9px;color:var(--dim)">No log data available yet</div>`;
  }

  // --- Failed tasks in last 24h from allLogs ---
  const failEl = document.getElementById('sec-failed-tasks');
  if (failEl) {
    const cutoff = Date.now() - daysMs(1);
    const failed = allLogs.filter(l => l.status === 'failed' && new Date(l.created_at).getTime() > cutoff);
    if (!failed.length) {
      failEl.innerHTML = `<div style="font-size:10px;color:var(--green)">✓ No failed tasks in last 24h</div>`;
    } else {
      // group by agent
      const byAgent = {};
      failed.forEach(l => { byAgent[l.agent_name] = (byAgent[l.agent_name]||0)+1; });
      failEl.innerHTML = Object.entries(byAgent).map(([ag, cnt]) => {
        const pct = Math.round(cnt / Math.max(allLogs.filter(l=>l.agent_name===ag && new Date(l.created_at).getTime()>cutoff).length,1) * 100);
        const col = pct > 30 ? 'var(--red)' : pct > 15 ? 'var(--amber)' : 'var(--text)';
        return `<div style="display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid var(--border);font-size:9px">
          <span style="color:var(--amber)">${escHtml(ag)}</span>
          <span style="color:${col}">${cnt} failures (${pct}%)</span>
          ${pct>30?'<span style="color:var(--red)">⚠ High failure rate</span>':''}
        </div>`;
      }).join('') || `<div style="font-size:9px;color:var(--dim)">—</div>`;
    }
  }

  // --- Agent scope audit: last 5 tasks per agent ---
  const scopeEl = document.getElementById('sec-scope-audit');
  if (scopeEl) {
    const out = agentList.map(ag => {
      const id = ag.id || ag.name?.toLowerCase();
      const recent = (logsByAgent[id]||[]).slice(0,5);
      if (!recent.length) return `<div style="font-size:9px;color:var(--dim);margin-bottom:6px">${escHtml(ag.name||id)}: no recent tasks</div>`;
      const flags = recent.filter(l => /\b(rm|delete|drop|truncate|unlink|sudo|chmod|chown|curl.*webhook|exec\(|eval\()/i.test(l.task_description||''));
      const flagHtml = flags.length ? `<span style="color:var(--red);margin-left:6px">⚠ ${flags.length} flagged</span>` : `<span style="color:var(--green);margin-left:6px">✓ clean</span>`;
      return `<div style="margin-bottom:8px">
        <div style="font-size:9px;color:var(--amber);margin-bottom:3px">${escHtml(ag.name||id)}${flagHtml}</div>
        ${recent.map(l=>`<div style="font-size:8px;color:var(--dim);padding:2px 0;border-bottom:1px solid var(--border)">${escHtml((l.task_description||'').slice(0,80))}</div>`).join('')}
      </div>`;
    }).join('');
    scopeEl.innerHTML = out || `<div class="empty"><div class="empty-t">No data</div></div>`;
  }

  // --- Data store status: show which data sources have been populated ---
  const storeEl = document.getElementById('sec-store-status');
  if (storeEl) {
    const storeChecks = [
      { name:'watchlist',    url:'/api/trading/watchlist' },
      { name:'signals',      url:'/api/trading/signals' },
      { name:'journal',      url:'/api/trading/journal' },
      { name:'factory',      url:'/api/factory/proposals' },
      { name:'email-inbox',  url:'/api/email/inbox' },
      { name:'content-ideas',url:'/api/content/ideas' },
      { name:'projects',     url:'/api/projects' },
      { name:'goals',        url:'/api/goals' },
    ];
    const results = await Promise.allSettled(storeChecks.map(sc => fetch(sc.url).then(r=>r.json()).then(d=>({...sc, count: Array.isArray(d)?d.length:0, ok:true})).catch(()=>({...sc, ok:false}))));
    storeEl.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">` +
      results.map(r => {
        const d = r.status==='fulfilled'?r.value:{name:'?',ok:false,count:0};
        return `<div style="font-size:9px;padding:4px 8px;background:var(--raised);border-radius:3px;display:flex;align-items:center;gap:4px">
          <span style="color:${d.ok?'var(--green)':'var(--red)'}">●</span>
          ${escHtml(d.name)}
          <span style="color:var(--dim);margin-left:auto">${d.count}</span>
        </div>`;
      }).join('') +
      `</div>`;
  }
}

