function updateConnection(status, text) {
  const dot = document.querySelector('#conn-status .cs-dot');
  const label = document.getElementById('cs-text');
  if (!dot || !label) return;
  dot.className = 'cs-dot ' + status;
  label.textContent = text || status;
}

let eventSource = null;
let sseBackoff = 1000;
function connectSSE() {
  if (eventSource) { eventSource.close(); }
  try {
    eventSource = new EventSource('/api/events');
    eventSource.addEventListener('connected', () => {
      updateConnection('on', 'live');
      sseBackoff = 1000; // reset on success
    });
    eventSource.addEventListener('cli-output', (e) => {
      try { handleCLIOutput(JSON.parse(e.data)); } catch {}
    });
    eventSource.addEventListener('relay-event', (e) => {
      try { if (window._handleSSEEvent) window._handleSSEEvent('relay-event', JSON.parse(e.data)); } catch {}
    });
    eventSource.onerror = () => {
      updateConnection('warn', 'reconnecting…');
      sseBackoff = Math.min(sseBackoff * 1.5 + Math.random() * 1000, 30000);
      setTimeout(connectSSE, sseBackoff);
    };
  } catch (e) {
    updateConnection('off', 'offline');
  }
}

