    }
    const m = node.name.match(/^([A-Z0-9._-]+)\.md$/i);
    const t = m ? m[1].toUpperCase() : null;
    const badge = (t && wlSet.has(t)) ? `<span style="margin-left:4px;font-size:7px;padding:0 3px;border:1px solid var(--amber);color:var(--amber);border-radius:2px">WL</span>` : '';
