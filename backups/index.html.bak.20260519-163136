      } else {
        const icon = item.name.match(/\.(md)$/i) ? '📄' : item.name.match(/\.(js|ts|tsx|jsx)$/i) ? '⚡' : item.name.match(/\.(json|yml|yaml|toml)$/i) ? '⚙️' : item.name.match(/\.(html|css)$/i) ? '🎨' : '📄';
        html += `<div class="fi-item" onclick="openFile('${escHtml(item.name).replace(/'/g, "\\'")}')"><span class="fi-icon">${icon}</span><span class="fi-name">${escHtml(item.name)}</span><span class="fi-meta">${item.size > 1024 ? Math.round(item.size/1024)+'KB' : item.size+'B'}</span></div>`;
      }
    });
