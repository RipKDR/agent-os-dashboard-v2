/* ─── GLOBAL CAPTURE ─────────────────────────────────────── */
function classifyCaptureText(text) {
  const raw = String(text || '').trim();
  const t = raw.toLowerCase();
  const tag = t.match(/^\[([^\]]+)\]/)?.[1];
  if (tag) return tag === 'trade' ? 'trade_thesis' : tag;
  if (/\$[a-z]{1,6}\b/.test(t) || /^(buy|sell|long|short|enter|exit|trade|position|invest)\b/.test(t)) return 'trade_thesis';
  if (/^(project|initiative|ship|launch)\b/.test(t)) return 'project';
  if (/^(task|todo|do|build|fix|add|update|change|create|make|implement)\b/.test(t)) return 'task';
  if (/^(why|how|what|when|where|who|is|are|does|can)\b/.test(t) || t.endsWith('?')) return 'question';
  if (/^(journal|today|feeling|note|log|diary)\b/.test(t)) return 'journal';
  if (/\bhttps?:\/\//.test(t) || /^(http|www\.)/.test(t)) return 'clip';
  return 'idea';
}

function captureRouteLabel(intent, text) {
  const ticker = String(text || '').match(/\$([A-Z]{1,6})\b/i)?.[1]?.toUpperCase();
  const labels = {
    idea: 'Content idea queue',
    task: 'Work task queue',
    question: 'Capture inbox',
    trade_thesis: ticker ? `Trading signal draft: ${ticker}` : 'Trading capture, ticker needed',
    project: 'Work projects',
    clip: 'Capture inbox as clip',
    journal: 'Trading journal note',
  };
  return labels[intent] || 'Capture inbox';
}

function updateCapturePreview() {
  const input = document.getElementById('capture-input');
  const intentEl = document.getElementById('capture-intent');
  const routeEl = document.getElementById('capture-route');
  if (!input || !intentEl || !routeEl) return;
  const intent = classifyCaptureText(input.value);
  intentEl.textContent = intent.replace('_', ' ');
  routeEl.textContent = captureRouteLabel(intent, input.value);
}

function showCapture(prefill = '') {
  const overlay = document.getElementById('capture-overlay');
  const input = document.getElementById('capture-input');
  if (!overlay || !input) return;
  overlay.classList.add('open');
  overlay.setAttribute('aria-hidden', 'false');
  if (prefill) input.value = prefill;
  updateCapturePreview();
  setTimeout(() => input.focus(), 20);
}

function hideCapture() {
  const overlay = document.getElementById('capture-overlay');
  if (!overlay) return;
  overlay.classList.remove('open');
  overlay.setAttribute('aria-hidden', 'true');
}

async function submitCapture() {
  const input = document.getElementById('capture-input');
  const submit = document.getElementById('capture-submit');
  const routeEl = document.getElementById('capture-route');
  const text = (input?.value || '').trim();
  if (!text) { toast2('Capture text required', 'error'); return; }
  const intent = classifyCaptureText(text);
  if (submit) { submit.disabled = true; submit.textContent = 'Routing...'; }
  try {
    const capture = await apiFetch('/api/capture', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text, intent, source: 'dashboard-cmd-n' }),
    });
    if (routeEl) routeEl.textContent = capture.route?.action ? `${capture.route.action} -> ${capture.route.destination}` : 'Captured';
    if (input) input.value = '';
    hideCapture();
    toast2(`Captured: ${capture.route?.destination || capture.intent || 'inbox'}`, 'success');
    loadNowSurface();
    if (capture.route?.destination === 'tasks') renderTasks();
    if (capture.route?.destination === 'content_ideas' && typeof loadIdeas === 'function') loadIdeas();
    if (capture.route?.destination === 'trading_signals') loadSignals();
  } catch(e) {
    toast2('Capture failed: ' + e.message, 'error');
  } finally {
    if (submit) { submit.disabled = false; submit.textContent = 'Route'; }
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('capture-input');
  const overlay = document.getElementById('capture-overlay');
  if (input) {
    input.addEventListener('input', updateCapturePreview);
    input.addEventListener('keydown', e => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
        e.preventDefault();
        submitCapture();
      }
      if (e.key === 'Escape') hideCapture();
    });
  }
  if (overlay) overlay.addEventListener('click', e => { if (e.target === overlay) hideCapture(); });
});

