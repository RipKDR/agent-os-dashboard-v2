async function dispatchTask() {
  const input = document.getElementById('dispatch-input');
  const task = input.value.trim();
  if (!task || !selectedAgents.length) return;
  
  // Show auto-model selection toast
  showAutoModelToast();
  
  input.disabled = true;
  document.querySelector('.dispatch-btn').disabled = true;
  
  const resultsEl = document.getElementById('dispatch-results');
  const emptyEl = document.getElementById('dispatch-empty');
  if (emptyEl) emptyEl.style.display = 'none';
  
  selectedAgents.forEach(agent => {
    const card = document.createElement('div');
    card.className = 'dr-card';
    card.id = `dr-${agent}`;
    card.innerHTML = `
      <div class="dr-agent">${AGENTS.find(a => a.id === agent)?.name || agent}</div>
      <div class="dr-status">⏳ Running…</div>
      <div class="dr-body" id="dr-body-${agent}"></div>
    `;
    resultsEl.prepend(card);
  });

  for (const agent of selectedAgents) {
    try {
      const res = await fetch('/api/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agent_name: agent, body: task }),
      });
      const data = await res.json();
      const bodyEl = document.getElementById(`dr-body-${agent}`);
      if (data.inbound) {
        bodyEl.textContent = data.inbound.body.slice(0, 2000) + (data.inbound.body.length > 2000 ? '\n\n[...truncated]' : '');
      }
      const card = document.getElementById(`dr-${agent}`);
      if (card) {
        card.querySelector('.dr-status').innerHTML = data.inbound?.error ? '❌ Failed' : '✅ Done';
      }
    } catch (err) {
      const bodyEl = document.getElementById(`dr-body-${agent}`);
      if (bodyEl) bodyEl.textContent = 'Error: ' + err.message;
    }
  }
  
  input.disabled = false;
  document.querySelector('.dispatch-btn').disabled = false;
  input.value = '';
  toast2(`Dispatched to ${selectedAgents.length} agent(s)`, 'success');
}

