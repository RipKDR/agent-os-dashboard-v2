let _dataFp = ''; // render fingerprint: skip DOM rebuild if data unchanged

async function loadAll() {
  if (!sb) { renderTicker(); renderMission(); return; }
  try {
    const { data, error } = await sb
      .from('agent_logs')
      .select('*')
      .order('created_at', { ascending: false })
      .limit(500);

    if (error) throw error;
    const newLogs = data || [];
    if (loadAborted) return;

    // Build fingerprint: first+last id + count + last-agent combo
    const fp = newLogs.length
      ? `${newLogs.length}:${newLogs[0]?.id || ''}:${newLogs[newLogs.length-1]?.id || ''}:${(newLogs[0]?.agent_name||'')}:${(newLogs[0]?.status||'')}`
      : 'empty';
    const dataChanged = fp !== _dataFp;
    _dataFp = fp;

    allLogs = newLogs;

    logsByAgent = {};
    AGENTS.forEach(a => {
      logsByAgent[a.id] = allLogs.filter(l => (l.agent_name || '').toLowerCase() === a.id);
    });
    const done = allLogs.filter(l => l.status === 'completed').length;
    const fail = allLogs.filter(l => l.status === 'failed').length;
    const today = new Date().toDateString();
    globalStats = {
      total: allLogs.length,
      done,
      fail,
      rate: allLogs.length ? Math.round(done / allLogs.length * 100) + '%' : '—',
      todayCount: allLogs.filter(l => new Date(l.created_at).toDateString() === today).length,
    };

    // Only re-render panels if data actually changed
    if (dataChanged) {
      renderSidebar();
      renderSysBar();
      renderCards();
      renderLogs();
      renderTasks();
    }
    renderTicker();
    renderMission();

    document.getElementById('upd-badge').textContent =
      `UPD ${new Date().toLocaleTimeString('en-US', { hour12: false })}`;
  } catch(e) {
    console.error('[loadAll error]', e?.message, e?.stack);
    document.getElementById('upd-badge').textContent = 'ERROR';
  }
}

