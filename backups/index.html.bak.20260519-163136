async function _autoDetectStandup() {
  if (!allLogs.length) return;
  const now = Date.now();
  const window5m = 5 * 60 * 1000;
  const window10m = 10 * 60 * 1000;
  // Only look at logs from the last 10 minutes
  const recent = allLogs.filter(l => (now - new Date(l.created_at).getTime()) < window10m);
  if (recent.length < 2) return;
  // Find pairs of different agents whose log timestamps are within 5 minutes of each other
  const participantIds = new Set();
  for (let i = 0; i < recent.length; i++) {
    for (let j = i+1; j < recent.length; j++) {
      if (recent[i].agent_name === recent[j].agent_name) continue;
      const diff = Math.abs(new Date(recent[i].created_at).getTime() - new Date(recent[j].created_at).getTime());
      if (diff < window5m) {
        participantIds.add(recent[i].agent_name);
        participantIds.add(recent[j].agent_name);
      }
    }
  }
  if (participantIds.size < 2) return;

  // Throttle: don't regenerate if we already did in last 30 min
  const lastGenKey = '_standupLastGenTs';
  const lastGen = window[lastGenKey] || 0;
  if ((now - lastGen) < 30 * 60 * 1000) return;
  window[lastGenKey] = now;

  // Fire auto-standup generation
  try {
    const logs = recent.filter(l => participantIds.has(l.agent_name));
    const result = await fetch('/api/standup/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ logs })
    }).then(r=>r.json());
    if (result && result.summary) {
      const sec = document.getElementById('office-standup');
      const content = document.getElementById('office-standup-content');
      if (sec && content) { sec.style.display = 'block'; content.textContent = result.summary; }
      pushNotif(`📋 Auto-standup: ${[...participantIds].join(', ')}`, 'info');
    }
  } catch {}
}

