/* ─── V2: CLAUDE CODE TERMINAL ──────────────────── */
let termSessionId = null;
let termBuffer = '';

async function startTerminal() {
  const mode = document.getElementById('term-mode')?.value || 'claude';
  const modeName = mode === 'codex' ? 'Codex CLI' : 'Claude Code';
  try {
    const res = await fetch('/api/cli/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: mode, cwd: '/home/admin/.openclaw/workspace' }),
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    termSessionId = data.id;
    
    document.getElementById('term-status').innerHTML = '● <span style="color:var(--green)">running</span>';
    document.getElementById('term-start-btn').style.display = 'none';
    document.getElementById('term-stop-btn').style.display = 'inline-block';
    document.getElementById('term-input').disabled = false;
    document.getElementById('term-send-btn').disabled = false;
    document.getElementById('term-mode').disabled = true;
    
    const output = document.getElementById('term-output');
    output.innerHTML = `<div style="color:var(--amber)">⎇ ${modeName} session started</div>`;
    termBuffer = '';
    
    setTimeout(() => document.getElementById('term-input').focus(), 300);
    toast2('Claude Code session started', 'success');
    
    // Enter key handler
    document.getElementById('term-input').onkeydown = (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendTerminalInput(); }
    };
    
  } catch (err) {
    toast2('Failed: ' + err.message, 'error');
    document.getElementById('term-output').innerHTML += `<div style="color:var(--red)">✕ ${escHtml(err.message)}</div>`;
  }
}

async function sendTerminalInput() {
  const input = document.getElementById('term-input');
  const text = input.value.trim();
  if (!text || !termSessionId) return;
  
  appendTermOutput(`<span style="color:var(--green)">❯</span> ${escHtml(text)}`);
  input.value = '';
  
  try {
    const res = await fetch(`/api/cli/${termSessionId}/input`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ input: text }),
    });
    if (!res.ok) throw new Error('Send failed');
  } catch (err) {
    appendTermOutput(`<span style="color:var(--red)">✕ ${escHtml(err.message)}</span>`);
  }
}

async function stopTerminal() {
  if (!termSessionId) return;
  try {
    await fetch(`/api/cli/${termSessionId}/stop`, { method: 'POST' });
  } catch {}
  termSessionId = null;
  
  document.getElementById('term-status').innerHTML = '● <span style="color:var(--faint)">stopped</span>';
  document.getElementById('term-start-btn').style.display = 'inline-block';
  document.getElementById('term-stop-btn').style.display = 'none';
  document.getElementById('term-input').disabled = true;
  document.getElementById('term-send-btn').disabled = true;
  document.getElementById('term-mode').disabled = false;
  appendTermOutput('<span style="color:var(--red)">⎇ Session terminated</span>');
}

function updateTermMode() {
  const mode = document.getElementById('term-mode').value;
  document.getElementById('term-cwd').textContent = '~/workspace';
  const output = document.getElementById('term-output');
  output.innerHTML = `<div style="color:var(--dim)">⏻ Click <span style="color:var(--amber)">Start</span> to launch ${mode === 'codex' ? 'Codex CLI' : 'Claude Code'} session.</div>`;
  termBuffer = '';
}

function clearTerminal() {
  const output = document.getElementById('term-output');
  output.innerHTML = '<div style="color:var(--dim)">— cleared —</div>';
  termBuffer = '';
}

function appendTermOutput(html) {
  const output = document.getElementById('term-output');
  const div = document.createElement('div');
  div.innerHTML = html;
  output.appendChild(div);
  output.scrollTop = output.scrollHeight;
}

function handleCLIOutput(data) {
  if (!data || !data.id) return;
  
  // Only process if we have a session and it matches
  if (termSessionId && data.id !== termSessionId) return;
  
  const text = data.data || '';
  termBuffer += text;
  
  // Batch into lines for display
  const lines = termBuffer.split('\n');
  if (lines.length > 1) {
    for (let i = 0; i < lines.length - 1; i++) {
      if (lines[i].trim()) {
        appendTermOutput(`<span style="color:var(--dim)">${escHtml(lines[i])}</span>`);
      }
    }
    termBuffer = lines[lines.length - 1];
  }
}

