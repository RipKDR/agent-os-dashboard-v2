    const task   = last?.task_description || 'No recent tasks';

    return `<div class="a-card" onclick="switchTab('chat');setTimeout(()=>selectChatAgent('${a.id}'),40)">
      <div class="ac-name">${a.name}</div>
      <div class="ac-role">${a.role}</div>
