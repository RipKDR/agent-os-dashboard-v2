  logs.forEach(l => {
    if (!byAgent[l.agent_name]) byAgent[l.agent_name] = { tasks:0, cost:0, models:{} };
    byAgent[l.agent_name].tasks++;
    const cost = modelCostFromPricing(l.model_used, pricing);
    byAgent[l.agent_name].cost += cost;
    const model = (l.model_used||'unknown').split('-')[1] || 'unknown';
    byAgent[l.agent_name].models[model] = (byAgent[l.agent_name].models[model]||0) + 1;
  });

  const totalCost = Object.values(byAgent).reduce((a,b) => a+b.cost, 0);
  const daysBack  = (pricing.days||14);
  const daily     = totalCost / daysBack;
  const projected = daily * 30;
  const topAgent  = Object.entries(byAgent).sort((a,b) => b[1].cost-a[1].cost)[0]?.[0] || '—';

  if (kpis) {
    kpis.innerHTML = [
      [`$${totalCost.toFixed(2)}`, `${daysBack}D Total`],
      [`$${daily.toFixed(2)}`, 'Daily Average'],
      [`$${projected.toFixed(2)}`, 'Projected/Month'],
      [escHtml(topAgent), 'Top Spender'],
    ].map(([v,l]) => `<div style="background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:10px"><div style="font-size:8px;color:var(--dim);margin-bottom:4px">${l}</div><div style="font-size:16px;color:var(--amber)">${v}</div></div>`).join('');
  }

  if (sug) {
    fetch('/api/costs/suggestions').then(r=>r.json()).then(sugs => {
      sug.innerHTML = sugs.map(s => `<div style="background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:10px 12px;display:flex;align-items:center;gap:10px"><span style="flex:1;font-size:9px;color:var(--text)">${escHtml(s.rule)}</span><span style="font-size:9px;color:var(--green)">-${s.saving_pct}%</span></div>`).join('');
    }).catch(()=>{});
  }
}

function modelCostFromPricing(modelStr, pricing) {
  const prices = pricing.model_prices || {};
  const avgTok  = pricing.avg_tokens || 2000;
  const m = (modelStr||'').toLowerCase();
  for (const [key, p] of Object.entries(prices)) {
    if (m.includes(key)) return ((p.input + p.output) / 2) * (avgTok / 1000);
  }
  return 0.003 * (avgTok / 1000);
}

