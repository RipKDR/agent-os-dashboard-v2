async function loadGitHubPRs(repo) {
  const el = document.getElementById('gh-content');
  if (!el) return;
  
  const reposToFetch = repo ? [repo] : await getReposToFetch();
  if (!reposToFetch.length) return;
  
  el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--dim)">Loading PRs…</div>';
  let allHtml = '<div style="padding:8px;display:flex;flex-direction:column;gap:6px">';
  
  for (const r of reposToFetch) {
    const data = await ghFetch(`/repos/${r}/pulls?state=open`);
    if (!Array.isArray(data)) continue;
    if (data.length === 0 && !repo) continue;
    
    allHtml += `<div style="font-size:9px;color:var(--dim);padding:4px 6px;text-transform:uppercase;letter-spacing:0.10em">${escHtml(r)}</div>`;
    data.forEach(pr => {
      const checks = pr.mergeable === true ? '✅' : pr.mergeable === false ? '❌' : '◻️';
      allHtml += `
        <div style="padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:4px">
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:11px;color:var(--amber)">#${pr.number}</span>
            <span style="font-size:11px;flex:1">${escHtml(pr.title)}</span>
            <span style="font-size:9px;color:var(--dim)">${checks}</span>
          </div>
          <div style="display:flex;gap:12px;margin-top:4px;font-size:8px;color:var(--faint)">
            <span>${escHtml(pr.head.label.replace('RipKDR:',''))} → ${pr.base.label.replace('RipKDR:','')}</span>
            <span>👤 ${pr.user?.login || '?'}</span>
            <button class="ap-btn" onclick="window.open('${pr.html_url}','_blank')" style="font-size:8px;margin-left:auto">Open ↗</button>
          </div>
        </div>`;
    });
    if (data.length === 0 && !repo) allHtml += '<div style="padding:6px;font-size:10px;color:var(--dim)">No open PRs</div>';
  }
  
  allHtml += '</div>';
  el.innerHTML = allHtml;
}

async function loadGitHubCommits(repo) {
  const el = document.getElementById('gh-content');
  if (!el) return;
  
  const reposToFetch = repo ? [repo] : await getReposToFetch();
  if (!reposToFetch.length) return;
  
  el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--dim)">Loading commits…</div>';
  let allHtml = '<div style="padding:8px;display:flex;flex-direction:column;gap:4px">';
  
  for (const r of reposToFetch) {
    const data = await ghFetch(`/repos/${r}/commits?per_page=10`);
    if (!Array.isArray(data)) continue;
    
    allHtml += `<div style="font-size:9px;color:var(--dim);padding:4px 6px 2px;text-transform:uppercase;letter-spacing:0.10em">${escHtml(r)}</div>`;
    data.forEach(c => {
      const msg = (c.commit?.message || '').split('\n')[0];
      const author = c.commit?.author?.name || c.author?.login || '?';
      const date = c.commit?.author?.date ? new Date(c.commit.author.date).toLocaleString() : '';
      allHtml += `
        <div style="padding:6px 10px;background:var(--surface);border:1px solid var(--border);border-radius:3px;display:flex;align-items:center;gap:8px">
          <span style="font-size:9px;color:var(--amber);font-family:var(--mono)">${c.sha?.slice(0,7) || '?'}</span>
          <span style="font-size:10px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtml(msg)}</span>
          <span style="font-size:8px;color:var(--dim)">${author}</span>
          <span style="font-size:8px;color:var(--faint)">${date}</span>
        </div>`;
    });
  }
  
  allHtml += '</div>';
  el.innerHTML = allHtml;
}

async function getReposToFetch() {
  const data = await ghFetch('/user/repos?per_page=10&sort=updated');
  if (!Array.isArray(data)) return [];
  return data.slice(0, 5).map(r => r.full_name);
}

