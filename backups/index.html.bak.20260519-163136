/* ─── V2: AUTO-MODEL SELECTION ──────────────────── */
function autoSelectModel(agent, taskDesc) {
  const t = taskDesc.toLowerCase();
  // Task type classification
  const isArchitecture = /schema|database|rls|auth|security|deploy|rollback|infra/i.test(t);
  const isDesign = /ux|ui|design|flow|screen|layout|microcopy|a11y|accessibility/i.test(t);
  const isCode = /implement|build|code|function|api|endpoint|test|fix|debug|refactor|migration/i.test(t);
  const isResearch = /research|competitor|market|pricing|analyze|find|compare|review/i.test(t);
  const isQA = /test|qa|release|regression|checklist|verify|audit/i.test(t);
  
  // Complexity
  const isSimple = taskDesc.length < 60 && !isArchitecture;
  const isComplex = isArchitecture || taskDesc.length > 200;
  
  const models = {
    'opencode/claude-opus-4-6': { name: 'Opus 4.6', tier: 'premium', score: 0 },
    'anthropic/claude-sonnet-4-6': { name: 'Sonnet 4.6', tier: 'premium', score: 0 },
    'openai-codex/gpt-5.5': { name: 'GPT-5.5', tier: 'premium', score: 0 },
    'opencode-go/kimi-k2.6': { name: 'Kimi K2.6', tier: 'standard', score: 0 },
  };
  
  // Score each model
  // Opus: best for architecture, complex, security
  if (isArchitecture) models['opencode/claude-opus-4-6'].score += 5;
  if (isComplex) models['opencode/claude-opus-4-6'].score += 3;
  if (agent === 'jordan') models['opencode/claude-opus-4-6'].score += 2;
  
  // Sonnet: best for design, creative
  if (isDesign) models['anthropic/claude-sonnet-4-6'].score += 5;
  if (agent === 'maya') models['anthropic/claude-sonnet-4-6'].score += 2;
  if (isQA) models['anthropic/claude-sonnet-4-6'].score += 2;
  
  // GPT-5.5: best for code, research, general
  if (isCode) models['openai-codex/gpt-5.5'].score += 4;
  if (isResearch) models['openai-codex/gpt-5.5'].score += 4;
  if (agent === 'alex') models['openai-codex/gpt-5.5'].score += 2;
  if (agent === 'dev') models['openai-codex/gpt-5.5'].score += 2;
  
  // Kimi: good for simple, standard tasks
  if (isSimple) models['opencode-go/kimi-k2.6'].score += 3;
  if (!isArchitecture && !isComplex) models['opencode-go/kimi-k2.6'].score += 2;
  
  // Find best
  const sorted = Object.entries(models).sort((a, b) => b[1].score - a[1].score);
  const best = sorted[0];
  
  return {
    model: best[0],
    name: best[1].name,
    score: best[1].score,
    reasoning: best[1].score >= 4 
      ? (isArchitecture ? 'Architectural task — best with Opus' :
         isDesign ? 'Design task — best with Sonnet' :
         isCode ? 'Code task — best with GPT-5.5' :
         isResearch ? 'Research task — best with GPT-5.5' :
         'Standard task — optimal model selected')
      : 'Simple task — efficient model chosen',
  };
}

