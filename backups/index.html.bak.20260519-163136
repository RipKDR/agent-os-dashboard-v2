      const priceStr = p >= 10000 ? (p/1000).toFixed(1)+'k' : p >= 1000 ? p.toFixed(0) : p >= 1 ? p.toFixed(2) : p.toFixed(4);
      const col = pct >= 0 ? 'var(--green)' : 'var(--red)';
      const arrow = pct >= 0 ? '▲' : '▼';
      return `${priceStr} <span style="color:${col}">${arrow}${Math.abs(pct).toFixed(2)}%</span>`;
    };
    set('m-axjo', fmtQ(d.aus?.axjo));
    set('m-aud',  fmtQ(d.aus?.aud));
    set('m-btc',  fmtQ(d.crypto?.btc));
    set('m-eth',  fmtQ(d.crypto?.eth));
    set('m-sol',  fmtQ(d.crypto?.sol));
    set('m-xrp',  fmtQ(d.crypto?.xrp));
  } catch {}
}

/* ─── HL Breadth Chart (HighLowTick style) ──────── */
async function drawHLBreadthChart() {
  const canvas = document.getElementById('hl-breadth-chart');
  if (!canvas) return;
  try {
    const d = await fetch('/api/trading/session-hl-history').then(r => r.json());
    const events = d.events || [];
    if (!events.length) return;

    // Load Chart.js if needed
    await new Promise((resolve, reject) => {
      if (typeof Chart !== 'undefined') return resolve();
      if (window._chartLoading) { const t = setInterval(() => { if (typeof Chart !== 'undefined') { clearInterval(t); resolve(); } }, 100); return; }
      window._chartLoading = true;
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js';
      s.onload = () => { window._chartLoading = false; resolve(); };
      s.onerror = reject;
      document.head.appendChild(s);
    });

    // Bucket into 5-min windows over last 2 hours
    const now = Date.now();
    const bucketMs = 5 * 60 * 1000;
    const numBuckets = 24;
    const windowStart = now - numBuckets * bucketMs;
    const buckets = Array.from({ length: numBuckets }, (_, i) => ({ highs: 0, lows: 0 }));

    events.forEach(ev => {
      const idx = Math.floor((ev.ts - windowStart) / bucketMs);
      if (idx >= 0 && idx < numBuckets) {
        if (ev.type === 'high') buckets[idx].highs++;
        else buckets[idx].lows++;
      }
    });

    // Running net HL line
    let net = 0;
    const netLine = buckets.map(b => { net += b.highs - b.lows; return net; });
    const totalHighs = buckets.reduce((s, b) => s + b.highs, 0);
    const totalLows  = buckets.reduce((s, b) => s + b.lows, 0);
    const finalNet   = totalHighs - totalLows;

    const badge = document.getElementById('hl-net-badge');
    if (badge) {
      badge.textContent = `Net ${finalNet >= 0 ? '+' : ''}${finalNet}`;
      badge.style.color = finalNet > 0 ? 'var(--green)' : finalNet < 0 ? 'var(--red)' : 'var(--dim)';
      badge.style.borderColor = finalNet > 0 ? 'var(--green)' : finalNet < 0 ? 'var(--red)' : 'var(--border)';
    }

    if (canvas._hlChart) canvas._hlChart.destroy();
    canvas._hlChart = new Chart(canvas.getContext('2d'), {
      type: 'bar',
      data: {
        labels: buckets.map((_, i) => {
          const t = new Date(windowStart + i * bucketMs);
          return t.getHours().toString().padStart(2,'0') + ':' + t.getMinutes().toString().padStart(2,'0');
        }),
        datasets: [
          { label: 'Highs', data: buckets.map(b => b.highs),   backgroundColor: 'rgba(76,175,80,0.75)',  borderWidth: 0, stack: 'a' },
          { label: 'Lows',  data: buckets.map(b => -b.lows),   backgroundColor: 'rgba(244,67,54,0.75)',  borderWidth: 0, stack: 'a' },
          { label: 'Net',   data: netLine, type: 'line',
            borderColor: 'rgba(232,160,69,0.9)', borderWidth: 1.5, pointRadius: 0, tension: 0.3,
            fill: false, yAxisID: 'y2' }
        ]
      },
      options: {
        animation: false, responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { enabled: false } },
        scales: {
          x: { display: false },
          y:  { display: false, stacked: true },
          y2: { display: false, position: 'right' }
        }
      }
    });
  } catch {}
}

/* ─── Portfolio Live P&L ─────────────────────── */
async function loadPortfolioPnL() {
  try {
    const positions = await fetch('/api/trading/positions').then(r => r.json());
    if (!Array.isArray(positions) || !positions.length) {
      ['pnl-value','pnl-unrealized','pnl-day'].forEach(id => { const e=document.getElementById(id); if(e) e.textContent='—'; });
      return;
    }
    const tickers = [...new Set(positions.map(p => p.ticker).filter(Boolean))].join(',');
    const quotes = await fetch(`/api/trading/quotes?tickers=${tickers}`).then(r => r.json());
    const qMap = {};
    quotes.forEach(q => { if (!q.error) qMap[q.ticker] = q; });
    let totalValue = 0, totalCost = 0, totalDayChg = 0;
    positions.forEach(p => {
      const q = qMap[p.ticker] || {};
      const cur = parseFloat(q.price || p.current_price || p.entry_price || 0);
      const entry = parseFloat(p.entry_price || 0);
      const size = parseFloat(p.size || 1);
      totalValue += cur * size;
      totalCost  += entry * size;
      totalDayChg += parseFloat(q.change_pct || 0) * entry * size / 100;
    });
    const unreal = totalValue - totalCost;
    const unrealPct = totalCost ? (unreal / totalCost * 100).toFixed(2) : 0;
    const dayPct = totalCost ? (totalDayChg / totalCost * 100).toFixed(2) : 0;
    const fmt$ = v => (v >= 0 ? '+' : '') + '$' + Math.abs(v).toLocaleString(undefined, {maximumFractionDigits:0});
    const col = v => v >= 0 ? 'var(--green)' : 'var(--red)';
    const set = (id, html) => { const e=document.getElementById(id); if(e) e.innerHTML = html; };
    set('pnl-value',      `<span style="color:var(--text)">Value: <b>$${totalValue.toLocaleString(undefined,{maximumFractionDigits:0})}</b></span>`);
    set('pnl-unrealized', `<span style="color:${col(unreal)}">Unrealized: ${fmt$(unreal)} (${unrealPct >= 0 ? '+' : ''}${unrealPct}%)</span>`);
    set('pnl-day',        `<span style="color:${col(totalDayChg)}">Day: ${fmt$(totalDayChg)} (${dayPct >= 0 ? '+' : ''}${dayPct}%)</span>`);
  } catch(e) { console.error('P&L error', e); }
}

