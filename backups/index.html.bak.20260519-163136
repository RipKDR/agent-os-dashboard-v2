let brainSessions = JSON.parse(localStorage.getItem('aos-brain-sessions') || '[]');
let brainCurrentSession = null;

function getBrainDefault() {
  if (!brainSessions.length) {
    brainSessions = [{ id: 's-'+Date.now(), title: 'New Session', created: new Date().toISOString(), ideas: [] }];
    localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
  }
  return brainSessions[0];
}

function loadBrainSessions() {
  brainSessions = JSON.parse(localStorage.getItem('aos-brain-sessions') || '[]');
  if (!brainSessions.length) getBrainDefault();
  
  const sel = document.getElementById('brain-session-select');
  if (sel) {
    sel.innerHTML = brainSessions.map((s, i) => 
      `<option value="${i}">${escHtml(s.title)} (${s.ideas?.length || 0} ideas)</option>`
    ).join('');
  }
  
  if (!brainCurrentSession) {
    brainCurrentSession = brainSessions[0];
    document.getElementById('brain-session-name').value = brainCurrentSession.title;
    sel.value = '0';
  }
  renderBrainIdeas();
}

function newBrainSession() {
  const title = document.getElementById('brain-session-name').value.trim() || 'Session ' + (brainSessions.length + 1);
  brainSessions.unshift({ id: 's-'+Date.now(), title, created: new Date().toISOString(), ideas: [] });
  brainCurrentSession = brainSessions[0];
  localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
  loadBrainSessions();
  document.getElementById('brain-session-select').value = '0';
  toast2('New session created', 'success');
}

function saveBrainSession() {
  const title = document.getElementById('brain-session-name').value.trim();
  if (brainCurrentSession && title) {
    brainCurrentSession.title = title;
    localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
    loadBrainSessions();
    toast2('Session saved', 'success');
  }
}

function loadBrainSession(index) {
  brainCurrentSession = brainSessions[parseInt(index)];
  if (brainCurrentSession) {
    document.getElementById('brain-session-name').value = brainCurrentSession.title;
    renderBrainIdeas();
  }
}

function addBrainIdea() {
  const input = document.getElementById('brain-input');
  const text = input.value.trim();
  if (!text || !brainCurrentSession) return;
  
  if (!brainCurrentSession.ideas) brainCurrentSession.ideas = [];
  brainCurrentSession.ideas.unshift({
    id: 'i-'+Date.now(),
    text,
    created: new Date().toISOString(),
    tags: [],
    status: 'active',
    refined: null,
    taskId: null,
  });
  localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
  input.value = '';
  renderBrainIdeas();
  loadBrainSessions(); // refresh dropdown count
}

function renderBrainIdeas() {
  const el = document.getElementById('brain-ideas');
  if (!el) return;
  
  if (!brainCurrentSession || !brainCurrentSession.ideas?.length) {
    el.innerHTML = `<div class="empty"><div class="empty-t">No ideas yet</div><div class="empty-s">Type your first idea in the box below</div></div>`;
    return;
  }
  
  el.innerHTML = brainCurrentSession.ideas.map(idea => {
    const ago = timeAgo(idea.created);
    const tags = (idea.tags || []).join(' ');
    const statusDot = idea.status === 'active' ? '💡' : idea.status === 'refined' ? '🔄' : idea.status === 'task' ? '📋' : '💡';
    return `<div style="padding:12px 14px;background:var(--surface);border:1px solid var(--border);border-radius:4px;animation:rowIn 200ms ease">
      <div style="display:flex;gap:8px">
        <span>${statusDot}</span>
        <div style="flex:1">
          <div style="font-size:11px;line-height:1.5">${escHtml(idea.text)}</div>
          <div style="display:flex;gap:10px;margin-top:6px;font-size:8px;color:var(--faint)">
            <span>${ago}</span>
            ${tagHtml(idea)}
            <span style="margin-left:auto"></span>
            <span onclick="refineIdea('${idea.id}')" style="cursor:pointer;color:var(--amber)">🔄 Refine</span>
            <span onclick="ideaToTask('${idea.id}')" style="cursor:pointer;color:var(--green)">📋 Task</span>
            <span onclick="deleteIdea('${idea.id}')" style="cursor:pointer;color:var(--red)">✕</span>
          </div>
          ${idea.refined ? `<div style="margin-top:6px;padding:8px 10px;background:var(--bg);border-radius:3px;border-left:2px solid var(--amber);font-size:10px;color:var(--dim)">${escHtml(idea.refined.slice(0,300))}</div>` : ''}
        </div>
      </div>
    </div>`;
  }).join('');
  
  // Focus input
  setTimeout(() => document.getElementById('brain-input')?.focus(), 100);
  
  // Enter key on input
  const inp = document.getElementById('brain-input');
  inp.onkeydown = (e) => { if (e.key === 'Enter') addBrainIdea(); };
}

function tagHtml(idea) {
  const tags = idea.tags || [];
  if (!tags.length) {
    return `<span onclick="addTag('${idea.id}')" style="cursor:pointer;color:var(--dim)">+ tag</span>`;
  }
  return tags.map(t => `<span style="color:var(--amber)">#${escHtml(t)}</span>`).join(' ');
}

function addTag(ideaId) {
  const tag = prompt('Tag:');
  if (!tag) return;
  const idea = brainCurrentSession.ideas.find(i => i.id === ideaId);
  if (idea) {
    if (!idea.tags) idea.tags = [];
    idea.tags.push(tag.toLowerCase().replace(/\s+/g, '-'));
    localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
    renderBrainIdeas();
  }
}

function deleteIdea(ideaId) {
  if (!confirm('Delete this idea?')) return;
  brainCurrentSession.ideas = brainCurrentSession.ideas.filter(i => i.id !== ideaId);
  localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
  renderBrainIdeas();
  loadBrainSessions();
}

async function refineIdea(ideaId) {
  const idea = brainCurrentSession.ideas.find(i => i.id === ideaId);
  if (!idea) return;
  try {
    const res = await fetch('/api/chat/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ agent_name: 'alex', body: `Refine this idea into a feature specification:\n\n${idea.text}` }),
    });
    const data = await res.json();
    if (data.inbound?.body) {
      idea.refined = data.inbound.body;
      idea.status = 'refined';
      localStorage.setItem('aos-brain-sessions', JSON.stringify(brainSessions));
      renderBrainIdeas();
      toast2('Idea refined by Alex', 'success');
    }
  } catch (err) {
    toast2('Refinement failed: ' + err.message, 'error');
  }
}

function ideaToTask(ideaId) {
  const idea = brainCurrentSession.ideas.find(i => i.id === ideaId);
  if (!idea) return;
  switchTab('orch');
  document.getElementById('dispatch-input').value = idea.text;
  toast2('Idea copied to dispatch — pick agents and send', 'info');
}

function timeAgo(iso) {
  const s = Math.floor((Date.now() - new Date(iso)) / 1000);
  if (s < 60) return 'just now';
  if (s < 3600) return Math.floor(s/60) + 'm ago';
  if (s < 86400) return Math.floor(s/3600) + 'h ago';
  return Math.floor(s/86400) + 'd ago';
}

