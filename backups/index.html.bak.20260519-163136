  if (!grid) return;
  grid.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:var(--dim)">Loading…</div>';
  try {
    const res = await fetch(`/api/files/list?path=${encodeURIComponent(dirPath)}`);
    const data = await res.json();
    if (pathDisplay) pathDisplay.textContent = data.path.replace('/home/admin/.openclaw/workspace', '~') + '/';
    if (!data.items || !data.items.length) {
      grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-t">Empty directory</div></div>';
      return;
    }
    let html = '';
    if (dirPath) {
      const parent = dirPath.split('/').slice(0, -1).join('/');
      html += `<div class="fi-item" onclick="loadDir('${parent}')"><span class="fi-icon">📁</span><span class="fi-name">..</span><span class="fi-meta">up</span></div>`;
    }
