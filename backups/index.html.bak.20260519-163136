// SSE system events
(function patchSSEHandler() {
  const origConnect = window.connectSSE;
  if (!origConnect) return;
  window.connectSSE = function() {
    const evtSource = origConnect.apply(this, arguments);
    return evtSource;
  };
  // intercept system-event from the SSE global handler
  const _origHandleSSE = window._handleSSEEvent;
  window._handleSSEEvent = function(type, data) {
    if (type === 'price-alert') {
      pushNotif(`🔔 ${data.message || 'Price alert triggered: ' + data.ticker}`, 'alert');
      toast2(data.message || `Price alert: ${data.ticker}`, 'info');
    } else if (type === 'brief-ready' || type === 'daily-brief-ready') {
      loadMorningBrief();
      loadNowSurface(); // refresh Now surface cockpit
    } else if (type === 'signal-approved') {
      pushNotif(`Signal approved: ${data.signal?.ticker}`, 'success');
    } else if (type === 'factory-build-done') {
      pushNotif('Factory build completed', 'success');
      if (_tabLoadFlags['factory']) loadFactory();
    }
    if (_origHandleSSE) _origHandleSSE(type, data);
  };
})();

