  html += '</g>';
  svg.innerHTML = html;
}

/* ─── V2: FILE WRITE ─────────────────────────────── */
let currentFilePath = '';

function mdToHtml(text) {
  return text
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/^### (.+)$/gm, '<div style="color:var(--amber);font-size:12px;font-weight:600;margin:12px 0 4px">$1</div>')
    .replace(/^## (.+)$/gm, '<div style="color:var(--amber);font-size:14px;font-weight:700;margin:16px 0 6px;border-bottom:1px solid var(--border);padding-bottom:4px">$1</div>')
    .replace(/^# (.+)$/gm, '<div style="color:var(--amber);font-size:18px;font-weight:700;margin:20px 0 8px;border-bottom:2px solid var(--amber);padding-bottom:6px">$1</div>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/`([^`]+)`/g, '<code style="background:var(--surface);padding:1px 5px;border-radius:2px;font-size:10px">$1</code>')
    .replace(/^- (.+)$/gm, '<div style="padding:1px 0 1px 12px;color:var(--text)">• $1</div>')
    .replace(/^\d+\. (.+)$/gm, '<div style="padding:1px 0 1px 12px;color:var(--text)"></div>')
    .replace(/\n\n/g, '</p><p style="margin:6px 0;line-height:1.7">')
    .replace(/^\|(.+)\|$/gm, '<div style="font-size:10px;color:var(--dim);font-family:var(--mono)">$1</div>');
}

async function openFile(fileName) {
  const curPath = (document.getElementById('files-path')?.textContent || '').replace('~', '');
  currentFilePath = curPath + fileName;
  
  try {
    const res = await fetch(`/api/files/read?path=${encodeURIComponent(currentFilePath)}&limit=500`);
    const data = await res.json();
    
    document.getElementById('fp-title').textContent = fileName;
    const content = document.getElementById('fp-content');
    const raw = data.lines.slice(0, 500).join('\n');
    
    // Render .md files with formatting, others as plain text
    if (fileName.endsWith('.md')) {
      let html = mdToHtml(raw);
      // Resolve [[wikilinks]] → clickable spans
      html = html.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, alias) => {
        return `<span class="wikilink" onclick="openWikilink('${escHtml(target.replace(/'/g,"\\\'"))}')" style="color:var(--amber);cursor:pointer;text-decoration:underline dotted">${escHtml(alias || target)}</span>`;
      });
      content.innerHTML = html;
      content.style.whiteSpace = 'normal';
    } else {
      content.textContent = raw;
      content.style.whiteSpace = 'pre-wrap';
    }

    // Show frontmatter tags + wikilinks metadata bar
    _renderFileMetaBar(data);

    if (data.truncated) content.innerHTML += '<div style="color:var(--dim);padding:8px;border-top:1px solid var(--border);margin-top:8px">... file truncated (first 500 lines)</div>';
    document.getElementById('fp-path-display').textContent = currentFilePath;
    
    // Show save button only for .md files
    const saveBtn = document.getElementById('fp-save');
    const preview = document.getElementById('file-preview');
    if (fileName.endsWith('.md')) {
      saveBtn.style.display = 'inline-block';
      content.contentEditable = true;
      content.style.outline = '1px dashed var(--amber)';
      content.style.cursor = 'text';
    } else {
      saveBtn.style.display = 'none';
      content.contentEditable = false;
      content.style.outline = 'none';
    }
    
    preview.classList.add('open');
  } catch (err) {
    toast2('Failed to read file: ' + err.message, 'error');
  }
}

function closeFilePreview() {
  document.getElementById('file-preview').classList.remove('open');
  document.getElementById('fp-content').contentEditable = false;
  document.getElementById('fp-content').style.outline = 'none';
  document.getElementById('fp-save').style.display = 'none';
}

async function saveFileFromPreview() {
  if (!currentFilePath) return;
  const content = document.getElementById('fp-content').textContent;
  if (!content.trim()) return;
  
  try {
    const res = await fetch('/api/files/write', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: currentFilePath, content }),
    });
    const data = await res.json();
    if (data.ok) {
      toast2('File saved', 'success');
      document.getElementById('fp-save').style.display = 'none';
    } else {
      toast2('Save failed: ' + (data.error || 'unknown'), 'error');
    }
  } catch (err) {
    toast2('Save failed: ' + err.message, 'error');
  }
}

/* ─── OBSIDIAN / TAGS SIDEBAR ────────────────────── */
let _activeTagFilter = null;

function _renderFileMetaBar(data) {
  // Remove any previous meta bar
  const existing = document.getElementById('fp-meta-bar');
  if (existing) existing.remove();
  if (!data || (!data.tags?.length && !data.wikilinks?.length)) return;
  const bar = document.createElement('div');
  bar.id = 'fp-meta-bar';
  bar.style.cssText = 'padding:6px 14px;border-bottom:1px solid var(--border);display:flex;flex-wrap:wrap;gap:6px;background:var(--raised);font-size:9px;flex-shrink:0';
  if (data.tags?.length) {
    bar.innerHTML += data.tags.map(t =>
      `<span onclick="filterByTag('${escHtml(t.replace(/'/g,"\\'"))}')" style="cursor:pointer;padding:2px 7px;border-radius:999px;background:var(--a-soft);color:var(--amber);border:1px solid var(--amber)">#${escHtml(t)}</span>`
    ).join('');
  }
  if (data.wikilinks?.length) {
    bar.innerHTML += '<span style="color:var(--dim);padding:2px 0">Links:</span>' +
      data.wikilinks.slice(0,8).map(l =>
        `<span onclick="openWikilink('${escHtml(l.replace(/'/g,"\\'"))}')" style="cursor:pointer;padding:2px 7px;border-radius:999px;background:var(--surface);color:var(--text);border:1px solid var(--border2)">[[${escHtml(l)}]]</span>`
      ).join('');
  }
  const fpContent = document.getElementById('fp-content');
  if (fpContent && fpContent.parentNode) fpContent.parentNode.insertBefore(bar, fpContent);
}

async function openWikilink(noteName) {
  // Try to find a .md file whose basename matches noteName (case-insensitive)
  try {
    const { tree } = await fetch('/api/files/tree').then(r => r.json());
    const allFiles = [];
    function flatten(node) { if (!node) return; if (node.type === 'file') allFiles.push(node.path); if (node.children) node.children.forEach(flatten); }
    if (Array.isArray(tree)) tree.forEach(flatten);
    else flatten(tree);
    const target = allFiles.find(f => {
      const base = f.split('/').pop().replace(/\.md$/i, '');
      return base.toLowerCase() === noteName.toLowerCase();
    });
    if (target) {
      const rel = target.replace(/^.*workspace\//, '');
      currentFilePath = rel;
      const fname = rel.split('/').pop();
      await openFile(fname);
    } else {
      toast2(`Note not found: ${noteName}`, 'error');
    }
  } catch(e) { toast2('Wikilink error: ' + e.message, 'error'); }
}

