    // openclaw gateway — try non-blocking; skip if binary not found
    await new Promise(resolve => {
      execFile(OPENCLAW_BIN, ['gateway', 'status', '--json'], { timeout: 4000 }, (err, stdout) => {
        try {
          if (!err && stdout) {
            const data = JSON.parse(stdout.trim());
            const containers = Array.isArray(data) ? data : (data.services || data.containers || []);
            containers.forEach(c => services.push({ name: c.name || c.service || 'container', status: (c.status || c.state || '').toLowerCase().includes('running') ? 'running' : 'stopped', detail: c.status || c.state || '' }));
