// ─── Direct LLM (OpenRouter, fast path) ──────────────────────
function callLLM(systemPrompt, userPrompt, model = 'anthropic/claude-haiku-4-5') {
  return new Promise((resolve, reject) => {
    if (!OPENROUTER_API_KEY) return reject(new Error('OPENROUTER_API_KEY not set'));
    const body = JSON.stringify({
      model,
      messages: [
        { role: 'system', content: systemPrompt },
        { role: 'user',   content: userPrompt },
      ],
      max_tokens: 600,
    });
    const req = https.request({
      hostname: 'openrouter.ai',
      path: '/api/v1/chat/completions',
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${OPENROUTER_API_KEY}`,
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
        'HTTP-Referer': 'https://atlas.local',
        'X-Title': 'Atlas Why Engine',
      },
    }, res => {
      let raw = '';
      res.on('data', c => raw += c);
      res.on('end', () => {
        try {
          const d = JSON.parse(raw);
          if (d.error) return reject(new Error(d.error.message || JSON.stringify(d.error)));
          resolve(d.choices?.[0]?.message?.content || '');
        } catch(e) { reject(e); }
      });
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

// ─── Intent Classifier (rules-based v1) ──────────────────────
function classifyIntent(text) {
  const t = (text || '').toLowerCase().trim();
  if (/^\[(idea|task|question|trade|project|clip|journal)\]/.test(t)) {
    const tag = t.match(/^\[([^\]]+)\]/)?.[1];
    return tag === 'trade' ? 'trade_thesis' : tag;
  }
  if (/\$[a-z]{1,6}\b/.test(t) || /^(buy|sell|long|short|enter|exit|trade|position|invest)\b/.test(t)) return 'trade_thesis';
  if (/^(project|initiative|ship|launch)\b/.test(t)) return 'project';
  if (/^(idea|thought|concept|what if|maybe|could we|imagine)\b/.test(t)) return 'idea';
  if (/^(task|todo|do|build|fix|add|update|change|create|make|implement)\b/.test(t)) return 'task';
  if (/^(why|how|what|when|where|who|is|are|does|can)\b/.test(t) || t.endsWith('?')) return 'question';
  if (/^(journal|today|feeling|note|log|diary)\b/.test(t)) return 'journal';
  if (/\bhttps?:\/\//.test(t) || /^(http|www\.)/.test(t)) return 'clip';
  return 'idea';
}

function cleanCaptureText(text) {
  return String(text || '').replace(/^\s*\[[^\]]+\]\s*/, '').trim();
}

function extractTicker(text) {
  const raw = String(text || '');
  const cashtag = raw.match(/\$([A-Z]{1,6})(?:\b|\s|$)/i);
  if (cashtag) return cashtag[1].toUpperCase();
  const direct = raw.match(/\b([A-Z]{2,6})\b/);
  return direct ? direct[1].toUpperCase() : '';
}

function inferTradeDirection(text) {
  const t = String(text || '').toLowerCase();
  if (/\b(short|sell|bear|bearish|puts?)\b/.test(t)) return 'short';
  if (/\b(long|buy|bull|bullish|calls?|enter|invest)\b/.test(t)) return 'long';
  return 'watch';
}

function routeCapture(capture, text, intent) {
  const cleaned = cleanCaptureText(text);
  const title = cleaned.slice(0, 96) || 'Untitled capture';
  const base = { capture_id: capture.id, intent, routed_at: new Date().toISOString() };

  if (intent === 'task') {
    const task = stores.tasks.append({
      title,
      description: cleaned,
      status: 'todo',
      source: 'capture',
      capture_id: capture.id,
    });
    return { ...base, destination: 'tasks', action: 'created_task', id: task.id, label: task.title };
  }

  if (intent === 'project') {
    const project = stores.projects.append({
      name: title,
      description: cleaned,
      status: 'active',
      source: 'capture',
      capture_id: capture.id,
    });
    return { ...base, destination: 'projects', action: 'created_project', id: project.id, label: project.name };
  }

  if (intent === 'idea') {
    const idea = stores.contentIdeas.append({
      title,
      summary: cleaned,
      source: 'capture',
      status: 'idea',
      capture_id: capture.id,
    });
    return { ...base, destination: 'content_ideas', action: 'created_idea', id: idea.id, label: idea.title };
  }

  if (intent === 'trade_thesis') {
    const ticker = extractTicker(text);
    const direction = inferTradeDirection(text);
    if (ticker) {
      const signal = stores.signals.append({
        ticker,
        direction,
        thesis: cleaned,
        rationale: cleaned,
        confidence: 2,
        source: 'capture',
        capture_id: capture.id,
        status: 'watching',
        ts: new Date().toISOString(),
      });
      return { ...base, destination: 'trading_signals', action: 'created_signal', id: signal.id, label: ticker };
    }
    return { ...base, destination: 'captures', action: 'needs_ticker', label: 'Ticker needed before signal creation' };
  }

  if (intent === 'journal') {
    const entry = stores.journal.append({
      ticker: extractTicker(text) || null,
      direction: 'note',
      thesis: cleaned,
      lessons: '',
      source: 'capture',
      capture_id: capture.id,
      ts: new Date().toISOString(),
    });
    return { ...base, destination: 'trade_journal', action: 'created_journal_note', id: entry.id, label: title };
  }

  if (intent === 'clip') {
    return { ...base, destination: 'capture_inbox', action: 'saved_clip', label: title };
  }

  return { ...base, destination: 'capture_inbox', action: 'saved_question', label: title };
}
