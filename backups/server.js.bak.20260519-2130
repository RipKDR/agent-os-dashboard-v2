      const pastResearch = stores.guideResearch.all().slice(-5);
      const memorySummary = pastResearch.length > 0
        ? `User previously asked: ${pastResearch.map(r => r.question).join(' | ')}`
        : 'First deep research question from this user.';

      // Meta Layer 1: Agent designs its own research plan (aware of history)
      const metaPlanPrompt = `Design a 7-step research plan for a complete beginner with low income.\n` +
                             `Memory: ${memorySummary}\nQuestion: "${question}"\nContext: ${JSON.stringify(liveContext)}\n` +
                             `Output only the numbered plan.`;
      const metaPlan = await runAgent('alex', metaPlanPrompt);

      // Meta Layer 2: First draft
      let draft1 = await runAgent('alex', `Follow this plan:\n${metaPlan}\n\nQuestion: ${question}`);

      // Meta Layer 3: Self-critique
      const critique1 = await runAgent('alex', `Critique this draft for a total beginner:\n${draft1}\nReturn problems + improved version.`);

      // Meta Layer 4: Revised draft
      let draft2 = await runAgent('alex', `Apply improvements:\n${critique1}`);

      // Meta Layer 5: Safety & clarity final check
      const finalMeta = await runAgent('alex', `Final safety check for a poor beginner. Fix and output final answer:\n${draft2}`);

      // Meta Layer 6: Generate personalized learning path + suggested follow-up questions
      const learningPrompt = `Based on "${question}" and past questions, create:\n` +
                             `1. "Next topics you should learn" (3 items)\n` +
                             `2. Two good follow-up questions the user should ask\n` +
                             `Keep it encouraging and realistic.`;
      const learningPath = await runAgent('alex', learningPrompt);

      answer = `${finalMeta || draft2 || draft1}\n\n---\n**Your personal learning path & next questions:**\n${learningPath}`;

