// ─── Agent Config ─────────────────────────────────────────────
function getAgentConfig() {
  const agentsFile = path.join(DATA_DIR, 'agents.json');
  if (fs.existsSync(agentsFile)) {
    try { return JSON.parse(fs.readFileSync(agentsFile, 'utf8')); } catch {}
  }
  // Parse AGENTS.md for agent info
  try {
    const md = fs.readFileSync(path.join(WORKSPACE_ROOT, 'AGENTS.md'), 'utf8');
    const agents = [];
    const tableRegex = /\|\s*([^|]+)\s*\|\s*([^|]+)\s*\|\s*([^|]+)\s*\|\s*([^|]+)\s*\|/g;
    let m;
    while ((m = tableRegex.exec(md)) !== null) {
      const [, name, id, , domain] = m.map(s => s.trim());
      if (name && id && !name.startsWith('-') && name !== 'Agent') {
        agents.push({ id: id.replace(/`/g,'').toLowerCase(), name: name.replace(/[^\w\s]/g,'').trim(), role: domain.replace(/[^\w\s,/]/g,'').trim() });
      }
    }
    if (agents.length) return agents;
  } catch {}
  // Parse openclaw.json
  try {
    const cfg = JSON.parse(fs.readFileSync(path.join(WORKSPACE_ROOT, '..', 'openclaw.json'), 'utf8'));
    const agentCfg = cfg.agents || {};
    return Object.entries(agentCfg).map(([id, a]) => ({ id, name: a.name || id, role: a.role || a.description || 'Agent', model: a.model || '' }));
  } catch {}
  return [
    { id:'alex',   name:'Alex',   role:'Product Research' },
    { id:'maya',   name:'Maya',   role:'UX / UI' },
    { id:'jordan', name:'Jordan', role:'Architecture' },
    { id:'dev',    name:'Dev',    role:'Implementation' },
    { id:'sam',    name:'Sam',    role:'QA / Release' },
  ];
}

// ─── Cron Jobs ────────────────────────────────────────────────
function getCronJobs() {
  const jobs = [];
  // Try openclaw.json
  try {
    const cfg = JSON.parse(fs.readFileSync(path.join(WORKSPACE_ROOT, '..', 'openclaw.json'), 'utf8'));
    const sched = cfg.schedule || cfg.cron || cfg.heartbeat || {};
    Object.entries(sched).forEach(([name, val]) => {
      const entry = typeof val === 'object' ? val : { schedule: val };
      jobs.push({ agent: entry.agent || 'main', job_name: name, schedule_human: entry.schedule || entry.cron || String(val), next_run: null, last_run: null, status: 'scheduled' });
    });
  } catch {}
  // Walk workspace for *.heartbeat.json
  try {
    const { files } = walkDir(WORKSPACE_ROOT, { maxDepth: 3, fileTest: e => e.name.endsWith('.heartbeat.json') });
    files.forEach(f => {
      try {
        const hb = JSON.parse(fs.readFileSync(f, 'utf8'));
        jobs.push({ agent: hb.agent || path.basename(f, '.heartbeat.json'), job_name: hb.job || hb.name || path.basename(f), schedule_human: hb.schedule || hb.cron || '—', next_run: hb.next_run || null, last_run: hb.last_run || null, status: hb.status || 'scheduled' });
      } catch {}
    });
  } catch {}
  return jobs;
}

