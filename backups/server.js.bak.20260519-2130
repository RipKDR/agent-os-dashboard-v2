  // ── Why Engine ──────────────────────────────────────────────
  if (method === 'GET' && pathname.startsWith('/api/trading/why/')) {
    const ticker = decodeURIComponent(pathname.split('/').pop()).toUpperCase();
    try {
      const since24h = new Date(Date.now() - 24 * 3600 * 1000).toISOString();
      const avKey = AV_API_KEY || readJsonFile(TR_SETTINGS_FILE).alpha_vantage_key || '';
      const [newsRes, quoteRes, macroRes, avNewsRes] = await Promise.allSettled([
        alpaca ? alpaca.getNews([ticker], 15, since24h) : Promise.resolve({ news: [] }),
        alpaca ? alpaca.getSnapshot(ticker)             : Promise.resolve(null),
        Promise.allSettled([yahooQuote('SPY'), yahooQuote('^VIX')]),
        avKey
          ? withCache(`avnews:${ticker}`, 600000, () =>
              fetchUrl(`https://www.alphavantage.co/query?function=NEWS_SENTIMENT&tickers=${ticker}&apikey=${avKey}&limit=20`))
          : Promise.resolve(null),
      ]);

      // Merge Alpaca + AV news, deduplicated by URL
      const alpacaNews = (newsRes.value?.news || []).slice(0, 10);
      const avFeed = (avNewsRes.value?.feed || []).slice(0, 10);
      const seenUrls = new Set(alpacaNews.map(n => n.url));
      const mergedNews = [
        ...alpacaNews.map(n => ({ headline: n.headline, source: n.source, url: n.url, sentiment: null })),
        ...avFeed.filter(n => !seenUrls.has(n.url)).map(n => ({
          headline: n.title, source: n.source, url: n.url,
          sentiment: n.overall_sentiment_label,
          sentiment_score: n.overall_sentiment_score,
        })),
      ].slice(0, 15);

      // AV aggregate sentiment for this ticker
      const tickerSentiments = avFeed.flatMap(n => n.ticker_sentiment || []).filter(ts => ts.ticker === ticker);
      const avgSentScore = tickerSentiments.length
        ? (tickerSentiments.reduce((s, ts) => s + parseFloat(ts.ticker_sentiment_score || 0), 0) / tickerSentiments.length).toFixed(3)
        : null;
      const sentLabel = avgSentScore !== null
        ? (avgSentScore > 0.15 ? 'Bullish' : avgSentScore < -0.15 ? 'Bearish' : 'Neutral')
        : null;

      const articles = mergedNews.map(n =>
        `• ${n.headline} (${n.source})${n.sentiment ? ` [${n.sentiment}]` : ''}`
      ).join('\n');

      const snap = quoteRes.value;
      const price     = snap?.latestTrade?.p || snap?.latestQuote?.bp || 'N/A';
      const prevClose = snap?.prevDailyBar?.c || 'N/A';
      const pctChange = (prevClose && prevClose !== 'N/A' && price !== 'N/A')
        ? (((price - prevClose) / prevClose) * 100).toFixed(2) + '%'
        : 'N/A';
      const spyVal  = macroRes.value?.[0]?.value?.price;
      const vixVal  = macroRes.value?.[1]?.value?.price;
      const macroCtx = `SPY: ${spyVal ? '$' + spyVal.toFixed(2) : 'N/A'}, VIX: ${vixVal ? vixVal.toFixed(1) : 'N/A'}`;
      const sentCtx  = sentLabel ? `AV Sentiment: ${sentLabel} (score ${avgSentScore})` : '';

      // Stocktwits social sentiment
      const socialSnap = stores.socialSentiment.all().filter(e => e.ticker === ticker).slice(-1)[0];
      const socialCtx = socialSnap ? `Stocktwits: ${Math.round(socialSnap.bull_pct * 100)}% bull / ${Math.round(socialSnap.bear_pct * 100)}% bear (${socialSnap.total} msgs)` : '';

      // EDGAR recent filings (last 30 days) for Why context
      const since30 = new Date(Date.now() - 30 * 86400000).toISOString();
      const recentFilings = stores.edgarFilings.all().filter(e => e.ticker === ticker && (e.filed_at || '') >= since30).slice(-3);
      const filingCtx = recentFilings.length ? `SEC Filings: ${recentFilings.map(f => `${f.type} ${String(f.filed_at).slice(0,10)} ${f.title}`).join(' | ')}` : '';

      const sources = mergedNews.slice(0, 8).map(n => ({
        headline: n.headline, url: n.url, source: n.source,
        sentiment: n.sentiment || null, published_at: n.created_at,
      }));

      let explanation;
      if (OPENROUTER_API_KEY) {
        try {
          const systemP = `You are a senior macro analyst. Write a concise causal explanation (3-5 sentences, max 140 words) for the price move. Cite headlines and sentiment data directly. End with one key risk. Plain text, no markdown headers.`;
          const userP   = `Ticker: ${ticker}\nPrice: $${price} (${pctChange} today)\nMacro: ${macroCtx}\n${sentCtx ? sentCtx + '\n' : ''}${socialCtx ? socialCtx + '\n' : ''}${filingCtx ? filingCtx + '\n' : ''}\nNews last 24h:\n${articles || 'No news found.'}\n\nExplain the move and its causes.`;
          explanation = await callLLM(systemP, userP);
        } catch { explanation = null; }
      }
      if (!explanation) {
        const dir = pctChange !== 'N/A' ? (parseFloat(pctChange) >= 0 ? '▲' : '▼') : '─';
        explanation = [
          `${ticker} ${dir} ${pctChange} | $${price} | ${macroCtx}${sentCtx ? ' | ' + sentCtx : ''}`,
          mergedNews.length ? 'Top stories (last 24h):' : 'No news found in last 24h.',
          ...sources.slice(0, 5).map(s => `• ${s.headline}`),
        ].join('\n');
      }

      const note = stores.whyNotes.append({ ticker, price, pct_change: pctChange, explanation, sources, sentiment_score: avgSentScore, sentiment_label: sentLabel, ts: new Date().toISOString() });

      const date = new Date().toISOString().slice(0, 10);
      const vaultDir = path.join(VAULT_ROOT, 'trading', 'whys');
