        `---\nticker: ${ticker}\ndate: ${date}\ngenerated: true\nsentiment: ${sentLabel || 'N/A'}\nscore: ${avgSentScore || 'N/A'}\ntags: [why, ${ticker.toLowerCase()}]\n---`,
