                 `The data you see (new highs, volume spikes, etc.) is information, not a prediction or recommendation.`;
      }
      else if (q.includes('high') || q.includes('low')) {
        answer = `New highs and lows show which stocks are moving strongly today.\n` +
                 `A “new high” means the price is higher than it has been all session (or year for 52-week high).\n` +
                 `This is just data. It does not mean the stock will keep going up.`;
      }
      else if (q.includes('volume')) {
        answer = `Volume = how many shares are traded. A volume spike means much more activity than normal.\n` +
                 `It can show strong interest or panic. It is not a signal to buy or sell by itself.`;
      }
      else if (q.includes('watchlist')) {
        answer = `Your watchlist currently has: ${wlTickers.length ? wlTickers.join(', ') : 'no tickers yet'}.\n` +
                 `Add companies you understand and watch them daily. This helps you learn how prices move.`;
      }
      else if (q.includes('predict') || q.includes('future') || q.includes('will go up')) {
        answer = `No one can reliably predict the future price of any stock.\n` +
                 `The dashboard shows what is happening right now, not what will happen tomorrow.\n` +
                 `Any “prediction” you see is just an observation of current data, never a guarantee.`;
      }
      else {
        answer = `Thanks for your question. The best way to learn is to watch the live numbers every day and read simple explanations.\n` +
                 `Try asking about “volume”, “new highs”, or “safe first steps”.`;
      }

      try {
      // === DEEP META RESEARCH ENGINE v3 (self-referential + learning path + follow-ups) ===
      const liveContext = {
        regime: regime || 'Normal',
        recentHighs: (newHighs || []).slice(0, 5),
        volumeSpikes: (volumeSpikes || []).slice(0, 5),
        watchlist: wlTickers.slice(0, 10),
