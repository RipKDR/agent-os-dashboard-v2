      })();

      const watchlist = stores.watchlist.all().slice(0, 10);
      const wlTickers = watchlist.map(w => w.ticker || w.symbol).filter(Boolean);

      let answer = '';

      if (q.includes('safe') || q.includes('invest') || q.includes('worth') || q.includes('buy') || q.includes('money')) {
        answer = `This is very important: There is no “safe” investment that guarantees money. Every investment carries risk of loss.\n\n` +
                 `Right now the dashboard shows real market movement (highs, lows, volume). Use it only to learn.\n` +
                 `Recommended first steps:\n` +
