  // ── Vault API ────────────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/vault/browse') {
    const dirParam = url.searchParams.get('dir') || '';
    const target = path.resolve(VAULT_ROOT, dirParam);
    if (!target.startsWith(VAULT_ROOT)) return sendJson(res, 403, { error: 'forbidden' });
    function buildTree(dir, rel = '') {
      const entries = [];
      try {
        for (const name of fs.readdirSync(dir).sort()) {
          if (name.startsWith('.')) continue;
          const full = path.join(dir, name);
          const relPath = rel ? `${rel}/${name}` : name;
          const stat = fs.statSync(full);
          if (stat.isDirectory()) {
            entries.push({ name, path: relPath, type: 'dir', children: buildTree(full, relPath) });
          } else if (name.endsWith('.md')) {
            entries.push({ name, path: relPath, type: 'file', size: stat.size, mtime: stat.mtimeMs });
          }
        }
      } catch {}
      return entries;
    }
    return sendJson(res, 200, buildTree(target));
  }

  if (method === 'GET' && pathname === '/api/vault/file') {
    const relPath = url.searchParams.get('path') || '';
    if (!relPath) return sendJson(res, 400, { error: 'path required' });
    const target = path.resolve(VAULT_ROOT, relPath);
    if (!target.startsWith(VAULT_ROOT)) return sendJson(res, 403, { error: 'forbidden' });
    try {
      const content = fs.readFileSync(target, 'utf8');
      const backlinks = [...content.matchAll(/\[\[([^\]]+)\]\]/g)].map(m => m[1]);
      return sendJson(res, 200, { path: relPath, content, backlinks: [...new Set(backlinks)] });
    } catch(e) { return sendJson(res, 404, { error: 'not found' }); }
  }

  if (method === 'GET' && pathname === '/api/vault/search') {
    const q = (url.searchParams.get('q') || '').trim();
    if (!q) return sendJson(res, 400, { error: 'q required' });
    const safeTerm = q.replace(/[^a-zA-Z0-9 _\-\.]/g, '').slice(0, 80);
    if (!safeTerm) return sendJson(res, 400, { error: 'invalid query' });
    try {
      const results = await new Promise((resolve, reject) => {
        execFile('grep', ['-ril', '--include=*.md', safeTerm, VAULT_ROOT], { timeout: 5000 }, (err, stdout) => {
          if (err && err.code !== 1) return reject(err);
          const files = (stdout || '').trim().split('\n').filter(Boolean).map(f => ({
            path: path.relative(VAULT_ROOT, f),
            name: path.basename(f),
          }));
          resolve(files);
