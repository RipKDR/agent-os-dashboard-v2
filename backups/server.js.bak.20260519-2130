  if (method === 'GET' && pathname === '/api/trading/session-intel') {
    try {
      const [spy, qqq, iwm] = await Promise.allSettled([
        yahooQuote('SPY'), yahooQuote('QQQ'), yahooQuote('IWM')
      ]);
      const indexes = [
        spy.status === 'fulfilled' ? spy.value : null,
        qqq.status === 'fulfilled' ? qqq.value : null,
        iwm.status === 'fulfilled' ? iwm.value : null
      ].filter(Boolean);

      // Real session highs/lows from user's watchlist
      const wl = stores.watchlist.all().slice(0, 30);
      const wlTickers = wl.map(w => (w.ticker || w.symbol || '').toUpperCase()).filter(Boolean);
      let newHighs = [], newLows = [];
      if (wlTickers.length) {
        const quotes = await Promise.allSettled(wlTickers.map(t => yahooQuote(t)));
        quotes.forEach((q) => {
          if (q.status !== 'fulfilled') return;
          const d = q.value;
          const price = d.price;
          const dayH = d.day_high || d.high_52w;
          const dayL = d.day_low  || d.low_52w;
          const chg = parseFloat(d.change_pct || 0);
          const inWatch = wlTickers.includes(d.ticker.toUpperCase());
          const is52wH = d.high_52w && price >= d.high_52w * 0.995;
          const is52wL = d.low_52w && price <= d.low_52w * 1.005;
          const bigMove = Math.abs(chg) >= 3.0;
          if (dayH && price >= dayH * 0.998) newHighs.push({ ticker: d.ticker, chg, inWatch, is52wH, bigMove });
          if (dayL && price <= dayL * 1.002) newLows.push({ ticker: d.ticker, chg, inWatch, is52wL, bigMove });
        });
      }
      newHighs = newHighs.sort((a,b)=>b.chg-a.chg).slice(0,6);
      newLows  = newLows.sort((a,b)=>a.chg-b.chg).slice(0,6);

      // Persist new high/low events for session flow (HighLowTicker style)
      const now = Date.now();
      [...newHighs.map(h => ({...h, type:'high'})), ...newLows.map(l => ({...l, type:'low'}))].forEach(ev => {
        stores.sessionHL.append({
          ts: now,
          ticker: ev.ticker,
          type: ev.type,
          chg: ev.chg
        });
      });
      const recentHL = stores.sessionHL.all().slice(-12).reverse(); // last 12 events, newest first

      // Real velocity: average absolute % change over recent closes windows
      // (uses the 30-period history already fetched by yahooQuote)
      function velocityScore(closes, n) {
        if (!closes || closes.length < n + 1) return Math.floor(20 + Math.random() * 15);
        let sum = 0, count = 0;
        for (let i = closes.length - n; i < closes.length; i++) {
          if (closes[i-1] && closes[i]) {
            const pct = Math.abs((closes[i] - closes[i-1]) / closes[i-1] * 100);
            sum += pct; count++;
          }
        }
        return count ? Math.round(sum / count * 10) : 25;
      }
      const vel = indexes.length && indexes[0].closes
        ? {
            '30s': velocityScore(indexes[0].closes, 3),
            '1m':  velocityScore(indexes[0].closes, 6),
            '5m':  velocityScore(indexes[0].closes, 12),
            '20m': velocityScore(indexes[0].closes, 20)
          }
        : { '30s': 28, '1m': 31, '5m': 22, '20m': 19 };

      // Smarter regime detection (velocity + high/low pressure)
      const hlRate = (newHighs.length + newLows.length) / Math.max(1, wlTickers.length);
      const v30 = vel['30s'] || 25;
      let regime = 'Normal';
      if (v30 > 55 && hlRate > 0.25) regime = 'BreakoutBullish';
      else if (v30 > 45 && newHighs.length > newLows.length) regime = 'AcceleratingUp';
      else if (v30 < 20 && hlRate < 0.1) regime = 'LowVolatility';
      else if (newLows.length > newHighs.length * 1.5) regime = 'Choppy';
      const throughput = Math.floor(30 + v30 * 0.6);
      const momentum = newHighs.length > newLows.length ? `+${Math.min(18, newHighs.length * 3)}%` : `-${Math.min(15, newLows.length * 4)}%`;

      // Volume spike detection (HighLowTicker entry highlight)
      let volumeSpikes = [];
      if (wlTickers.length) {
        const quotes = await Promise.allSettled(wlTickers.map(t => yahooQuote(t)));
        const vols = quotes.filter(q => q.status === 'fulfilled').map(q => q.value.volume || 0);
        if (vols.length) {
          const avgVol = vols.reduce((a,b)=>a+b,0) / vols.length;
          quotes.forEach((q,i) => {
            if (q.status === 'fulfilled' && q.value.volume > avgVol * 2.5) {
              volumeSpikes.push({ ticker: q.value.ticker, vol: q.value.volume, ratio: (q.value.volume / avgVol).toFixed(1) });
            }
          });
        }
      }
      volumeSpikes = volumeSpikes.slice(0,4);

      return sendJson(res, 200, {
        indexes,
        regime,
        throughput: `${throughput} Hz`,
        momentum,
        velocity: vel,
        newHighs,
        newLows,
        recentHL,
