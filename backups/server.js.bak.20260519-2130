    try { const r = stores.positions.patch(id, JSON.parse(await readBody(req))); return sendJson(res, r ? 200 : 404, r || { error: 'not found' }); }
    catch(e) { return sendJson(res, 400, { error: e.message }); }
  }

  if (pathname === '/api/trading/alerts') {
    if (method === 'GET') return sendJson(res, 200, stores.priceAlerts.all());
    if (method === 'POST') {
      try { return sendJson(res, 200, stores.priceAlerts.append(JSON.parse(await readBody(req)))); }
