        ts: Date.now(),
        question,
        context: liveContext,
        plan: (metaPlan || '').slice(0, 600),
        final: answer.slice(0, 2200)
      });
    } catch (agentErr) {
      answer += `\n\n[Deep meta research hit an error — safe fallback used]`;
    }

      return sendJson(res, 200, {
