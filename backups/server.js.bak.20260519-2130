function modelPrice(modelStr) {
  if (!modelStr) return 0;
  const m = modelStr.toLowerCase();
  for (const [key, p] of Object.entries(MODEL_PRICES)) {
    if (m.includes(key)) return ((p.input + p.output) / 2) * (AVG_TOKENS / 1000);
  }
  return 0.003 * (AVG_TOKENS / 1000);
}

