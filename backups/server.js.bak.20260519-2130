// ─── Generic JSON Store Factory ──────────────────────────────
function makeStore(filename, maxItems = 2000) {
  const file = path.join(DATA_DIR, filename);
  const read = () => {
    fs.mkdirSync(DATA_DIR, { recursive: true });
    try { const r = fs.readFileSync(file, 'utf8'); const p = JSON.parse(r || '[]'); return Array.isArray(p) ? p : []; } catch { return []; }
  };
  const write = (items) => {
    const tmp = `${file}.tmp`;
    fs.writeFileSync(tmp, JSON.stringify(items.slice(-maxItems), null, 2) + '\n');
    fs.renameSync(tmp, file);
  };
  return {
    all: read,
    append: (item) => {
      const items = read();
      const row = { id: `${Date.now()}-${Math.random().toString(36).slice(2,7)}`, created_at: new Date().toISOString(), ...item };
      items.push(row);
      write(items);
      return row;
    },
    patch: (id, updates) => {
      const items = read();
      const i = items.findIndex(x => x.id === id);
      if (i < 0) return null;
      items[i] = { ...items[i], ...updates, updated_at: new Date().toISOString() };
      write(items);
      return items[i];
    },
    remove: (id) => {
      const items = read();
      const next = items.filter(x => x.id !== id);
      write(next);
      return next.length < items.length;
    },
  };
}

