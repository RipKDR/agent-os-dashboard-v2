async function yahooQuote(ticker) {
  return withCache(`yq:${ticker}`, 60000, () =>
    fetchUrl(`https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(ticker)}?interval=1d&range=1y`)
      .then(d => {
        const q = d?.chart?.result?.[0];
        if (!q) throw new Error('no data');
        const meta = q.meta || {};
        const closes = q.indicators?.quote?.[0]?.close || [];
        const high52 = Math.max(...closes.filter(Boolean));
        const low52  = Math.min(...closes.filter(Boolean));
        return {
          ticker, price: meta.regularMarketPrice || 0,
          change: (meta.regularMarketPrice || 0) - (meta.previousClose || 0),
          change_pct: meta.regularMarketPrice && meta.previousClose
            ? (((meta.regularMarketPrice - meta.previousClose) / meta.previousClose) * 100).toFixed(2) : '0.00',
          volume: meta.regularMarketVolume || 0,
          market_cap: meta.marketCap || 0,
          high_52w: high52, low_52w: low52,
          day_high: meta.regularMarketDayHigh || null,
          day_low:  meta.regularMarketDayLow  || null,
          currency: meta.currency || 'USD',
          closes: closes.slice(-30),
          timestamps: q.timestamp?.slice(-30) || [],
        };
      })
  );
}

