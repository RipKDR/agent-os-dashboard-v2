// ─── Helpers ─────────────────────────────────────────────────
function sendJson(res, status, payload) {
  const body = JSON.stringify(payload);
  const headers = { 'Content-Type': 'application/json; charset=utf-8', 'Cache-Control': 'no-store' };
  const accepts = res.req?.headers['accept-encoding'] || '';
  if (accepts.includes('gzip') && body.length > 512) {
    headers['Content-Encoding'] = 'gzip';
    headers['Vary'] = 'Accept-Encoding';
    res.writeHead(status, headers);
    res.end(zlib.gzipSync(body));
  } else {
    headers['Content-Length'] = Buffer.byteLength(body);
    res.writeHead(status, headers);
    res.end(body);
  }
}

function safeCompare(a, b) {
  const la = Buffer.from(String(a || '')), lb = Buffer.from(String(b || ''));
  return la.length === lb.length && crypto.timingSafeEqual(la, lb);
}

function isAuthorized(req) {
  if (!DASHBOARD_USER || !DASHBOARD_PASSWORD) return true;
  const h = req.headers.authorization || '';
  if (!h.startsWith('Basic ')) return false;
  try {
    const d = Buffer.from(h.slice(6), 'base64').toString('utf8');
    const i = d.indexOf(':');
    if (i < 0) return false;
    return safeCompare(d.slice(0, i), DASHBOARD_USER) && safeCompare(d.slice(i + 1), DASHBOARD_PASSWORD);
  } catch { return false; }
}

function requireAuth(req, res) {
  if (isAuthorized(req)) return true;
  res.writeHead(401, {
    'WWW-Authenticate': 'Basic realm="Agent Dashboard", charset="UTF-8"',
    'Content-Type': 'text/plain; charset=utf-8', 'Cache-Control': 'no-store',
  });
  res.end('Authentication required');
  return false;
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    let body = '';
    req.on('data', c => { body += c; if (body.length > 256 * 1024) { req.destroy(); reject(new Error('Body too large')); } });
    req.on('end', () => resolve(body));
    req.on('error', reject);
  });
}

function readBodyRaw(req, maxBytes = 10 * 1024 * 1024) {
  return new Promise((resolve, reject) => {
    const chunks = [];
    let total = 0;
    req.on('data', c => { total += c.length; if (total > maxBytes) { req.destroy(); reject(new Error('File too large (max 10MB)')); } chunks.push(c); });
    req.on('end', () => resolve(Buffer.concat(chunks)));
    req.on('error', reject);
  });
}

function splitBuffer(buf, sep) {
  const parts = [];
  let start = 0;
  while (true) {
    const idx = buf.indexOf(sep, start);
    if (idx === -1) { parts.push(buf.slice(start)); break; }
    parts.push(buf.slice(start, idx));
    start = idx + sep.length;
  }
  return parts;
}

function safePath(userPath) {
  const clean = decodeURIComponent(userPath).replace(/^\/+/, '');
  const resolved = path.resolve(WORKSPACE_ROOT, clean);
  if (!resolved.startsWith(WORKSPACE_ROOT)) throw new Error('Path traversal');
  return resolved;
}

// ─── Agent Runner ────────────────────────────────────────────
function extractAgentText(stdout) {
  const text = String(stdout || '').trim();
  if (!text) return '';
  try {
    const parsed = JSON.parse(text);
    const payloads = Array.isArray(parsed?.payloads) ? parsed.payloads : (Array.isArray(parsed?.result?.payloads) ? parsed.result.payloads : null);
    if (payloads?.[0]?.text) return payloads.map(p => p.text).filter(Boolean).join('\n\n');
    if (typeof parsed?.result?.finalAssistantVisibleText === 'string') return parsed.result.finalAssistantVisibleText;
    if (typeof parsed?.text === 'string') return parsed.text;
    if (typeof parsed?.message === 'string') return parsed.message;
  } catch {}
  return text;
}

function runAgent(agentName, message) {
  const agentId = AGENT_MAP[String(agentName).toLowerCase()];
  if (!agentId) return Promise.reject(new Error(`Unknown agent: ${agentName}`));
  const prompt = agentId === 'main' ? message : `${message}${SPECIALIST_LOGGING_GATE}`;
  return new Promise((resolve, reject) => {
    execFile(OPENCLAW_BIN, ['agent', '--agent', agentId, '--message', prompt, '--json', '--timeout', '600'], {
      cwd: WORKSPACE_ROOT, timeout: 660000, maxBuffer: 8 * 1024 * 1024, env: process.env,
    }, (err, stdout, stderr) => {
      if (err) return reject(new Error(String(stderr || stdout || err.message).trim()));
      resolve(extractAgentText(stdout) || '(No response)');
    });
  });
}

// ─── CLI Process Manager ─────────────────────────────────────
const CLI_SESSIONS = new Map();

function startCLI(type, cwd = WORKSPACE_ROOT) {
  if (CLI_SESSIONS.size >= MAX_CLI_SESSIONS) throw new Error(`Max ${MAX_CLI_SESSIONS} CLI sessions`);
  const cmd = type === 'codex' ? 'codex' : 'claude';

  const id = `cli-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
  const proc = spawn(cmd, [], { cwd, shell: true, env: { ...process.env } });

  const session = { id, type, cmd, proc, cwd, startedAt: new Date(), lastActivity: new Date(), listeners: new Set(), buffer: [] };
  CLI_SESSIONS.set(id, session);

  proc.stdout.on('data', (data) => {
    const s = data.toString();
    session.buffer.push(s);
    if (session.buffer.length > 1000) session.buffer.shift();
    broadcast('cli-output', { id, type, data: s });
  });

  proc.stderr.on('data', (data) => {
    const s = data.toString();
    session.buffer.push(s);
    broadcast('cli-output', { id, type, data: s, stream: 'stderr' });
  });

  proc.on('exit', (code) => {
    broadcast('cli-exit', { id, type, code });
    CLI_SESSIONS.delete(id);
  });

  proc.on('error', (err) => {
    broadcast('cli-error', { id, type, error: err.message });
    CLI_SESSIONS.delete(id);
  });

  return id;
}

function sendCLIInput(id, input) {
  const s = CLI_SESSIONS.get(id);
  if (!s || !s.proc.stdin.writable) throw new Error('Session not active');
  s.lastActivity = new Date();
  s.proc.stdin.write(input + '\n');
}

function stopCLI(id) {
  const s = CLI_SESSIONS.get(id);
  if (!s) return;
  s.proc.kill('SIGTERM');
  setTimeout(() => { if (CLI_SESSIONS.has(id)) s.proc.kill('SIGKILL'); }, 5000);
}

function getCLISessions() {
  return Array.from(CLI_SESSIONS.values()).map(s => ({
    id: s.id, type: s.type, cmd: s.cmd, cwd: s.cwd,
    startedAt: s.startedAt, lastActivity: s.lastActivity,
  }));
}

// ─── File System API ─────────────────────────────────────────
function listDir(dirPath) {
  const resolved = safePath(dirPath);
  const entries = fs.readdirSync(resolved, { withFileTypes: true });
  const items = entries.map(e => {
    const full = path.join(resolved, e.name);
    let stat;
    try { stat = fs.statSync(full); } catch { return null; }
    return {
      name: e.name, isDir: e.isDirectory(), size: stat.size,
      mtime: stat.mtime.toISOString(), mode: stat.mode.toString(8),
    };
  }).filter(Boolean);
  items.sort((a, b) => {
    if (a.isDir !== b.isDir) return a.isDir ? -1 : 1;
    return a.name.localeCompare(b.name);
  });
  return { path: resolved, items };
}

function parseFrontmatter(content) {
  const fm = { tags: [], links: [] };
  // YAML frontmatter
  const fmMatch = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
  if (fmMatch) {
    const yaml = fmMatch[1];
    // tags: [a, b] or tags:\n  - a\n  - b
    const tagsLine = yaml.match(/^tags:\s*\[([^\]]+)\]/m);
    if (tagsLine) {
      fm.tags = tagsLine[1].split(',').map(t => t.trim().replace(/^['"]|['"]$/g, '')).filter(Boolean);
    } else {
      const tagsBlock = yaml.match(/^tags:\s*\n((?:\s+-\s*.+\n?)+)/m);
      if (tagsBlock) {
        fm.tags = tagsBlock[1].split('\n').map(l => l.replace(/^\s+-\s*/, '').trim().replace(/^['"]|['"]$/g, '')).filter(Boolean);
      }
    }
    // inline tags from body and frontmatter: #tagname
    const inlineTags = content.match(/#([a-zA-Z][\w/-]+)/g) || [];
    inlineTags.forEach(t => { const v = t.slice(1); if (!fm.tags.includes(v)) fm.tags.push(v); });
  } else {
    // No frontmatter — still collect inline #tags
    const inlineTags = content.match(/#([a-zA-Z][\w/-]+)/g) || [];
    inlineTags.forEach(t => { const v = t.slice(1); if (!fm.tags.includes(v)) fm.tags.push(v); });
  }
  // Wikilinks [[Note Name]] or [[Note Name|alias]]
  const wikilinkRe = /\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g;
  let m;
  while ((m = wikilinkRe.exec(content)) !== null) fm.links.push(m[1].trim());
  return fm;
}

function readFile(filePath, offset = 0, limit = 200) {
  const resolved = safePath(filePath);
  const stat = fs.statSync(resolved);
  const content = fs.readFileSync(resolved, 'utf8');
  const lines = content.split('\n');
  const result = {
    path: resolved, size: stat.size, mtime: stat.mtime.toISOString(),
    totalLines: lines.length, language: path.extname(resolved).slice(1),
    lines: lines.slice(offset, offset + limit),
    truncated: lines.length > offset + limit,
    offset, limit,
  };
  if (path.extname(resolved) === '.md') {
    const fm = parseFrontmatter(content);
    result.tags = fm.tags;
    result.wikilinks = fm.links;
  }
  return result;
}

/** Shared directory walker — reduces duplicated traversal code */
function walkDir(dir, opts = {}) {
  const { maxDepth = Infinity, ignore = IGNORED_DIRS, fileTest = null, skipHidden = true } = opts;
  const files = [];
  const dirs = [];
  function walk(d, depth) {
    if (depth > maxDepth) return;
    try {
      for (const e of fs.readdirSync(d, { withFileTypes: true })) {
        if (ignore && (ignore.has(e.name) || (skipHidden && e.name.startsWith('.')))) continue;
        const full = path.join(d, e.name);
        if (e.isDirectory()) {
          dirs.push(full);
          walk(full, depth + 1);
        } else if (e.isFile() && (!fileTest || fileTest(e, full))) {
          files.push(full);
        }
      }
    } catch {}
  }
  walk(dir, 0);
  return { files, dirs };
}

function searchFiles(query, root = WORKSPACE_ROOT) {
  const results = [];
  const q = query.toLowerCase();
  const { files } = walkDir(root, { maxDepth: 4, fileTest: () => true });
  for (const full of files) {
    try {
      const content = fs.readFileSync(full, 'utf8').toLowerCase();
      if (content.includes(q)) {
        results.push({ path: full, name: path.basename(full), size: fs.statSync(full).size });
      }
    } catch {}
  }
  return results.slice(0, 200);
}

function getFileTree(root = WORKSPACE_ROOT, depth = 0) {
  if (depth > 3) return [];
  const items = [];
  try {
    for (const e of fs.readdirSync(root, { withFileTypes: true })) {
      if (IGNORED_DIRS.has(e.name) || e.name.startsWith('.')) continue;
      const full = path.join(root, e.name);
      const node = { name: e.name, path: full.replace(WORKSPACE_ROOT, ''), isDir: e.isDirectory() };
      if (e.isDirectory()) {
        node.children = getFileTree(full, depth + 1);
        if (node.children.length > 0 || depth === 0) items.push(node);
      } else if (e.isFile() && /\.(md|txt|json|js|ts|tsx|jsx|html|css|yml|yaml|toml|env)$/i.test(e.name)) {
        try { node.size = fs.statSync(full).size; } catch {}
        items.push(node);
      }
    }
  } catch {}
  return items;
}

function getMemoryFiles() {
  const memDir = path.join(WORKSPACE_ROOT, 'memory');
  const results = [];
  try {
    for (const e of fs.readdirSync(memDir, { withFileTypes: true })) {
      if (e.isFile() && e.name.endsWith('.md')) {
        const stat = fs.statSync(path.join(memDir, e.name));
        results.push({ name: e.name, path: `/memory/${e.name}`, size: stat.size, mtime: stat.mtime.toISOString() });
      }
    }
  } catch {}
  // Also MEMORY.md at root
  try {
    const stat = fs.statSync(path.join(WORKSPACE_ROOT, 'MEMORY.md'));
    results.push({ name: 'MEMORY.md', path: '/MEMORY.md', size: stat.size, mtime: stat.mtime.toISOString() });
  } catch {}
  results.sort((a, b) => new Date(b.mtime) - new Date(a.mtime));
  return results;
}

function getSelfImprovingFiles() {
  const siDir = path.join(WORKSPACE_ROOT, 'self-improving');
  const altDir = '/home/admin/self-improving';
  const results = [];
  let resolvedDir = siDir;
  if (!fs.existsSync(siDir) && fs.existsSync(altDir)) resolvedDir = altDir;
  function walk(dir, prefix = '') {
    try {
      for (const e of fs.readdirSync(dir, { withFileTypes: true })) {
        const full = path.join(dir, e.name);
        if (e.isDirectory()) walk(full, `${prefix}/${e.name}`);
        else if (e.isFile() && e.name.endsWith('.md')) {
          const stat = fs.statSync(full);
          results.push({ name: `${prefix}/${e.name}`, path: full.replace(WORKSPACE_ROOT, ''), size: stat.size, mtime: stat.mtime.toISOString() });
        }
      }
    } catch {}
  }
  try { walk(resolvedDir); } catch {}
  return results;
}

// ─── GitHub Proxy ────────────────────────────────────────────
async function githubProxy(req, res, url) {
  const authHeader = req.headers.authorization || '';
  const token = authHeader.toLowerCase().startsWith('bearer ') ? authHeader.slice(7).trim() : '';
  const ghPath = url.searchParams.get('path');
  if (!token || !ghPath) return sendJson(res, 400, { error: 'authorization bearer token and path param required' });
  try {
    const data = await new Promise((resolve, reject) => {
      https.get(`https://api.github.com${ghPath}`, {
        headers: { 'User-Agent': 'AgentDashboard', 'Authorization': `Bearer ${token}`, 'Accept': 'application/vnd.github.v3+json' },
      }, (res) => {
        let d = '';
        res.on('data', c => d += c);
        res.on('end', () => { try { resolve(JSON.parse(d)); } catch { resolve(d); } });
      }).on('error', reject);
    });
    sendJson(res, 200, data);
  } catch (err) {
    sendJson(res, 500, { error: err.message });
  }
}

// ─── SSE Endpoint ────────────────────────────────────────────
function handleSSE(req, res) {
  res.writeHead(200, {
    'Content-Type': 'text/event-stream', 'Cache-Control': 'no-cache',
    'Connection': 'keep-alive', 'X-Accel-Buffering': 'no',
  });
  res.write(`event: connected\ndata: ${JSON.stringify({ timestamp: new Date().toISOString() })}\n\n`);

  const send = (event, data) => res.write(`event: ${event}\ndata: ${JSON.stringify(data)}\n\n`);

  const handlerMap = {
    'cli-output': d => send('cli-output', d), 'cli-exit': d => send('cli-exit', d),
    'cli-error': d => send('cli-error', d), 'system-event': d => send('system-event', d),
    'dispatch': d => send('dispatch', d),
  };

  Object.entries(handlerMap).forEach(([ev, h]) => eventBus.on(ev, h));
  const keepalive = setInterval(() => res.write(`:ping\n\n`), 15000);
  req.on('close', () => {
    Object.entries(handlerMap).forEach(([ev, h]) => eventBus.off(ev, h));
    clearInterval(keepalive);
  });
}

// ─── API Router ──────────────────────────────────────────────
async function handleApi(req, res, url) {
  const method = req.method;
  const pathname = url.pathname;

  if (method === 'GET' && pathname === '/api/config') {
    if (!requireAuth(req, res)) return;
    return sendJson(res, 200, {
      supabaseUrl: DASHBOARD_SUPABASE_URL,
      supabaseKey: DASHBOARD_SUPABASE_KEY,
    });
  }

  // ── SSE ──
  if (method === 'GET' && pathname === '/api/events') return handleSSE(req, res);

  // ── Chat ──
  if (method === 'GET' && pathname.startsWith('/api/chat/')) {
    const agent = decodeURIComponent(pathname.split('/').pop()).toLowerCase();
    const rows = readMessages().filter(r => String(r.agent_name).toLowerCase() === agent).sort((a, b) => new Date(a.created_at) - new Date(b.created_at)).slice(-200);
    return sendJson(res, 200, { rows });
  }
  if (method === 'POST' && pathname === '/api/chat/send') {
    try {
      const payload = JSON.parse(await readBody(req) || '{}');
      const agent = String(payload.agent_name).toLowerCase();
      const body = String(payload.body || '').trim();
      if (!AGENT_MAP[agent]) return sendJson(res, 400, { error: `Unknown agent: ${agent}` });
      if (!body) return sendJson(res, 400, { error: 'Message required' });
      const outbound = appendMessage({ agent_name: agent, sender: 'operator', body, direction: 'outbound' });
      let inbound;
      try {
        const reply = await runAgent(agent, body);
        inbound = appendMessage({ agent_name: agent, sender: AGENT_MAP[agent], body: reply, direction: 'inbound' });
      } catch (err) {
        inbound = appendMessage({ agent_name: agent, sender: 'system', body: `Failed: ${err.message}`, direction: 'inbound', error: true });
      }
      return sendJson(res, 200, { outbound, inbound });
    } catch (err) { return sendJson(res, 500, { error: err.message }); }
  }

  if (method === 'POST' && pathname === '/api/dispatch') {
    try {
      const payload = JSON.parse(await readBody(req) || '{}');
      const agent = String(payload.agent || '').toLowerCase();
      const message = String(payload.message || '').trim();
      const SPECIALISTS = ['alex', 'maya', 'jordan', 'dev', 'sam'];
      if (!SPECIALISTS.includes(agent)) return sendJson(res, 400, { error: `Unknown agent: ${agent}` });
      if (!message) return sendJson(res, 400, { error: 'Message required' });
      runAgent(agent, message).catch(err => console.error(`[dispatch] ${agent}:`, err.message));
      return sendJson(res, 200, { ok: true, agent, queued: true });
    } catch (err) { return sendJson(res, 500, { error: err.message }); }
  }

  // ── CLI ──
  if (method === 'POST' && pathname === '/api/cli/start') {
    try {
      const { type, cwd } = JSON.parse(await readBody(req) || '{}');
      const id = startCLI(type || 'claude', cwd || WORKSPACE_ROOT);
      return sendJson(res, 200, { id });
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'POST' && pathname.match(/^\/api\/cli\/(cli-[^/]+)\/input$/)) {
    try {
      const id = pathname.match(/cli-[^/]+/)[0];
      const { input } = JSON.parse(await readBody(req) || '{}');
      sendCLIInput(id, input || '');
      return sendJson(res, 200, { ok: true });
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'POST' && pathname.match(/^\/api\/cli\/(cli-[^/]+)\/stop$/)) {
    const id = pathname.match(/cli-[^/]+/)[0];
    stopCLI(id);
    return sendJson(res, 200, { ok: true });
  }
  if (method === 'GET' && pathname === '/api/cli/sessions') {
    return sendJson(res, 200, { sessions: getCLISessions() });
  }

  // ── Files ──
  if (method === 'POST' && pathname === '/api/files/write') {
    try {
      const { file, content } = JSON.parse(await readBody(req) || '{}');
      if (!file || content === undefined) return sendJson(res, 400, { error: 'file and content required' });
      const resolved = safePath(file);
      // Only allow .md files for safety
      if (!resolved.endsWith('.md')) return sendJson(res, 400, { error: 'Only .md files can be written from dashboard' });
      fs.writeFileSync(resolved, content, 'utf8');
      broadcast('file-change', { path: resolved, action: 'write' });
      return sendJson(res, 200, { ok: true });
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'POST' && pathname === '/api/files/upload') {
    try {
      const ALLOWED_EXT = new Set(['.py','.js','.ts','.txt','.md','.json','.csv','.yaml','.yml','.sh','.sql','.html','.css']);
      const contentType = req.headers['content-type'] || '';
      const boundaryMatch = contentType.match(/boundary=([^\s;]+)/);
      if (!boundaryMatch) return sendJson(res, 400, { error: 'Missing multipart boundary' });
      const boundary = Buffer.from('--' + boundaryMatch[1]);
      const buf = await readBodyRaw(req);
      const parts = splitBuffer(buf, boundary);
      let uploaded = null;
      for (const part of parts) {
        // Skip preamble and epilogue markers
        if (part.length < 4) continue;
        const headerEnd = part.indexOf(Buffer.from('\r\n\r\n'));
        if (headerEnd === -1) continue;
        const headerStr = part.slice(0, headerEnd).toString('utf8');
        if (!headerStr.includes('filename=')) continue;
        const fnMatch = headerStr.match(/filename="([^"]+)"/);
        if (!fnMatch) continue;
        const filename = fnMatch[1];
        // Security: reject path traversal and slashes
        if (filename.includes('..') || filename.includes('/') || filename.includes('\\')) {
          return sendJson(res, 400, { error: 'Invalid filename' });
        }
        const ext = path.extname(filename).toLowerCase();
        if (!ALLOWED_EXT.has(ext)) {
          return sendJson(res, 400, { error: `File type ${ext} not allowed` });
        }
        // File body starts after \r\n\r\n, trim trailing \r\n
        let fileData = part.slice(headerEnd + 4);
        if (fileData.slice(-2).equals(Buffer.from('\r\n'))) fileData = fileData.slice(0, -2);
        const uploadDir = path.join(process.env.HOME, 'Vault', 'uploads');
        fs.mkdirSync(uploadDir, { recursive: true });
        const destPath = path.join(uploadDir, filename);
        fs.writeFileSync(destPath, fileData);
        uploaded = { ok: true, path: 'uploads/' + filename, size: fileData.length };
        break; // process first file part only
      }
      if (!uploaded) return sendJson(res, 400, { error: 'No valid file part found' });
      return sendJson(res, 200, uploaded);
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'GET' && pathname === '/api/files/list') {
    try { return sendJson(res, 200, listDir(url.searchParams.get('path') || '')); }
    catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'GET' && pathname === '/api/files/read') {
    try {
      const filePath = url.searchParams.get('path') || '';
      const offset = parseInt(url.searchParams.get('offset') || '0', 10);
      const limit = parseInt(url.searchParams.get('limit') || '200', 10);
      return sendJson(res, 200, readFile(filePath, offset, Math.min(limit, 500)));
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'GET' && pathname === '/api/files/search') {
    try { return sendJson(res, 200, { results: searchFiles(url.searchParams.get('q') || '') }); }
    catch (err) { return sendJson(res, 400, { error: err.message }); }
  }
  if (method === 'GET' && pathname === '/api/files/tree') {
    try { return sendJson(res, 200, { tree: getFileTree() }); }
    catch (err) { return sendJson(res, 400, { error: err.message }); }
  }

  if (method === 'GET' && pathname === '/api/files/tags') {
    try {
      const { files } = walkDir(WORKSPACE_ROOT, { maxDepth: 4, fileTest: e => e.name.endsWith('.md') });
      const tagMap = {}; // tag → [relpath, ...]
      for (const f of files) {
        try {
          const content = fs.readFileSync(f, 'utf8');
          const rel = path.relative(WORKSPACE_ROOT, f);
          const fm = parseFrontmatter(content);
          fm.tags.forEach(t => { (tagMap[t] = tagMap[t] || []).push(rel); });
        } catch {}
      }
      return sendJson(res, 200, tagMap);
    } catch(err) { return sendJson(res, 400, { error: err.message }); }
  }

  // ── Memory ──
  if (method === 'GET' && pathname === '/api/memory/list') {
    return sendJson(res, 200, { files: getMemoryFiles() });
  }
  if (method === 'GET' && pathname.startsWith('/api/memory/read')) {
    try {
      const p = url.searchParams.get('path') || '';
      const offset = parseInt(url.searchParams.get('offset') || '0', 10);
      const limit = parseInt(url.searchParams.get('limit') || '200', 10);
      return sendJson(res, 200, readFile(p, offset, Math.min(limit, 500)));
    } catch (err) { return sendJson(res, 400, { error: err.message }); }
  }

  // ── Self-Improving ──
  if (method === 'GET' && pathname === '/api/learning/list') {
    return sendJson(res, 200, { files: getSelfImprovingFiles() });
  }

  // ── System Status ──
  if (method === 'GET' && pathname === '/healthz') {
    const checks = {};
    const t0 = Date.now();
    // Supabase
    if (DASHBOARD_SUPABASE_URL && DASHBOARD_SUPABASE_KEY) {
      try {
        await fetchUrl(`${DASHBOARD_SUPABASE_URL}/rest/v1/agent_logs?limit=1`, {
          'apikey': DASHBOARD_SUPABASE_KEY, 'Authorization': `Bearer ${DASHBOARD_SUPABASE_KEY}`,
        });
        checks.supabase = { ok: true, latencyMs: Date.now() - t0 };
      } catch(e) { checks.supabase = { ok: false, error: e.message }; }
    } else { checks.supabase = { ok: false, error: 'no credentials' }; }
    // Alpaca
    if (alpaca) {
      try { await alpaca.getAccount(); checks.alpaca = { ok: true, latencyMs: Date.now() - t0 }; }
      catch(e) { checks.alpaca = { ok: false, error: e.message }; }
    } else { checks.alpaca = { ok: false, error: 'no credentials' }; }
    // OpenRouter — test with a real completion probe, not just auth/key
    if (OPENROUTER_API_KEY) {
      try {
        const t1 = Date.now();
        await callLLM('say ok', 'ok', 'anthropic/claude-haiku-4-5');
        checks.openrouter = { ok: true, latencyMs: Date.now() - t1 };
      } catch(e) { checks.openrouter = { ok: false, error: e.message }; }
    } else { checks.openrouter = { ok: false, error: 'no key' }; }
    const allOk = Object.values(checks).every(c => c.ok);
    return sendJson(res, allOk ? 200 : 207, { ok: allOk, checks, uptime: process.uptime(), ts: new Date().toISOString() });
  }

  if (method === 'GET' && pathname === '/api/status') {
    return sendJson(res, 200, {
