  if (method === 'DELETE' && pathname.startsWith('/api/trading/alerts/')) {
    return sendJson(res, 200, { ok: stores.priceAlerts.remove(pathname.split('/').pop()) });
  }

  if (method === 'POST' && pathname.startsWith('/api/trading/research/')) {
    const ticker = decodeURIComponent(pathname.split('/').pop());
    const body   = await readBody(req).then(b => { try { return JSON.parse(b); } catch { return {}; } });
    const context = body.context || '';
    const prompt = context
      ? `Trade Review for ${ticker}:\n${context}\n\nReview this trade critically. What worked, what didn't, and what should I do differently? Extract 2-3 concrete lessons.`
      : `Build a full investment thesis for ${ticker}. Include: (1) bull case with catalysts and price targets, (2) bear case with key risks, (3) comparable companies table with P/E, EV/EBITDA, (4) recommended entry/stop/target levels, (5) macro context. Be specific and quantitative.`;
    try {
      const reply = await runAgent('main', prompt);
      const dir = path.join(DATA_DIR, 'theses');
      fs.mkdirSync(dir, { recursive: true });
      const filename = `${ticker}-${new Date().toISOString().slice(0,10)}.md`;
      fs.writeFileSync(path.join(dir, filename), `# ${ticker} Thesis — ${new Date().toLocaleDateString()}\n\n${reply}`);
      return sendJson(res, 200, { reply, file: `/theses/${filename}` });
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }

  if (pathname === '/api/trading/settings') {
    if (method === 'GET') return sendJson(res, 200, readJsonFile(TR_SETTINGS_FILE));
    if (method === 'POST') {
      try {
        const incoming = JSON.parse(await readBody(req));
        const existing = readJsonFile(TR_SETTINGS_FILE);
        writeJsonFile(TR_SETTINGS_FILE, { ...existing, ...incoming });
        return sendJson(res, 200, { ok: true });
      }
      catch(e) { return sendJson(res, 400, { error: e.message }); }
    }
  }

  // ── Alpaca Broker ─────────────────────────────────────────────
  if (pathname.startsWith('/api/trading/broker')) {
    if (!alpaca) return sendJson(res, 503, { error: 'Alpaca keys not configured' });
    try {
      // GET /api/trading/broker/account
      if (method === 'GET' && pathname === '/api/trading/broker/account') {
        const [account, positions, orders, clock] = await Promise.all([
          alpaca.getAccount(), alpaca.getPositions(), alpaca.getOrders('open', 20), alpaca.getClock()
        ]);
        return sendJson(res, 200, { account, positions, orders, clock, paper: alpaca.isPaper });
      }
      // GET /api/trading/broker/positions
      if (method === 'GET' && pathname === '/api/trading/broker/positions') {
        return sendJson(res, 200, await alpaca.getPositions());
      }
      // DELETE /api/trading/broker/positions  (close all)
      if (method === 'DELETE' && pathname === '/api/trading/broker/positions') {
        const { cancel } = JSON.parse(await readBody(req).catch(() => '{}'));
        return sendJson(res, 200, await alpaca.closeAll(cancel));
      }
      // DELETE /api/trading/broker/positions/:symbol
      if (method === 'DELETE' && pathname.startsWith('/api/trading/broker/positions/')) {
        const symbol = pathname.split('/').pop();
        return sendJson(res, 200, await alpaca.closePosition(symbol));
      }
      // GET /api/trading/broker/orders
      if (method === 'GET' && pathname === '/api/trading/broker/orders') {
        const status = url.searchParams.get('status') || 'open';
        const limit  = Number(url.searchParams.get('limit') || 50);
        return sendJson(res, 200, await alpaca.getOrders(status, limit));
      }
      // POST /api/trading/broker/orders  — place order
      if (method === 'POST' && pathname === '/api/trading/broker/orders') {
        const body = JSON.parse(await readBody(req));
        const { symbol, qty, side, type, tif, limit_price, stop_price,
                take_profit, stop_loss, stop_loss_limit, trail_percent,
                bracket, entry, confirm_pin } = body;
        if (!symbol || !qty || !side) return sendJson(res, 400, { error: 'symbol, qty, side required' });
        // PIN gate: required for live orders or paper orders >= TRADE_PIN_THRESHOLD
        if (TRADE_PIN) {
          const notional = body.notional || (Number(qty) * Number(limit_price || stop_price || 0));
          const needsPin = !ALPACA_PAPER || notional >= TRADE_PIN_THRESHOLD;
          if (needsPin && confirm_pin !== TRADE_PIN) {
            return sendJson(res, 403, { error: 'PIN required to place this order', pin_required: true });
          }
        }
        const result = bracket
          ? await alpaca.bracketOrder(symbol, qty, side, entry || null, take_profit, stop_loss, tif)
          : await alpaca.placeOrder(symbol, qty, side, { type, tif, limit_price, stop_price, take_profit, stop_loss, stop_loss_limit, trail_percent });
        notifyDiscord(`📈 Order placed (${alpaca.isPaper ? 'PAPER' : 'LIVE'}): ${side.toUpperCase()} ${qty}x ${symbol.toUpperCase()} [${type || 'market'}]`);
        broadcast('system-event', { type: 'order-placed', order: result });
        // Auto-journal vault entry for fills
        if (result.status === 'filled') {
          writeTradeJournal({
            symbol:      result.symbol,
            side:        result.side,
            qty:         result.filled_qty || result.qty,
            avg_price:   result.filled_avg_price || result.limit_price || '?',
            total_value: (Number(result.filled_qty || result.qty) * Number(result.filled_avg_price || 0)),
            order_id:    result.id,
            filled_at:   result.filled_at,
          }).catch(e => {
            console.error('[journal] writeTradeJournal failed:', e.message);
            broadcast('system-event', { type: 'journal-error', error: e.message });
          });
          ensureTickerPage(result.symbol).catch(e => {
            console.error('[journal] ensureTickerPage failed:', e.message);
          });
        }
        return sendJson(res, 200, result);
      }
      // DELETE /api/trading/broker/orders/:id
      if (method === 'DELETE' && pathname.startsWith('/api/trading/broker/orders/')) {
        const id = pathname.split('/').pop();
        if (id === 'all') return sendJson(res, 200, await alpaca.cancelAll());
        return sendJson(res, 200, await alpaca.cancelOrder(id));
      }
      // GET /api/trading/broker/clock
      if (method === 'GET' && pathname === '/api/trading/broker/clock') {
        return sendJson(res, 200, await alpaca.getClock());
      }
      // GET /api/trading/broker/snapshot?symbol=AAPL
      if (method === 'GET' && pathname === '/api/trading/broker/snapshot') {
        const symbol = url.searchParams.get('symbol');
        const symbols = url.searchParams.get('symbols');
        if (symbols) return sendJson(res, 200, await alpaca.getSnapshots(symbols.split(',').map(s => s.trim())));
        if (!symbol)  return sendJson(res, 400, { error: 'symbol or symbols required' });
        return sendJson(res, 200, await alpaca.getSnapshot(symbol));
      }
      // GET /api/trading/broker/bars?symbol=AAPL&timeframe=1Day&limit=50
      if (method === 'GET' && pathname === '/api/trading/broker/bars') {
        const symbol = url.searchParams.get('symbol');
        if (!symbol) return sendJson(res, 400, { error: 'symbol required' });
        const tf    = url.searchParams.get('timeframe') || '1Day';
        const limit = Number(url.searchParams.get('limit') || 100);
        return sendJson(res, 200, await alpaca.getBars(symbol, tf, limit));
      }
      // GET /api/trading/broker/portfolio
      if (method === 'GET' && pathname === '/api/trading/broker/portfolio') {
        const period = url.searchParams.get('period') || '1M';
        const tf     = url.searchParams.get('timeframe') || '1D';
        return sendJson(res, 200, await alpaca.getPortfolio(period, tf));
      }
    } catch(e) {
      return sendJson(res, e.status || 500, { error: e.message, detail: e.body || null });
    }
  }

  // ── Trading Automation ───────────────────────────────────────
  if (pathname.startsWith('/api/trading/auto')) {
    if (!scheduler) return sendJson(res, 503, { error: 'Trading engine not configured' });
    try {
      // GET /api/trading/auto/status
      if (method === 'GET' && pathname === '/api/trading/auto/status') {
        return sendJson(res, 200, scheduler.status());
      }
      // POST /api/trading/auto/scan  — trigger immediate scan
      if (method === 'POST' && pathname === '/api/trading/auto/scan') {
        const scanBody = await readBody(req).then(b => { try { return JSON.parse(b); } catch { return {}; } });
        const force = scanBody && scanBody.force === true;
        scheduler.scanNow(force).catch(() => {});
        return sendJson(res, 200, { ok: true, message: force ? 'forced scan triggered' : 'scan triggered' });
      }
      // POST /api/trading/auto/sync  — force account sync
      if (method === 'POST' && pathname === '/api/trading/auto/sync') {
        await scheduler.syncNow();
        return sendJson(res, 200, { ok: true, status: scheduler.status() });
      }
      // GET /api/trading/auto/risk
      if (method === 'GET' && pathname === '/api/trading/auto/risk') {
        return sendJson(res, 200, riskGov.status());
      }
      // POST /api/trading/auto/risk  — update risk config
      if (method === 'POST' && pathname === '/api/trading/auto/risk') {
        const cfg = JSON.parse(await readBody(req));
        riskGov.configure(cfg);
        return sendJson(res, 200, riskGov.status());
      }
      // POST /api/trading/auto/risk/reset — reset daily circuit breaker
      if (method === 'POST' && pathname === '/api/trading/auto/risk/reset') {
        riskGov.resetDailyBreaker();
        return sendJson(res, 200, { ok: true, status: riskGov.status() });
      }
    } catch(e) {
      return sendJson(res, 500, { error: e.message });
    }
  }

  // ── Factory ───────────────────────────────────────────────────
  if (pathname === '/api/factory/proposals') {
    if (method === 'GET') return sendJson(res, 200, stores.factoryProps.all().reverse());
    if (method === 'POST') {
      try { return sendJson(res, 200, stores.factoryProps.append(JSON.parse(await readBody(req)))); }
      catch(e) { return sendJson(res, 400, { error: e.message }); }
    }
  }
  if (method === 'PATCH' && pathname.startsWith('/api/factory/proposals/') && !pathname.endsWith('/build')) {
    const id = pathname.split('/').slice(-1)[0];
    try { const r = stores.factoryProps.patch(id, JSON.parse(await readBody(req))); return sendJson(res, r ? 200 : 404, r || { error: 'not found' }); }
    catch(e) { return sendJson(res, 400, { error: e.message }); }
  }
  if (method === 'POST' && pathname.endsWith('/build')) {
    const id = pathname.split('/').slice(-2)[0];
    const prop = stores.factoryProps.all().find(p => p.id === id);
    if (!prop) return sendJson(res, 404, { error: 'proposal not found' });
    stores.factoryProps.patch(id, { status: 'building' });
    broadcast('system-event', { type: 'factory-build-started', proposal: prop });
    const prompt = `Build a production-ready MVP for this product proposal:\n\nTitle: ${prop.title}\nProblem: ${prop.problem}\nSolution: ${prop.solution}\n\nCreate a GitHub repo, implement the core features, deploy to Vercel. Report the GitHub URL and Vercel preview URL when done.`;
    runAgent('dev', prompt)
      .then(reply => {
        const ghMatch = reply.match(/github\.com\/[\w-]+\/[\w-]+/);
        const vercelMatch = reply.match(/[\w-]+\.vercel\.app/);
        stores.factoryProps.patch(id, { status: 'review', github_repo: ghMatch?.[0] || null, vercel_url: vercelMatch?.[0] || null, build_output: reply.slice(0,500) });
        broadcast('system-event', { type: 'factory-build-done', id });
      })
      .catch(e => stores.factoryProps.patch(id, { status: 'proposal', build_error: e.message }));
    return sendJson(res, 200, { ok: true, message: 'Build started' });
  }

  // ── Email Inbox ───────────────────────────────────────────────
  if (pathname === '/api/email/inbox') {
    if (method === 'GET') {
      let items = stores.emailInbox.all().reverse();
      const status = url.searchParams.get('status');
      const priority = url.searchParams.get('priority');
      if (status) items = items.filter(e => e.status === status);
      if (priority) items = items.filter(e => e.priority === priority);
      return sendJson(res, 200, items);
    }
    if (method === 'POST') {
      try { return sendJson(res, 200, stores.emailInbox.append(JSON.parse(await readBody(req)))); }
      catch(e) { return sendJson(res, 400, { error: e.message }); }
    }
  }
  if (method === 'PATCH' && pathname.startsWith('/api/email/inbox/') && !pathname.includes('/reply') && !pathname.includes('/escalate')) {
    const id = pathname.split('/').pop();
    try { const r = stores.emailInbox.patch(id, JSON.parse(await readBody(req))); return sendJson(res, r ? 200 : 404, r || { error: 'not found' }); }
    catch(e) { return sendJson(res, 400, { error: e.message }); }
  }
  if (method === 'POST' && pathname.match(/\/api\/email\/inbox\/[^/]+\/(reply-positive|reply-negative|escalate)$/)) {
    const parts = pathname.split('/');
    const action = parts.pop();
    const id = parts.pop();
    const email = stores.emailInbox.all().find(e => e.id === id);
    if (!email) return sendJson(res, 404, { error: 'not found' });
    const sentiment = action === 'reply-positive' ? 'positive and helpful' : action === 'reply-negative' ? 'politely declining' : 'detailed and thorough';
    const prompt = action === 'escalate'
      ? `I need your help with this email:\n\nFrom: ${email.from}\nSubject: ${email.subject}\nSummary: ${email.summary}\nAction items: ${JSON.stringify(email.action_items)}\n\nPlease provide a thorough, strategic response or action plan.`
      : `Draft a ${sentiment} email reply to:\n\nFrom: ${email.from}\nSubject: ${email.subject}\nContent summary: ${email.summary}\n\nWrite only the reply body, professional tone, concise.`;
    try {
      const reply = await runAgent('main', prompt);
      stores.emailInbox.patch(id, { draft_reply: reply, status: 'draft_ready' });
      return sendJson(res, 200, { reply });
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }

  // ── Costs ─────────────────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/costs') {
    const days = parseInt(url.searchParams.get('days') || '14', 10);
    const cutoff = new Date(Date.now() - days * 86400000).toISOString();
    const agentsFile = path.join(DATA_DIR, 'agents.json');
    const agents = getAgentConfig();
    // Read from Supabase via a simple fetch from the frontend; server just returns model pricing table
    // Server can't hit Supabase directly without service key, so return pricing table + instructions
    return sendJson(res, 200, { model_prices: MODEL_PRICES, avg_tokens: AVG_TOKENS, agents: agents.map(a => a.id), days, cutoff });
  }
  if (method === 'GET' && pathname === '/api/costs/suggestions') {
    return sendJson(res, 200, [
      { rule: 'Use Haiku for routine summarization tasks — saves ~70% vs Sonnet', saving_pct: 70 },
      { rule: 'Batch research tasks to reduce parallel Opus calls', saving_pct: 30 },
      { rule: 'Cache repeated web searches in agent memory files', saving_pct: 20 },
      { rule: 'Use local Ollama/Gemma for privacy-sensitive email triage', saving_pct: 100 },
    ]);
  }

  // ── Morning Brief ─────────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/brief/today') {
    const briefs = stores.dailyBrief.all();
    const today = new Date().toDateString();
    const brief = briefs.reverse().find(b => new Date(b.created_at).toDateString() === today);
    return sendJson(res, 200, brief || null);
  }
  if (method === 'POST' && pathname === '/api/brief/generate') {
    try {
      const brief = await generateDailyBrief();
      return sendJson(res, 200, brief);
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }

  if (method === 'GET' && pathname === '/api/brief/weekly') {
    return sendJson(res, 200, stores.weeklyBrief.all().slice(-4));
  }
  if (method === 'POST' && pathname === '/api/brief/weekly/generate') {
    try {
      const brief = await generateWeeklyReview();
      return sendJson(res, 200, brief);
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }

  // ── GitHub proxy ─────────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/github/prs') {
    if (!GITHUB_TOKEN || !GITHUB_REPO) return sendJson(res, 200, { error: 'not configured' });
    try {
      const data = await new Promise((resolve, reject) => {
        const req2 = https.request({
          hostname: 'api.github.com',
          path: `/repos/${GITHUB_REPO}/pulls?state=open&per_page=20`,
          method: 'GET',
          headers: { 'Authorization': `Bearer ${GITHUB_TOKEN}`, 'User-Agent': 'atlas-dashboard/1.0', 'Accept': 'application/vnd.github+json' },
        }, (r2) => {
          let raw = '';
          r2.on('data', c => raw += c);
          r2.on('end', () => { try { resolve(JSON.parse(raw)); } catch(e) { reject(e); } });
        });
        req2.on('error', reject);
        req2.end();
      });
      const prs = Array.isArray(data) ? data.map(pr => ({
        number: pr.number, title: pr.title, author: pr.user?.login,
        state: pr.state, draft: pr.draft, url: pr.html_url,
        created_at: pr.created_at, mergeable: pr.mergeable,
        head: pr.head?.label, base: pr.base?.label,
      })) : data;
      return sendJson(res, 200, prs);
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }
  if (method === 'POST' && pathname.startsWith('/api/github/prs/') && pathname.endsWith('/merge')) {
    if (!GITHUB_TOKEN || !GITHUB_REPO) return sendJson(res, 503, { error: 'not configured' });
    const prNum = pathname.split('/')[4];
    if (!prNum || isNaN(Number(prNum))) return sendJson(res, 400, { error: 'invalid PR number' });
    try {
      const body = JSON.parse(await readBody(req) || '{}');
      const result = await new Promise((resolve, reject) => {
        const payload = JSON.stringify({ merge_method: body.merge_method || 'squash', commit_title: body.commit_title });
        const req2 = https.request({
          hostname: 'api.github.com',
          path: `/repos/${GITHUB_REPO}/pulls/${prNum}/merge`,
          method: 'PUT',
          headers: { 'Authorization': `Bearer ${GITHUB_TOKEN}`, 'User-Agent': 'atlas-dashboard/1.0', 'Accept': 'application/vnd.github+json', 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(payload) },
        }, (r2) => {
          let raw = '';
          r2.on('data', c => raw += c);
          r2.on('end', () => { try { resolve({ status: r2.statusCode, body: JSON.parse(raw) }); } catch(e) { reject(e); } });
        });
        req2.on('error', reject);
        req2.write(payload);
        req2.end();
      });
      return sendJson(res, result.status >= 400 ? 422 : 200, result.body);
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }

  // ── Standup ───────────────────────────────────────────────────
  if (method === 'POST' && pathname === '/api/standup/generate') {
    try {
      const body = JSON.parse(await readBody(req) || '{}');
      const logs = body.logs || [];
      const prompt = `Based on these recent agent activities:\n${logs.map(l=>`- ${l.agent_name}: ${l.task_description} (${l.status})`).join('\n')}\n\nWrite a brief standup summary (3-5 bullets) covering what was accomplished and what's next.`;
      const reply = await runAgent('main', prompt);
      const standup = stores.standups.append({ summary: reply, participants: [...new Set(logs.map(l=>l.agent_name))] });
      return sendJson(res, 200, standup);
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
  }
  if (method === 'GET' && pathname === '/api/standup/latest') {
    const all = stores.standups.all();
    return sendJson(res, 200, all[all.length-1] || null);
  }

  // ── Unified Approvals ─────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/approvals') {
    const signals  = stores.signals.all().filter(s => s.status === 'watching').map(s => ({ ...s, _type: 'signal',  _label: `${s.direction?.toUpperCase()} ${s.ticker}` }));
    const ideas    = stores.contentIdeas.all().filter(i => i.status === 'idea').map(i => ({ ...i, _type: 'content', _label: i.title }));
    const emails   = stores.emailInbox.all().filter(e => e.status === 'unread').map(e => ({ ...e, _type: 'email',   _label: e.subject || e.from }));
    const proposals= stores.factoryProps.all().filter(p => p.status === 'proposal').map(p => ({ ...p, _type: 'factory', _label: p.title }));
    const all = [...signals, ...ideas, ...emails, ...proposals].sort((a,b) => new Date(b.created_at) - new Date(a.created_at));
    return sendJson(res, 200, all);
  }

  // ── Webhook Receiver ──────────────────────────────────────────
  if (method === 'POST' && pathname.startsWith('/api/webhook/')) {
    const source = pathname.split('/').pop();
    if (WEBHOOK_SECRET) {
      const sig = req.headers['x-webhook-secret'] || req.headers['x-hub-signature-256'] || '';
      if (!sig.includes(WEBHOOK_SECRET)) return sendJson(res, 401, { error: 'invalid signature' });
    }
    try {
      const payload = JSON.parse(await readBody(req));
      const event = stores.webhookEvents.append({ source, payload });
      broadcast('system-event', { type: 'webhook', source, event });
      // Route to appropriate agent if factory/github deploy
      if (source === 'vercel' && payload?.type === 'deployment') {
        const deploymentUrl = payload?.deployment?.url;
        if (deploymentUrl) {
          const id = payload?.deployment?.meta?.factoryId;
          if (id) stores.factoryProps.patch(id, { status: 'deployed', vercel_url: deploymentUrl });
        }
      }
      return sendJson(res, 200, { ok: true });
    } catch(e) { return sendJson(res, 400, { error: e.message }); }
  }

  // ── Settings ──────────────────────────────────────────────────
  if (pathname === '/api/settings') {
    if (method === 'GET') return sendJson(res, 200, readJsonFile(SETTINGS_FILE));
    if (method === 'POST') {
      try {
        const incoming = JSON.parse(await readBody(req));
        const existing = readJsonFile(SETTINGS_FILE);
        writeJsonFile(SETTINGS_FILE, { ...existing, ...incoming });
        return sendJson(res, 200, { ok: true });
      }
      catch(e) { return sendJson(res, 400, { error: e.message }); }
    }
  }

  // ── Agent Logs (Supabase) ─────────────────────────────────────
  if (method === 'GET' && pathname === '/api/agent-logs') {
    if (!requireAuth(req, res)) return;
    if (!DASHBOARD_SUPABASE_URL || !DASHBOARD_SUPABASE_KEY) {
      return sendJson(res, 503, { error: 'Supabase not configured' });
    }
    try {
      const limit = Math.min(Number(url.searchParams.get('limit') || 50), 200);
      const data = await fetchUrl(
        `${DASHBOARD_SUPABASE_URL}/rest/v1/agent_logs?select=agent_name,task_description,model_used,status,created_at&order=created_at.desc&limit=${limit}`,
        { 'apikey': DASHBOARD_SUPABASE_KEY, 'Authorization': `Bearer ${DASHBOARD_SUPABASE_KEY}` }
      );
      const logs = Array.isArray(data) ? data : [];
      const grouped = {};
      for (const log of logs) {
        const name = log.agent_name || 'unknown';
        if (!grouped[name]) grouped[name] = [];
        grouped[name].push(log);
      }
      return sendJson(res, 200, { logs, grouped, count: logs.length });
    } catch (e) {
      return sendJson(res, 502, { error: e.message });
    }
  }

  // ── Agent Stats (Supabase) ────────────────────────────────────
  if (method === 'GET' && pathname === '/api/agent-stats') {
    if (!requireAuth(req, res)) return;
    if (!DASHBOARD_SUPABASE_URL || !DASHBOARD_SUPABASE_KEY) {
      return sendJson(res, 503, { error: 'Supabase not configured' });
    }
    try {
      const data = await fetchUrl(
        `${DASHBOARD_SUPABASE_URL}/rest/v1/agent_logs?select=agent_name,status,created_at&order=created_at.desc&limit=5000`,
        { 'apikey': DASHBOARD_SUPABASE_KEY, 'Authorization': `Bearer ${DASHBOARD_SUPABASE_KEY}` }
      );
      const logs = Array.isArray(data) ? data : [];
      const stats = {};
      for (const log of logs) {
        const name = log.agent_name || 'unknown';
        if (!stats[name]) {
          stats[name] = { agent_name: name, total: 0, completed: 0, failed: 0, last_active: null };
        }
        stats[name].total++;
        if (log.status === 'completed') stats[name].completed++;
        if (log.status === 'failed') stats[name].failed++;
        if (log.created_at && (!stats[name].last_active || log.created_at > stats[name].last_active)) {
          stats[name].last_active = log.created_at;
        }
      }
      return sendJson(res, 200, { stats: Object.values(stats), count: logs.length });
    } catch (e) {
      return sendJson(res, 502, { error: e.message });
    }
  }

  // ── Activity Heatmap (Supabase) ────────────────────────────────
  if (method === 'GET' && pathname === '/api/activity-heatmap') {
    if (!requireAuth(req, res)) return;
    if (!DASHBOARD_SUPABASE_URL || !DASHBOARD_SUPABASE_KEY) {
      return sendJson(res, 503, { error: 'Supabase not configured' });
    }
    try {
      const since = new Date(Date.now() - 24 * 3600000).toISOString();
      const data = await fetchUrl(
        `${DASHBOARD_SUPABASE_URL}/rest/v1/agent_logs?select=agent_name,created_at&created_at=gte.${since}&order=created_at.asc&limit=5000`,
        { 'apikey': DASHBOARD_SUPABASE_KEY, 'Authorization': `Bearer ${DASHBOARD_SUPABASE_KEY}` }
      );
      const logs = Array.isArray(data) ? data : [];
      const agents = [...new Set(logs.map(l => l.agent_name).filter(Boolean))];
      const hours = Array.from({length: 24}, (_, i) => i);
      const heatmap = {};
      for (const a of agents) heatmap[a] = {};
      for (const h of hours) for (const a of agents) heatmap[a][h] = 0;
      for (const log of logs) {
        const h = new Date(log.created_at).getUTCHours();
        if (heatmap[log.agent_name]) heatmap[log.agent_name][h]++;
      }
      return sendJson(res, 200, { agents, hours, data: heatmap });
    } catch (e) {
      return sendJson(res, 502, { error: e.message });
    }
  }

  // ── 7-Day Activity Chart (Supabase) ───────────────────────────
  if (method === 'GET' && pathname === '/api/activity-chart') {
    if (!requireAuth(req, res)) return;
    if (!DASHBOARD_SUPABASE_URL || !DASHBOARD_SUPABASE_KEY) {
      return sendJson(res, 503, { error: 'Supabase not configured' });
    }
    try {
      const since = new Date(Date.now() - 7 * 86400000).toISOString();
      const data = await fetchUrl(
        `${DASHBOARD_SUPABASE_URL}/rest/v1/agent_logs?select=status,created_at&created_at=gte.${since}&order=created_at.asc&limit=5000`,
        { 'apikey': DASHBOARD_SUPABASE_KEY, 'Authorization': `Bearer ${DASHBOARD_SUPABASE_KEY}` }
      );
      const logs = Array.isArray(data) ? data : [];
      const days = [];
      const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      for (let i = 6; i >= 0; i--) {
        const d = new Date(Date.now() - i * 86400000);
        days.push({ key: d.toISOString().slice(0,10), label: dayNames[d.getUTCDay()], total: 0, completed: 0 });
      }
      for (const log of logs) {
        const key = log.created_at.slice(0,10);
        const day = days.find(d => d.key === key);
        if (day) { day.total++; if (log.status === 'completed') day.completed++; }
      }
      return sendJson(res, 200, {
        labels: days.map(d => d.label),
        total: days.map(d => d.total),
        completed: days.map(d => d.completed)
      });
    } catch (e) {
      return sendJson(res, 502, { error: e.message });
    }
  }

  // ── Models ────────────────────────────────────────────────────
  if (method === 'GET' && pathname === '/api/models') {
    try {
      const openclawCfg = JSON.parse(fs.readFileSync(path.join(WORKSPACE_ROOT, '..', 'openclaw.json'), 'utf8'));
      const agentsList = openclawCfg.agents?.list || [];
      const defaults = openclawCfg.agents?.defaults || {};
      const defaultModel = defaults.model?.primary || '';
      const defaultFallbacks = defaults.model?.fallbacks || [];
      const allDefinedModels = Object.keys(defaults.models || {});

      const agents = agentsList.map(agent => {
        const agentId = agent.id;
        // Read agent-specific models.json from agentDir if available
        let availableModels = [];
        if (agent.agentDir) {
          const agentModelsFile = path.join(agent.agentDir, 'models.json');
          try {
            if (fs.existsSync(agentModelsFile)) {
              const agentModels = JSON.parse(fs.readFileSync(agentModelsFile, 'utf8'));
              const providers = agentModels.providers || {};
              for (const [provider, pCfg] of Object.entries(providers)) {
                const models = pCfg.models || [];
                for (const m of models) {
                  availableModels.push({
                    provider,
                    model_id: m.id,
                    full_id: m.id,
                  });
                }
              }
            }
          } catch {}
        }
        // If no agentDir models, fall back to defaults.models keys
        if (!availableModels.length) {
          availableModels = allDefinedModels.map(m => {
            const slash = m.indexOf('/');
            return {
              provider: slash >= 0 ? m.slice(0, slash) : m,
              model_id: m,
              full_id: m,
            };
          });
        }
        // Determine current model: agent override or default
        const agentModel = agent.model || agent.modelOverride || '';
        const currentModel = agentModel || defaultModel;
        return {
          id: agentId,
          name: agent.identity?.name || agent.name || agentId,
          current_model: currentModel,
          available_models: availableModels,
        };
      });

      return sendJson(res, 200, { agents });
    } catch (e) {
      return sendJson(res, 500, { error: e.message });
    }
  }

  if (method === 'POST' && pathname === '/api/agent-model') {
    if (!requireAuth(req, res)) return;
    try {
      const body = JSON.parse(await readBody(req) || '{}');
      const { agent_id, model_id, fallbacks } = body;
      if (!agent_id) return sendJson(res, 400, { error: 'agent_id required' });

      const openclawPath = path.join(WORKSPACE_ROOT, '..', 'openclaw.json');

      // Rotate backup before write
      const ts = new Date().toISOString().replace(/[:.]/g, '-');
      const bakPath = `${openclawPath}.bak.${ts}`;
      try { fs.copyFileSync(openclawPath, bakPath); } catch {}

      const cfg = JSON.parse(fs.readFileSync(openclawPath, 'utf8'));
      const agentsList = cfg.agents?.list || [];
      const idx = agentsList.findIndex(a => a.id === agent_id);
      if (idx === -1) return sendJson(res, 404, { error: 'agent not found' });

      const agent = agentsList[idx];
      const isDefault = !model_id || model_id === 'default' || model_id === '';

      if (isDefault) {
        // Remove override — agent falls back to defaults.model
        delete agent.model;
        delete agent.modelOverride;
        delete agent.fallbacks;
      } else {
        agent.model = model_id;
        if (fallbacks && Array.isArray(fallbacks) && fallbacks.length) {
          agent.fallbacks = fallbacks;
        } else {
          delete agent.fallbacks;
        }
      }

      agentsList[idx] = agent;
      cfg.agents.list = agentsList;

      // Atomic write
      const tmpPath = `${openclawPath}.tmp`;
      fs.writeFileSync(tmpPath, JSON.stringify(cfg, null, 2) + '\n');
      fs.renameSync(tmpPath, openclawPath);

      return sendJson(res, 200, {
        ok: true,
        agent_id,
        model: isDefault ? null : model_id,
        fallbacks: isDefault ? null : (fallbacks || null),
        is_default: isDefault,
      });
    } catch (e) {
      return sendJson(res, 500, { error: e.message });
    }
  }

  // ── Capture ──
  if (pathname === '/api/capture') {
    if (method === 'GET') return sendJson(res, 200, stores.captures.all().slice(-200).reverse());
    if (method === 'POST') {
      try {
        const body = JSON.parse(await readBody(req));
        const { text = '', source = 'dashboard', intent: overrideIntent = '' } = body;
        const raw = String(text || '').trim();
        if (!raw) return sendJson(res, 400, { error: 'text required' });
        const classified = classifyIntent(raw);
        const allowed = new Set(['idea', 'task', 'question', 'trade_thesis', 'project', 'clip', 'journal']);
        const intent = allowed.has(overrideIntent) ? overrideIntent : classified;
        const capture = stores.captures.append({ raw_text: raw, text: cleanCaptureText(raw), intent, source, status: 'captured' });
        const route = routeCapture(capture, raw, intent);
        stores.captures.patch(capture.id, { status: 'routed', route });
        const routed = { ...capture, status: 'routed', route };
        broadcast('capture', routed);
        return sendJson(res, 201, routed);
      } catch(e) { return sendJson(res, 400, { error: e.message }); }
    }
  }

  sendJson(res, 404, { error: 'Not found' });
}

// ─── Daily Brief Generator (shared) ──────────────────────────
async function generateDailyBrief() {
  const agents  = getAgentConfig().map(a => a.name).join(', ');
  const cronJobs = getCronJobs().slice(0, 5).map(j => j.job_name).join(', ');
  const signals  = stores.signals.all().filter(s => s.status === 'watching').slice(0, 3)
    .map(s => `${s.direction?.toUpperCase()} ${s.ticker}`).join(', ') || 'none';
  const emails   = stores.emailInbox.all().filter(e => e.status === 'unread').length;
  const topForecasts = stores.forecasts.all().slice(-20)
    .sort((a, b) => Math.abs(b.score || 0) - Math.abs(a.score || 0)).slice(0, 3)
    .map(f => `${f.direction?.toUpperCase()} ${f.ticker} (score ${f.score})`).join(', ') || 'none';
  const prompt = `Generate a concise Morning Brief for my AI agent operating system.\n\nAgent crew: ${agents}\nScheduled jobs today: ${cronJobs}\nActive trading signals: ${signals}\nTop forecast signals: ${topForecasts}\nUnread emails: ${emails}\n\nFormat:\n• 1-sentence macro market summary\n• Top 3 priorities for today\n• Any alerts or risks to be aware of\n• Motivational closer (1 sentence)\n\nBe specific, actionable, and energising.`;
  const reply = await runAgent('main', prompt);
  const brief = stores.dailyBrief.append({ content: reply, generated_by: 'scheduled' });
  broadcast('system-event', { type: 'brief-ready', brief });

  // Write to vault _daily/<date>.md
  const date = new Date().toISOString().slice(0, 10);
  const dailyDir = path.join(VAULT_ROOT, '_daily');
  fs.mkdirSync(dailyDir, { recursive: true });
  fs.writeFileSync(path.join(dailyDir, `${date}.md`), [
    `---\ndate: ${date}\ngenerated: true\ntags: [daily]\n---`,
    `# Daily Brief — ${date}`,
    `\n${reply}\n`,
    `---\n_Generated by Atlas at ${new Date().toISOString()}_`,
  ].join('\n'));

  return brief;
}

// ─── Weekly Review Generator ─────────────────────────────────
async function generateWeeklyReview() {
  const now = new Date();
  const weekStart = new Date(now);
  weekStart.setDate(now.getDate() - now.getDay()); // Sunday
  weekStart.setHours(0, 0, 0, 0);

  // Collect this week's daily briefs from vault
  const dailyDir = path.join(VAULT_ROOT, '_daily');
  let dailyContent = '';
  try {
    for (const f of fs.readdirSync(dailyDir).sort()) {
      if (!f.endsWith('.md')) continue;
      const d = new Date(f.replace('.md', ''));
      if (d >= weekStart) {
        dailyContent += fs.readFileSync(path.join(dailyDir, f), 'utf8').slice(0, 600) + '\n\n';
      }
    }
  } catch {}

  // Collect this week's Why notes from vault
  const whyDir = path.join(VAULT_ROOT, 'trading', 'whys');
  let whyContent = '';
  try {
    for (const f of fs.readdirSync(whyDir).sort().slice(-5)) {
      if (!f.endsWith('.md')) continue;
      whyContent += fs.readFileSync(path.join(whyDir, f), 'utf8').slice(0, 400) + '\n\n';
    }
  } catch {}

  // Collect recent captures
  const captures = stores.captures.all().filter(c => new Date(c.created_at) >= weekStart)
    .slice(-20).map(c => `• [${c.intent}] ${c.raw_text || c.text}`).join('\n');

  // Recent fills / trades
  const fills = stores.journal.all().filter(j => new Date(j.ts || j.created_at) >= weekStart)
    .slice(-10).map(j => `• ${j.side?.toUpperCase()} ${j.qty}x ${j.symbol} @ ${j.fill_price || j.price}`).join('\n');

  const weekNum = Math.ceil((now - new Date(now.getFullYear(), 0, 1)) / 604800000);
  const weekLabel = `${now.getFullYear()}-W${String(weekNum).padStart(2, '0')}`;

  const prompt = `Generate a weekly review for my AI agent operating system.\n\nWeek: ${weekLabel}\n\nDaily briefs this week:\n${dailyContent || 'None yet'}\n\nTrading Why notes:\n${whyContent || 'None'}\n\nCaptures this week:\n${captures || 'None'}\n\nTrade fills:\n${fills || 'None'}\n\nFormat the review as:\n## Week in Review — ${weekLabel}\n### What happened\n(3-5 bullet summary)\n### Trading\n(performance and key decisions)\n### Captures & Ideas\n(recurring themes)\n### Next week focus\n(2-3 priorities)\n\nBe specific, honest, and actionable.`;

  const reply = await runAgent('main', prompt);
  const weeklyDir = path.join(VAULT_ROOT, '_weekly');
  fs.mkdirSync(weeklyDir, { recursive: true });
  fs.writeFileSync(path.join(weeklyDir, `${weekLabel}.md`), [
    `---\nweek: ${weekLabel}\ngenerated: true\ntags: [weekly]\n---`,
    reply,
    `\n---\n_Generated by Atlas at ${now.toISOString()}_`,
  ].join('\n'));

  const brief = stores.weeklyBrief.append({ week: weekLabel, content: reply, generated_at: now.toISOString() });
  broadcast('system-event', { type: 'weekly-review-ready', week: weekLabel });
  return brief;
}

// ─── Daily Brief Scheduler ───────────────────────────────────
function scheduleDailyBrief() {
  const now = new Date();
  const next = new Date(now);
  next.setDate(now.getDate() + 1);
  next.setHours(7, 0, 0, 0);
  const delay = next - now;
  setTimeout(async () => {
    try { await generateDailyBrief(); } catch {}
    scheduleDailyBrief();
  }, delay);
}

// ─── Weekly Review Scheduler ─────────────────────────────────
function scheduleWeeklyReview() {
  const now = new Date();
  const next = new Date(now);
  const daysUntilSun = (7 - now.getDay()) % 7 || 7; // days until next Sunday (always ≥1)
  next.setDate(now.getDate() + daysUntilSun);
  next.setHours(20, 0, 0, 0);
  const delay = next - now;
  setTimeout(async () => {
    try { await generateWeeklyReview(); } catch {}
    scheduleWeeklyReview(); // reschedule next week
  }, delay);
}

// ─── HTTP Server ─────────────────────────────────────────────
const server = http.createServer(async (req, res) => {
  const url = new URL(req.url, `http://${req.headers.host || `${HOST}:${PORT}`}`);
  // /healthz — unauthenticated, for monitoring
  if (url.pathname === '/healthz') return handleApi(req, res, url);

  // SSE endpoint: browsers don't send Basic Auth with EventSource
  if (url.pathname !== '/api/events' && !requireAuth(req, res)) return;

  if (url.pathname.startsWith('/api/')) return handleApi(req, res, url);
  // Favicon
  if (url.pathname === '/favicon.ico') { res.writeHead(204); res.end(); return; }


  // Static file serving
  const safeName = path.normalize(decodeURIComponent(url.pathname)).replace(/^([/\\]*\.\.[/\\]*)+/, '');
  let filePath = path.join(ROOT, safeName === '/' ? 'index.html' : safeName);
  if (!filePath.startsWith(ROOT)) { res.writeHead(403); res.end('Forbidden'); return; }

  fs.stat(filePath, (err, stat) => {
    if (err || !stat.isFile()) filePath = path.join(ROOT, 'index.html');
    fs.readFile(filePath, (readErr, data) => {
      if (readErr) { res.writeHead(404); res.end('Not found'); return; }
      const ext = path.extname(filePath).toLowerCase();
      const mime = { '.html': 'text/html; charset=utf-8', '.js': 'text/javascript; charset=utf-8', '.css': 'text/css; charset=utf-8', '.json': 'application/json; charset=utf-8', '.svg': 'image/svg+xml', '.png': 'image/png', '.jpg': 'image/jpeg', '.ico': 'image/x-icon' }[ext] || 'application/octet-stream';
      const etag = `"${stat.size.toString(16)}-${stat.mtimeMs.toString(16)}"`;
      if (req.headers['if-none-match'] === etag) {
        res.writeHead(304); res.end(); return;
      }
      gzipOrRaw(res, data, {
        'Content-Type': mime,
        'Cache-Control': filePath.endsWith('index.html') ? 'no-cache, must-revalidate' : 'public, max-age=3600',
        'ETag': etag,
      });
    });
  });
});

// ─── Price Alert Checker ─────────────────────────────────────
function startPriceAlertChecker() {
  setInterval(async () => {
    const alerts = stores.priceAlerts.all().filter(a => !a.triggered);
    if (!alerts.length) return;
    const tickers = [...new Set(alerts.map(a => a.ticker))];
    try {
      const quotes = await Promise.allSettled(tickers.map(t => yahooQuote(t)));
      const priceMap = {};
      quotes.forEach((r, i) => { if (r.status === 'fulfilled') priceMap[tickers[i]] = r.value.price; });
      alerts.forEach(alert => {
        const price = priceMap[alert.ticker];
        if (!price) return;
        const triggered = (alert.condition === 'above' && price > alert.target) ||
                          (alert.condition === 'below' && price < alert.target);
        if (triggered) {
          stores.priceAlerts.patch(alert.id, { triggered: true, triggered_at: new Date().toISOString(), triggered_price: price });
          const msg = `🔔 Price Alert: ${alert.ticker} is ${alert.condition} $${alert.target} (now $${price.toFixed(2)})`;
          broadcast('system-event', { type: 'price-alert', ticker: alert.ticker, price, target: alert.target, condition: alert.condition, message: msg });
          notifyDiscord(msg);
        }
      });
    } catch {}
  }, 60000);
}

// ─── Port Pre-flight & Graceful Shutdown ─────────────────────
function checkPortFree(port, host) {
  return new Promise((resolve, reject) => {
    const tester = net.createServer()
      .once('error', err => {
        if (err.code === 'EADDRINUSE') reject(new Error(`Port ${port} already in use. Free it with: fuser -k ${port}/tcp`));
        else reject(err);
      })
      .once('listening', () => tester.close(resolve));
    tester.listen(port, host);
  });
}

let shuttingDown = false;
function gracefulShutdown(signal) {
  if (shuttingDown) return;
  shuttingDown = true;
  console.log(`▒ ${signal} — graceful shutdown`);
  if (scheduler) scheduler.stop?.();
  CLI_SESSIONS.forEach(sess => { try { sess.proc?.kill('SIGTERM'); } catch {} });
  CLI_SESSIONS.clear();
  server.close(() => { console.log('▒ Server closed'); process.exit(0); });
  setTimeout(() => { console.log('▒ Forced exit'); process.exit(1); }, 5000).unref();
}
process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT',  () => gracefulShutdown('SIGINT'));

