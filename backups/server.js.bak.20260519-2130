        sources.map(s => `- [${s.headline}](${s.url || '#'}) — _${s.source}_${s.sentiment ? ' · ' + s.sentiment : ''}`).join('\n'),
        `\n[[_daily/${date}]] [[trading/${ticker}]]`,
      ].join('\n'));

      ensureTickerPage(ticker, { lastPrice: price, lastWhy: explanation }).catch(() => {});
      return sendJson(res, 200, { ticker, price, pct_change: pctChange, explanation, sources, sentiment_score: avgSentScore, sentiment_label: sentLabel, vault_file: vaultFile });
    } catch(e) { return sendJson(res, 500, { error: e.message }); }
