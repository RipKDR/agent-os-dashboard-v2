      log.info('Risk config updated via API', { updates: parsed });
      return sendJson(res, 200, { ok: true, config: globalThis._riskEngine.config });
    } catch (e) {
      return sendJson(res, 500, { error: e.message });
    }
  }

  if (method === 'POST' && pathname === '/api/trading/risk/update') {
    try {
      if (!globalThis._riskEngine) {
        const { createTradingSystem } = require('../trading');
        globalThis._riskEngine = createTradingSystem().risk;
      }
      const body = await readBody(req);
      const parsed = JSON.parse(body);
      if (!parsed || typeof parsed.capital !== 'number' || parsed.capital <= 0) {
        return sendJson(res, 400, { error: 'capital must be a positive number' });
